<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TourGuideAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TourGuideAPP"
    xmlns:views="clr-namespace:TourGuideAPP.Views"
    xmlns:res="clr-namespace:TourGuideAPP.Resources.Strings"
    Title="TourGuideAPP"
    Shell.TabBarBackgroundColor="#1A1410"
    Shell.TabBarForegroundColor="#C8A96E"
    Shell.TabBarUnselectedColor="#3A2D22"
    Shell.TabBarTitleColor="#C8A96E"
    BackgroundColor="#0F0E0D">

    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="Shell" ApplyToDerivedTypes="True">
                <Setter Property="Shell.TabBarBackgroundColor" Value="#1A1410"/>
                <Setter Property="Shell.TabBarForegroundColor" Value="#C8A96E"/>
                <Setter Property="Shell.TabBarUnselectedColor" Value="#3A2D22"/>
                <Setter Property="Shell.TabBarTitleColor" Value="#C8A96E"/>
                <Setter Property="Shell.BackgroundColor" Value="#0F0E0D"/>
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar Route="MainTabs">

        <ShellContent
            Title="{x:Static res:AppResources.TabTours}"
            Route="ToursPage"
            Icon="icon_tour.svg"
            ContentTemplate="{DataTemplate views:ToursPage}" />

        <ShellContent
            Title="{x:Static res:AppResources.TabFeatured}"
            Route="MainPage"
            Icon="icon_trending.svg"
            ContentTemplate="{DataTemplate local:MainPage}" />

        <ShellContent
            Title="{x:Static res:AppResources.TabMap}"
            Route="MapPage"
            Icon="icon_map.svg"
            ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent
            Title="{x:Static res:AppResources.TabSettings}"
            Route="AccountPage"
            Icon="icon_account.svg"
            ContentTemplate="{DataTemplate views:AccountPage}" />

    </TabBar>

</Shell>
