<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.MainPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="#0F0E0D">
        <VerticalStackLayout Padding="0" Spacing="0" BackgroundColor="#0F0E0D">

            <!-- ═══ HEADER ═══ -->
            <Border BackgroundColor="#1A1410"
                    StrokeShape="RoundRectangle 0"
                    Stroke="Transparent"
                    Padding="20,52,20,20">

                <VerticalStackLayout Spacing="0">

                    <!-- Top row: user info + icons -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">

                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="CHÀO BUỔI SÁNG,"
                                   FontSize="9"
                                   CharacterSpacing="3"
                                   TextColor="#5A4A3A"
                                   FontAttributes="Bold"/>
                            <Label x:Name="UserLabel"
                                   Text="Lữ khách Sài Gòn"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#F0E6D3"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1"
                                               Spacing="8"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center">
                            <Border BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="Transparent"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMapClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="🗺️"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Border BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="Transparent"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStartGpsClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="📡"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Border BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="Transparent"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQRScanClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="📷"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>

                    </Grid>

                    <!-- Search bar -->
                    <Border BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#3A2D22"
                            StrokeThickness="1"
                            Padding="14,10">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0"
                                   Text="🔍"
                                   FontSize="15"
                                   VerticalOptions="Center"
                                   TextColor="#5A4A3A"/>
                            <Entry x:Name="SearchEntry"
                                   Grid.Column="1"
                                   Placeholder="Tìm quán ăn, cà phê..."
                                   PlaceholderColor="#5A4A3A"
                                   TextColor="#F0E6D3"
                                   BackgroundColor="Transparent"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   TextChanged="OnSearchTextChanged"/>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ═══ GPS STATUS ═══ -->
            <Border x:Name="GpsCard"
                    BackgroundColor="#1A1410"
                    StrokeShape="RoundRectangle 0"
                    Stroke="Transparent"
                    Padding="20,10,20,12"
                    IsVisible="False">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="📍"
                           FontSize="14"
                           VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label x:Name="GpsLabel"
                               Text="Chờ GPS..."
                               FontSize="11"
                               TextColor="#5A4A3A"/>
                        <Label x:Name="POILabel"
                               Text="🏛️ Chưa xác định điểm gần nhất"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#C8A96E"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Label x:Name="StatusLabel"
                   Text=""
                   FontSize="11"
                   TextColor="#5A4A3A"
                   IsVisible="False"
                   HorizontalOptions="Center"
                   Padding="0,6"/>

            <!-- ═══ LOCATION PILL ═══ -->
            <Border BackgroundColor="#1A1410"
                    StrokeShape="RoundRectangle 0"
                    Stroke="Transparent"
                    Padding="20,12,20,0">
                <Border BackgroundColor="#26201A"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#3A2D22"
                        StrokeThickness="1"
                        Padding="12,8">
                    <Grid ColumnDefinitions="Auto,*">
                        <BoxView Grid.Column="0"
                                 WidthRequest="6"
                                 HeightRequest="6"
                                 CornerRadius="3"
                                 BackgroundColor="#C8A96E"
                                 VerticalOptions="Center"
                                 Margin="0,0,8,0"/>
                        <Label Grid.Column="1"
                               x:Name="UserLocationLabel"
                               Text="📍 10.759917, 106.682257 · Quận 1, TP.HCM"
                               FontSize="10"
                               TextColor="#8A7560"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </Border>

            <!-- ═══ CATEGORIES ═══ -->
            <VerticalStackLayout BackgroundColor="#1A1410"
                                 Padding="20,16,20,16">

                <Label Text="KHÁM PHÁ THEO DANH MỤC"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#5A4A3A"
                       FontAttributes="Bold"
                       Margin="0,0,0,10"/>

                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8">

                        <Border x:Name="ChipAll"
                                BackgroundColor="#1A1410"
                                StrokeShape="RoundRectangle 20"
                                Stroke="#C8A96E"
                                StrokeThickness="1"
                                Padding="14,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCategoryAllTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="ChipAllLabel"
                                   Text="Tất cả"
                                   TextColor="#C8A96E"
                                   FontSize="11"
                                   FontAttributes="Bold"/>
                        </Border>

                        <Border x:Name="ChipCafe"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                Padding="14,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCategoryCafeTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="ChipCafeLabel"
                                   Text="☕ Cà phê"
                                   TextColor="#8A7560"
                                   FontSize="11"/>
                        </Border>

                        <Border x:Name="ChipRice"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                Padding="14,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCategoryRiceTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="ChipRiceLabel"
                                   Text="🍲 Cơm"
                                   TextColor="#8A7560"
                                   FontSize="11"/>
                        </Border>

                        <Border x:Name="ChipBeer"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                Padding="14,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCategoryBeerTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="ChipBeerLabel"
                                   Text="🍺 Quán nhậu"
                                   TextColor="#8A7560"
                                   FontSize="11"/>
                        </Border>

                        <Border x:Name="ChipBubbleTea"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                Padding="14,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCategoryBubbleTeaTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="ChipBubbleTeaLabel"
                                   Text="🧋 Trà sữa"
                                   TextColor="#8A7560"
                                   FontSize="11"/>
                        </Border>

                    </HorizontalStackLayout>
                </ScrollView>

            </VerticalStackLayout>

            <!-- ═══ FEATURED SECTION HEADER ═══ -->
            <Grid ColumnDefinitions="*,Auto"
                  Padding="20,16,20,12"
                  BackgroundColor="#0F0E0D">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="ĐỊA ĐIỂM NỔI BẬT"
                           FontSize="9"
                           CharacterSpacing="3"
                           FontAttributes="Bold"
                           TextColor="#C8A96E"/>
                    <Label Text="Hành trình vị giác"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#F0E6D3"/>
                </VerticalStackLayout>
                <Label Grid.Column="1"
                       Text="Xem tất cả →"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#C8A96E"
                       VerticalOptions="End"
                       Margin="0,0,0,4"/>
            </Grid>

            <!-- ═══ PLACES LIST ═══ -->
            <CollectionView x:Name="PlacesCollection"
                            ItemsLayout="VerticalList"
                            Margin="20,0,20,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <!-- Place Card -->
                        <Border BackgroundColor="#1A1410"
                                StrokeShape="RoundRectangle 18"
                                Stroke="#2A2018"
                                StrokeThickness="1"
                                Margin="0,0,0,14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlaceTapped"/>
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="150,Auto">

                                <!-- Place image with badge overlay -->
                                <Grid Grid.Row="0">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="150"/>
                                    <!-- Category badge top-right -->
                                    <Border BackgroundColor="#C8A96E"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            Padding="8,4"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="0,10,10,0">
                                        <Label Text="Đặc trưng"
                                               FontSize="9"
                                               FontAttributes="Bold"
                                               TextColor="#1A1410"/>
                                    </Border>
                                </Grid>

                                <!-- Card body -->
                                <VerticalStackLayout Grid.Row="1"
                                                     Padding="16,12,16,14"
                                                     Spacing="6">

                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#F0E6D3"/>

                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="#5A4A3A"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>

                                    <!-- Meta row: address + time -->
                                    <HorizontalStackLayout Spacing="12" Margin="0,4,0,0">
                                        <Label Text="{Binding Address, StringFormat='📍 {0}'}"
                                               FontSize="10"
                                               TextColor="#8A7560"/>
                                        <Label Text="{Binding OpenTime, StringFormat='🕐 {0}'}"
                                               FontSize="10"
                                               TextColor="#C8A96E"/>
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
