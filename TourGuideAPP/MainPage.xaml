<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.MainPage"
             BackgroundColor="{StaticResource Secondary}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="16,48,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label x:Name="UserLabel"
                       Text="👤 Khách"
                       FontSize="12"
                       TextColor="{StaticResource Secondary}"/>
                <Label Text="📍 Khánh Hội, Quận 4"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="White"/>
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="1" Spacing="12">
                <Button Text="🗺️"
                        Clicked="OnMapClicked"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="White"
                        CornerRadius="20"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"/>
                <Button x:Name="LoginButton"
                        Text="Đăng nhập"
                        Clicked="OnLoginClicked"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        FontSize="13"
                        Padding="12,0"/>
                <Button x:Name="LogoutButton"
                        Text="Đăng xuất"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        FontSize="13"
                        Padding="12,0"
                        IsVisible="False"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- Search + Action Buttons -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="{StaticResource Primary}" Padding="16,0,16,16" Spacing="12">

            <!-- Search Bar -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="0" BorderColor="Transparent">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center" Margin="12,0,0,0"/>
                    <Entry Grid.Column="1"
                           Placeholder="Tìm quán ăn..."
                           PlaceholderColor="#AAAAAA"
                           TextColor="{StaticResource OnSurface}"
                           BackgroundColor="Transparent"
                           Margin="8,8"/>
                </Grid>
            </Frame>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button Text="🚀 GPS"
                        Clicked="OnStartGpsClicked"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        Padding="16,0"
                        FontSize="13"/>
                <Button Text="📷 Quét QR"
                        Clicked="OnQRScanClicked"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        Padding="16,0"
                        FontSize="13"/>
                <Button Text="🎙️ Thuyết minh"
                        Clicked="OnNarrationClicked"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        Padding="16,0"
                        FontSize="13"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- GPS Status Card -->
                <Frame x:Name="GpsCard"
                       BackgroundColor="White"
                       CornerRadius="12"
                       Padding="16"
                       BorderColor="#E0E0E0"
                       IsVisible="False">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="GpsLabel"
                               Text="📍 Chờ GPS..."
                               FontSize="13"
                               TextColor="#666666"/>
                        <Label x:Name="POILabel"
                               Text="🏛️ Chưa xác định điểm gần nhất"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#E94560"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Status -->
                <Label x:Name="StatusLabel"
                       Text=""
                       FontSize="12"
                       TextColor="#AAAAAA"
                       HorizontalOptions="Center"
                       IsVisible="False"/>

                <!-- Categories -->
                <Label Text="Danh mục"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1A1A2E"/>

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="12">
                        <Frame BackgroundColor="#E94560" CornerRadius="20" Padding="16,8" BorderColor="Transparent">
                            <Label Text="🍜 Tất cả" TextColor="White" FontSize="13"/>
                        </Frame>
                        <Frame BackgroundColor="White" CornerRadius="20" Padding="16,8" BorderColor="#E0E0E0">
                            <Label Text="🍺 Quán nhậu" TextColor="#333333" FontSize="13"/>
                        </Frame>
                        <Frame BackgroundColor="White" CornerRadius="20" Padding="16,8" BorderColor="#E0E0E0">
                            <Label Text="☕ Cà phê" TextColor="#333333" FontSize="13"/>
                        </Frame>
                        <Frame BackgroundColor="White" CornerRadius="20" Padding="16,8" BorderColor="#E0E0E0">
                            <Label Text="🍲 Cơm" TextColor="#333333" FontSize="13"/>
                        </Frame>
                        <Frame BackgroundColor="White" CornerRadius="20" Padding="16,8" BorderColor="#E0E0E0">
                            <Label Text="🧋 Trà sữa" TextColor="#333333" FontSize="13"/>
                        </Frame>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Nearby Section -->
                <Label Text="🏛️ Địa điểm nổi bật"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1A1A2E"/>

                <!-- Place Cards -->
                <CollectionView x:Name="PlacesCollection">
    <CollectionView.ItemTemplate>
        <DataTemplate>
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   Padding="0"
                   BorderColor="#E0E0E0"
                   Margin="0,0,0,12">
                
                <!-- Thêm TapGestureRecognizer trực tiếp vào Frame -->
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPlaceTapped"/>
                </Frame.GestureRecognizers>
                
                <Grid RowDefinitions="180,Auto">
                    <Image Grid.Row="0"
                           Source="{Binding ImageUrl}"
                           Aspect="AspectFill"
                           HeightRequest="180"/>
                    <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                        <Label Text="{Binding Name}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A2E"/>
                        <Label Text="{Binding Description}"
                               FontSize="13"
                               TextColor="#666666"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"/>
                        <HorizontalStackLayout Spacing="16" Margin="0,4,0,0">
                            <Label Text="{Binding Address, StringFormat='📍 {0}'}"
                                   FontSize="12"
                                   TextColor="#AAAAAA"/>
                            <Label Text="{Binding OpenTime, StringFormat='🕐 {0}'}"
                                   FontSize="12"
                                   TextColor="#AAAAAA"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Frame>
        </DataTemplate>
    </CollectionView.ItemTemplate>
</CollectionView>

                <Label x:Name="POICountLabel"
                       Text=""
                       FontSize="12"
                       TextColor="#AAAAAA"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>