<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:TourGuideAPP.Resources.Strings"
             x:Class="TourGuideAPP.Views.AccountPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="#0F0E0D">
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ═══ HEADER ═══ -->
            <VerticalStackLayout BackgroundColor="#1A1410"
                                 Padding="20,52,20,20"
                                 Spacing="4">
                <Label Text="{x:Static res:AppResources.AccApp}"
                       FontSize="10"
                       CharacterSpacing="4"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"/>
                <Label Text="{x:Static res:AppResources.AccSettings}"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#F0E6D3"/>
            </VerticalStackLayout>

            <!-- ═══ TRẢI NGHIỆM ═══ -->
            <VerticalStackLayout Padding="20,24,20,0" Spacing="10">

                <Label Text="{x:Static res:AppResources.AccExperience}"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,4"/>

                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#2A2018"
                        StrokeThickness="1">
                    <VerticalStackLayout>

                        <!-- Giọng đọc TTS -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🗣️" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccTtsVoice}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label x:Name="TtsLocaleSubtitle"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="2"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#3A2D22"
                                    StrokeThickness="1"
                                    Padding="4,2">
                                <Picker x:Name="TtsLocalePicker"
                                        TextColor="#C8A96E"
                                        BackgroundColor="Transparent"
                                        FontSize="12"
                                        SelectedIndexChanged="OnTtsLocaleChanged"/>
                            </Border>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Thông báo -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🔔" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccNotifications}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccNotificationsOn}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2"
                                    IsToggled="True"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Chế độ tối -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🌙" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccDarkMode}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccDarkModeOn}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2"
                                    IsToggled="True"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"
                                    VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ═══ BẢN ĐỒ & VỊ TRÍ ═══ -->
            <VerticalStackLayout Padding="20,20,20,0" Spacing="10">

                <Label Text="{x:Static res:AppResources.AccMapSection}"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,4"/>

                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#2A2018"
                        StrokeThickness="1">
                    <VerticalStackLayout>

                        <!-- GPS tự động -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📡" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccGpsAuto}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccGpsAutoSub}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2"
                                    IsToggled="True"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Bán kính tìm kiếm -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📍" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccSearchRadius}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccSearchRadiusVal}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ═══ THÔNG TIN ỨNG DỤNG ═══ -->
            <VerticalStackLayout Padding="20,20,20,100" Spacing="10">

                <Label Text="{x:Static res:AppResources.AccInfoSection}"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,4"/>

                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#2A2018"
                        StrokeThickness="1">
                    <VerticalStackLayout>

                        <!-- Về ứng dụng -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="ℹ️" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccAbout}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccVersion}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Hướng dẫn sử dụng -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📖" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccUserGuide}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccUserGuideSub}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Xóa cache -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🗑️" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.AccClearCache}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="{x:Static res:AppResources.AccClearCacheSub}"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- DEV ONLY: huỷ kích hoạt để test luồng thanh toán -->
            <Label Text="{x:Static res:AppResources.AccDevDeactivate}"
                   TextColor="#5A4A3A"
                   FontSize="12"
                   HorizontalOptions="Center"
                   Margin="0,16,0,32">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDevDeactivateTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
