<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.AccountPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="#0F0E0D">
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- ═══ HEADER ═══ -->
            <VerticalStackLayout BackgroundColor="#1A1410"
                                 Padding="20,52,20,20"
                                 Spacing="4">
                <Label Text="ỨNG DỤNG"
                       FontSize="10"
                       CharacterSpacing="4"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"/>
                <Label Text="Cài đặt"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#F0E6D3"/>
            </VerticalStackLayout>

            <!-- ═══ TRẢI NGHIỆM ═══ -->
            <VerticalStackLayout Padding="20,24,20,0" Spacing="10">

                <Label Text="— TRẢI NGHIỆM"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,4"/>

                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#2A2018"
                        StrokeThickness="1">
                    <VerticalStackLayout>

                        <!-- Ngôn ngữ -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🌐" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Ngôn ngữ"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Tiếng Việt"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Thông báo -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🔔" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Thông báo"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Bật"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2"
                                    IsToggled="True"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Chế độ tối -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🌙" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Chế độ tối"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Đang bật"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2"
                                    IsToggled="True"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"
                                    VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ═══ BẢN ĐỒ & VỊ TRÍ ═══ -->
            <VerticalStackLayout Padding="20,20,20,0" Spacing="10">

                <Label Text="— BẢN ĐỒ &amp; VỊ TRÍ"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,4"/>

                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#2A2018"
                        StrokeThickness="1">
                    <VerticalStackLayout>

                        <!-- GPS tự động -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📡" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="GPS tự động"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Tự bật khi mở app"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2"
                                    IsToggled="True"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Bán kính tìm kiếm -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📍" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Bán kính tìm kiếm"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="500m"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ═══ THÔNG TIN ỨNG DỤNG ═══ -->
            <VerticalStackLayout Padding="20,20,20,100" Spacing="10">

                <Label Text="— THÔNG TIN"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,4"/>

                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#2A2018"
                        StrokeThickness="1">
                    <VerticalStackLayout>

                        <!-- Về ứng dụng -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="ℹ️" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Về ứng dụng"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Phiên bản 1.0.0"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Hướng dẫn sử dụng -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📖" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Hướng dẫn sử dụng"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Xem cách dùng app"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView BackgroundColor="#2A2018" HeightRequest="1" Margin="16,0"/>

                        <!-- Xóa cache -->
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="#26201A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="🗑️" FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="Xóa bộ nhớ đệm"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#F0E6D3"/>
                                <Label Text="Giải phóng dung lượng"
                                       FontSize="11" TextColor="#5A4A3A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="20" TextColor="#C8A96E"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
