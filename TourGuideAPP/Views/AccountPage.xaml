<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.AccountPage"
             Title="Cá nhân">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <Border BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16"
                Margin="0,8,0,12">
            <VerticalStackLayout Spacing="8">
                <Label Text="Tài khoản"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />
                <Label x:Name="StatusLabel"
                       Text="👤 Khách"
                       FontSize="13"
                       TextColor="{StaticResource Muted}" />
            </VerticalStackLayout>
        </Border>

        <HorizontalStackLayout Grid.Row="1" Spacing="12">
            <Button x:Name="LoginBtn"
                    Text="Đăng nhập"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="14"
                    Clicked="OnLoginClicked"
                    HorizontalOptions="FillAndExpand" />
            <Button x:Name="LogoutBtn"
                    Text="Đăng xuất"
                    BackgroundColor="{StaticResource Tertiary}"
                    TextColor="White"
                    CornerRadius="14"
                    Clicked="OnLogoutClicked"
                    IsVisible="False"
                    HorizontalOptions="FillAndExpand" />
        </HorizontalStackLayout>

        <Border Grid.Row="2"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16"
                Margin="0,12,0,0">
            <VerticalStackLayout Spacing="12">
                <Label Text="Tiện ích"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <Button Grid.Row="0" Grid.Column="0"
                            Text="⭐ Lịch sử"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource Primary}"
                            CornerRadius="14"
                            Clicked="OnComingSoon" />
                    <Button Grid.Row="0" Grid.Column="1"
                            Text="🔔 Thông báo"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource Primary}"
                            CornerRadius="14"
                            Clicked="OnComingSoon" />
                    <Button Grid.Row="1" Grid.Column="0"
                            Text="⚙️ Cài đặt"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource Primary}"
                            CornerRadius="14"
                            Clicked="OnComingSoon" />
                    <Button Grid.Row="1" Grid.Column="1"
                            Text="🛟 Hỗ trợ"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource Primary}"
                            CornerRadius="14"
                            Clicked="OnComingSoon" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>

