<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.AccountPage"
             BackgroundColor="#FFEBE6"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,52,20,100" Spacing="0">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="2" Margin="0,0,0,24">
                <Label Text="CÁ NHÂN" FontSize="10" CharacterSpacing="4"
                       TextColor="#FF5722" FontAttributes="Bold"/>
                <Label Text="Tài khoản" FontSize="30" FontAttributes="Bold"
                       TextColor="#3D1C1C"/>
            </VerticalStackLayout>

            <!-- PROFILE CARD -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20"
                    Stroke="#FFEBE6" StrokeThickness="1"
                    Padding="20,24" Margin="0,0,0,16">
                <VerticalStackLayout Spacing="0">

                    <!-- Avatar + Status -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16"
                          Margin="0,0,0,16">
                        <Border Grid.Column="0" WidthRequest="64" HeightRequest="64"
                                StrokeShape="RoundRectangle 32"
                                BackgroundColor="#FF5722" Stroke="Transparent">
                            <Label Text="👤" FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4"
                                             VerticalOptions="Center">
                            <!-- x:Name="StatusLabel" — dùng bởi code-behind -->
                            <Label x:Name="StatusLabel"
                                   Text="👤 Khách"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#3D1C1C"/>
                            <!-- x:Name="SummaryLabel" — dùng bởi code-behind -->
                            <Label x:Name="SummaryLabel"
                                   Text="Yêu thích: 0 | Lịch sử: 0 | Ghi chú: 0 | Wishlist: 0"
                                   FontSize="11"
                                   TextColor="#A36765"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Divider -->
                    <BoxView BackgroundColor="#FFEBE6" HeightRequest="1"
                             Margin="0,0,0,16"/>

                    <!-- Login / Logout Buttons -->
                    <HorizontalStackLayout Spacing="12">
                        <!-- x:Name="LoginBtn" -->
                        <Button x:Name="LoginBtn"
                                Text="Đăng nhập"
                                Clicked="OnLoginClicked"
                                BackgroundColor="#FF5722"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="44"
                                FontSize="14"
                                FontAttributes="Bold"
                                Padding="24,0"/>
                        <!-- x:Name="LogoutBtn" -->
                        <Button x:Name="LogoutBtn"
                                Text="Đăng xuất"
                                Clicked="OnLogoutClicked"
                                BackgroundColor="#FFEBE6"
                                TextColor="#D32F2F"
                                CornerRadius="12"
                                HeightRequest="44"
                                FontSize="14"
                                Padding="24,0"
                                IsVisible="False"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- TIỆN ÍCH -->
            <Label Text="— TIỆN ÍCH" FontSize="10" CharacterSpacing="3"
                   TextColor="#FF5722" FontAttributes="Bold"
                   Margin="0,8,0,14"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12" Margin="0,0,0,24">

                <!-- Yêu thích -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="White" StrokeShape="RoundRectangle 16"
                        Stroke="#FFEBE6" StrokeThickness="1" Padding="18,20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFavoritesClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="⭐" FontSize="28"/>
                        <Label Text="Yêu thích" FontSize="15"
                               FontAttributes="Bold" TextColor="#3D1C1C"/>
                        <Label Text="Địa điểm đã lưu" FontSize="11"
                               TextColor="#A36765"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Lịch sử -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="White" StrokeShape="RoundRectangle 16"
                        Stroke="#FFEBE6" StrokeThickness="1" Padding="18,20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHistoryClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🗺️" FontSize="28"/>
                        <Label Text="Lịch sử" FontSize="15"
                               FontAttributes="Bold" TextColor="#3D1C1C"/>
                        <Label Text="Tour đã đi qua" FontSize="11"
                               TextColor="#A36765"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Ghi chú -->
                <Border Grid.Row="1" Grid.Column="0"
                        BackgroundColor="White" StrokeShape="RoundRectangle 16"
                        Stroke="#FFEBE6" StrokeThickness="1" Padding="18,20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotesClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📝" FontSize="28"/>
                        <Label Text="Ghi chú" FontSize="15"
                               FontAttributes="Bold" TextColor="#3D1C1C"/>
                        <Label Text="Ghi chép cá nhân" FontSize="11"
                               TextColor="#A36765"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Wishlist -->
                <Border Grid.Row="1" Grid.Column="1"
                        BackgroundColor="White" StrokeShape="RoundRectangle 16"
                        Stroke="#FFEBE6" StrokeThickness="1" Padding="18,20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWishlistClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="💝" FontSize="28"/>
                        <Label Text="Wishlist" FontSize="15"
                               FontAttributes="Bold" TextColor="#3D1C1C"/>
                        <Label Text="Muốn thử sau" FontSize="11"
                               TextColor="#A36765"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- CÀI ĐẶT -->
            <Label Text="— CÀI ĐẶT" FontSize="10" CharacterSpacing="3"
                   TextColor="#FF5722" FontAttributes="Bold"
                   Margin="0,0,0,14"/>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                    Stroke="#FFEBE6" StrokeThickness="1">
                <VerticalStackLayout>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="🌐" FontSize="20"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Ngôn ngữ" FontSize="15" TextColor="#3D1C1C"/>
                            <Label Text="Tiếng Việt" FontSize="12" TextColor="#A36765"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="#FF5722" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView BackgroundColor="#FFEBE6" HeightRequest="1" Margin="18,0"/>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="🔔" FontSize="20"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Thông báo" FontSize="15" TextColor="#3D1C1C"/>
                            <Label Text="Bật" FontSize="12" TextColor="#A36765"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="#FF5722" VerticalOptions="Center"/>
                    </Grid>
                    <BoxView BackgroundColor="#FFEBE6" HeightRequest="1" Margin="18,0"/>
                    <Grid Padding="18,16" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="ℹ️" FontSize="20"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Về ứng dụng" FontSize="15" TextColor="#3D1C1C"/>
                            <Label Text="Phiên bản 1.0.0" FontSize="12" TextColor="#A36765"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="#FF5722" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
