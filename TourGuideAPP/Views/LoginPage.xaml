<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.LoginPage"
             BackgroundColor="{StaticResource Secondary}"
             Title="Đăng nhập">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <!-- Logo -->
            <VerticalStackLayout Spacing="4" Margin="0,40,0,30">
                <Label Text="🗺️ TourGuide"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="Khám phá ẩm thực Sài Gòn"
                       FontSize="14"
                       TextColor="{StaticResource Muted}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Email -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="0" BorderColor="{StaticResource Gray100}">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       PlaceholderColor="{StaticResource Muted}"
                       TextColor="{StaticResource OnSurface}"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       Margin="16,12"/>
            </Frame>

            <!-- Password -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="0" BorderColor="{StaticResource Gray100}">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Mật khẩu"
                       PlaceholderColor="{StaticResource Muted}"
                       TextColor="{StaticResource OnSurface}"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Margin="16,12"/>
            </Frame>

            <!-- Error label -->
            <Label x:Name="ErrorLabel"
                   Text=""
                   TextColor="#E94560"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Login button -->
            <Button Text="Đăng nhập"
                    Clicked="OnLoginClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontAttributes="Bold"
                    Margin="0,8,0,0"/>

            <!-- Guest button -->
            <Button Text="Tiếp tục không đăng nhập"
                    Clicked="OnGuestClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    CornerRadius="12"
                    HeightRequest="44"
                    BorderColor="{StaticResource Primary}"
                    BorderWidth="1"/>

            <!-- Register link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Chưa có tài khoản?"
                       TextColor="{StaticResource Muted}"
                       FontSize="14"
                       VerticalOptions="Center"/>
                <Label Text="Đăng ký ngay"
                       TextColor="{StaticResource Tertiary}"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>