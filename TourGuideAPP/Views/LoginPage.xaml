<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.LoginPage"
             BackgroundColor="#FFEBE6"
             Shell.NavBarIsVisible="False"
             Title="Đăng nhập">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <!-- Logo -->
            <VerticalStackLayout Spacing="4" Margin="0,60,0,36">
                <!-- Icon -->
                <Border WidthRequest="72" HeightRequest="72"
                        StrokeShape="RoundRectangle 20"
                        BackgroundColor="#FF5722" Stroke="Transparent"
                        HorizontalOptions="Center">
                    <Label Text="🗺️" FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Label Text="TourGuide"
                       FontSize="32" FontAttributes="Bold"
                       TextColor="#3D1C1C"
                       HorizontalOptions="Center"
                       Margin="0,12,0,0"/>
                <Label Text="Khám phá ẩm thực Sài Gòn"
                       FontSize="14" TextColor="#A36765"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Email -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#FFAB40" StrokeThickness="1"
                    Padding="0">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       PlaceholderColor="#A36765"
                       TextColor="#3D1C1C"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       Margin="16,12"/>
            </Border>

            <!-- Password -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#FFAB40" StrokeThickness="1"
                    Padding="0">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Mật khẩu"
                       PlaceholderColor="#A36765"
                       TextColor="#3D1C1C"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Margin="16,12"/>
            </Border>

            <!-- Error label -->
            <Label x:Name="ErrorLabel"
                   Text=""
                   TextColor="#D32F2F"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Login button -->
            <Button Text="Đăng nhập"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#FF5722"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontAttributes="Bold"
                    FontSize="16"
                    Margin="0,8,0,0"/>

            <!-- Guest button -->
            <Button Text="Tiếp tục không đăng nhập"
                    Clicked="OnGuestClicked"
                    BackgroundColor="Transparent"
                    TextColor="#FF5722"
                    CornerRadius="12"
                    HeightRequest="48"
                    BorderColor="#FF5722"
                    BorderWidth="1.5"
                    FontSize="14"/>

            <!-- Register link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4"
                                   Margin="0,8,0,0">
                <Label Text="Chưa có tài khoản?"
                       TextColor="#A36765" FontSize="14"
                       VerticalOptions="Center"/>
                <Label Text="Đăng ký ngay"
                       TextColor="#D32F2F" FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
