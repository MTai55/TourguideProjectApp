<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="TourGuideAPP.Views.MapPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False"
             Title="Bản đồ">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0"
              BackgroundColor="#1A1410"
              ColumnDefinitions="*,Auto"
              Padding="20,52,20,16">

            <VerticalStackLayout Grid.Column="0" Spacing="3">
                <Label Text="KHÁM PHÁ"
                       FontSize="10"
                       CharacterSpacing="4"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"/>
                <Label Text="Bản đồ"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#F0E6D3"/>
            </VerticalStackLayout>

            <!-- Filter chips -->
            <ScrollView Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        VerticalOptions="End">
                <HorizontalStackLayout Spacing="6">
                    <Border BackgroundColor="#C8A96E"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="12,6">
                        <Label Text="Tất cả"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#1A1410"/>
                    </Border>
                    <Border BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="12,6">
                        <Label Text="☕ Cafe"
                               FontSize="10"
                               TextColor="#8A7560"/>
                    </Border>
                    <Border BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="12,6">
                        <Label Text="🍜 Ăn"
                               FontSize="10"
                               TextColor="#8A7560"/>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

        </Grid>

        <!-- ═══ MAP + OVERLAY ═══ -->
        <Grid Grid.Row="1">

            <!-- Mapsui MapControl — giữ nguyên -->
            <mapsui:MapControl x:Name="MyMap"/>

            <!-- Zoom controls -->
            <VerticalStackLayout HorizontalOptions="End"
                                 VerticalOptions="Start"
                                 Margin="0,12,12,0"
                                 Spacing="6">
                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2A2018"
                        StrokeThickness="1"
                        WidthRequest="38"
                        HeightRequest="38">
                    <Label Text="＋"
                           FontSize="18"
                           TextColor="#C8A96E"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2A2018"
                        StrokeThickness="1"
                        WidthRequest="38"
                        HeightRequest="38">
                    <Label Text="－"
                           FontSize="18"
                           TextColor="#C8A96E"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2A2018"
                        StrokeThickness="1"
                        WidthRequest="38"
                        HeightRequest="38"
                        Margin="0,4,0,0">
                    <Label Text="📍"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <!-- Bottom info panel -->
            <Border BackgroundColor="#1A1410"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    Stroke="#2A2018"
                    StrokeThickness="1"
                    Padding="20,16,20,32"
                    VerticalOptions="End">
                <VerticalStackLayout Spacing="12">

                    <!-- Drag handle -->
                    <BoxView WidthRequest="36"
                             HeightRequest="4"
                             CornerRadius="2"
                             BackgroundColor="#3A2D22"
                             HorizontalOptions="Center"
                             Margin="0,0,0,4"/>

                    <!-- Current location row -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                WidthRequest="36"
                                HeightRequest="36">
                            <Label Text="🏛️"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="2">
                            <Label x:Name="CurrentAddressLabel"
                                   Text="📍 Địa chỉ hiện tại: đang cập nhật..."
                                   FontSize="11"
                                   TextColor="#5A4A3A"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <Label x:Name="NearestPOILabel"
                                   Text="Chưa xác định điểm gần nhất"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#C8A96E"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Check-in button -->
                    <Border BackgroundColor="#C8A96E"
                            StrokeShape="RoundRectangle 14"
                            Stroke="Transparent"
                            Padding="0,13">
                        <Label Text="✓  Check-in chỗ gần nhất"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1A1410"
                               HorizontalOptions="Center"/>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </Grid>

    </Grid>

</ContentPage>
