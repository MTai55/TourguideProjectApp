<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="TourGuideAPP.Views.MapPage"
             Title="Bản đồ">

    <Grid>
        <mapsui:MapControl x:Name="MyMap" />

        <Frame BackgroundColor="{StaticResource Surface}"
               VerticalOptions="End"
               Margin="10"
               Padding="10"
               CornerRadius="10">
            <VerticalStackLayout>
                <Label x:Name="NearestPOILabel"
                       Text="🏛️ Chưa xác định điểm gần nhất"
                       FontSize="14"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" />
                <Button Text="✔️ Check-in chỗ gần nhất"
                        Clicked="OnNearestCheckInClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="14"
                        FontSize="12"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>

</ContentPage>