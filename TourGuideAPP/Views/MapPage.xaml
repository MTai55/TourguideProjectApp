<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="TourGuideAPP.Views.MapPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False"
             Title="Bản đồ">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0"
              BackgroundColor="#1A1410"
              ColumnDefinitions="*,Auto"
              Padding="20,52,20,16">

            <VerticalStackLayout Grid.Column="0" Spacing="3">
                <Label Text="KHÁM PHÁ"
                       FontSize="10"
                       CharacterSpacing="4"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"/>
                <Label Text="Bản đồ"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#F0E6D3"/>
            </VerticalStackLayout>

            <!-- Filter chips -->
            <ScrollView Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        VerticalOptions="End">
                <HorizontalStackLayout Spacing="6">
                    <Border BackgroundColor="#C8A96E"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="12,6">
                        <Label Text="Tất cả"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#1A1410"/>
                    </Border>
                    <Border BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="12,6">
                        <Label Text="☕ Cafe"
                               FontSize="10"
                               TextColor="#8A7560"/>
                    </Border>
                    <Border BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="12,6">
                        <Label Text="🍜 Ăn"
                               FontSize="10"
                               TextColor="#8A7560"/>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

        </Grid>

        <!-- ═══ MAP + OVERLAY ═══ -->
        <Grid Grid.Row="1">

            <!-- Mapsui MapControl — giữ nguyên -->
            <mapsui:MapControl x:Name="MyMap"/>

            <!-- Nút tắt chỉ đường (chỉ hiện khi đang có route) -->
            <Border x:Name="CancelRoutePanel"
                    IsVisible="False"
                    BackgroundColor="#E94560"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Padding="14,10"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="12,12,0,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCancelRouteClicked"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6">
                    <Label Text="✕"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center"/>
                    <Label Text="Tắt chỉ đường"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Zoom controls -->
            <VerticalStackLayout HorizontalOptions="End"
                                 VerticalOptions="Start"
                                 Margin="0,12,12,0"
                                 Spacing="6">
                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2A2018"
                        StrokeThickness="1"
                        WidthRequest="38"
                        HeightRequest="38">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnZoomInClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="＋"
                           FontSize="18"
                           TextColor="#C8A96E"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2A2018"
                        StrokeThickness="1"
                        WidthRequest="38"
                        HeightRequest="38">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnZoomOutClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="－"
                           FontSize="18"
                           TextColor="#C8A96E"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Border BackgroundColor="#1A1410"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2A2018"
                        StrokeThickness="1"
                        WidthRequest="38"
                        HeightRequest="38"
                        Margin="0,4,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTrackLocationClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="📍"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <!-- Bottom info panel -->
            <Border BackgroundColor="#1A1410"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    Stroke="#2A2018"
                    StrokeThickness="1"
                    Padding="20,16,20,32"
                    VerticalOptions="End">
                <VerticalStackLayout Spacing="12">

                    <!-- Drag handle -->
                    <BoxView WidthRequest="36"
                             HeightRequest="4"
                             CornerRadius="2"
                             BackgroundColor="#3A2D22"
                             HorizontalOptions="Center"
                             Margin="0,0,0,4"/>

                    <!-- Current location row -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                WidthRequest="36"
                                HeightRequest="36">
                            <Label Text="🏛️"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="2">
                            <Label x:Name="CurrentAddressLabel"
                                   Text="📍 Địa chỉ hiện tại: đang cập nhật..."
                                   FontSize="11"
                                   TextColor="#5A4A3A"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                            <Label x:Name="NearestPOILabel"
                                   Text="Chưa xác định điểm gần nhất"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#C8A96E"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══ POI PLACE CARD (Google Maps style) ═══ -->
            <Border x:Name="PlaceCard"
                    IsVisible="False"
                    BackgroundColor="#1A1410"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    Stroke="#2A2018"
                    StrokeThickness="1"
                    Padding="20,16,20,32"
                    VerticalOptions="End">
                <VerticalStackLayout Spacing="14">

                    <!-- Drag handle -->
                    <BoxView WidthRequest="36"
                             HeightRequest="4"
                             CornerRadius="2"
                             BackgroundColor="#3A2D22"
                             HorizontalOptions="Center"
                             Margin="0,0,0,2"/>

                    <!-- Name row + dismiss button -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label x:Name="CardName"
                                   Text="Tên địa điểm"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#F0E6D3"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"/>
                            <HorizontalStackLayout Spacing="6">
                                <!-- Status badge -->
                                <Border x:Name="CardStatusBadge"
                                        BackgroundColor="#1B3A28"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="8,4">
                                    <Label x:Name="CardStatusLabel"
                                           Text="Đang mở"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#4CAF50"/>
                                </Border>
                                <!-- Stars -->
                                <Label x:Name="CardStars"
                                       Text="★★★★★"
                                       FontSize="12"
                                       TextColor="#C8A96E"
                                       VerticalOptions="Center"/>
                                <Label x:Name="CardRating"
                                       Text="4.5"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#C8A96E"
                                       VerticalOptions="Center"/>
                                <Label x:Name="CardReviews"
                                       Text="(123)"
                                       FontSize="11"
                                       TextColor="#5A4A3A"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Dismiss X -->
                        <Border Grid.Column="1"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                WidthRequest="32"
                                HeightRequest="32"
                                VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlaceCardDismiss"/>
                            </Border.GestureRecognizers>
                            <Label Text="✕"
                                   FontSize="13"
                                   TextColor="#8A7560"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Tag chips from Specialty -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="CardTags" Spacing="6"/>
                    </ScrollView>

                    <!-- Address -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍"
                               FontSize="13"
                               VerticalOptions="Center"/>
                        <Label x:Name="CardAddress"
                               Text="—"
                               FontSize="12"
                               TextColor="#A09080"
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                    </HorizontalStackLayout>

                    <!-- Hours -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🕐"
                               FontSize="13"
                               VerticalOptions="Center"/>
                        <Label x:Name="CardHours"
                               Text="—"
                               FontSize="12"
                               TextColor="#A09080"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Action buttons -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,4,0,0">

                        <!-- Chỉ đường -->
                        <Border x:Name="BtnDirections"
                                Grid.Column="0"
                                BackgroundColor="#C8A96E"
                                StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardDirections"/>
                                <PointerGestureRecognizer PointerEntered="OnCardBtnHoverEnter"
                                                          PointerExited="OnCardBtnHoverExit"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="🧭"
                                       FontSize="16"
                                       HorizontalOptions="Center"/>
                                <Label Text="Chỉ đường"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#1A1410"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Thuyết minh -->
                        <Border x:Name="BtnNarrate"
                                Grid.Column="1"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#3A2D22"
                                StrokeThickness="1"
                                Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardNarrate"/>
                                <PointerGestureRecognizer PointerEntered="OnCardBtnHoverEnter"
                                                          PointerExited="OnCardBtnHoverExit"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="🎙️"
                                       FontSize="16"
                                       HorizontalOptions="Center"/>
                                <Label Text="Thuyết minh"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#C8A96E"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Gọi ngay -->
                        <Border x:Name="BtnCall"
                                Grid.Column="2"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#3A2D22"
                                StrokeThickness="1"
                                Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardCall"/>
                                <PointerGestureRecognizer PointerEntered="OnCardBtnHoverEnter"
                                                          PointerExited="OnCardBtnHoverExit"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="📞"
                                       FontSize="16"
                                       HorizontalOptions="Center"/>
                                <Label Text="Gọi ngay"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#C8A96E"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Chi tiết -->
                        <Border x:Name="BtnDetail"
                                Grid.Column="3"
                                BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#3A2D22"
                                StrokeThickness="1"
                                Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardDetail"/>
                                <PointerGestureRecognizer PointerEntered="OnCardBtnHoverEnter"
                                                          PointerExited="OnCardBtnHoverExit"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="ℹ️"
                                       FontSize="16"
                                       HorizontalOptions="Center"/>
                                <Label Text="Chi tiết"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#C8A96E"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                </VerticalStackLayout>
            </Border>

        </Grid>

    </Grid>

</ContentPage>
