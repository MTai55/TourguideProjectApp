<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.NotesPage"
             Title="Ghi chú">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="Ghi chú địa điểm" FontSize="20" FontAttributes="Bold"/>

        <Frame BorderColor="Gray" CornerRadius="12" Padding="10">
            <VerticalStackLayout Spacing="8">
                <Entry x:Name="PlaceIdEntry" Placeholder="Place ID (số)" Keyboard="Numeric" />
                <Entry x:Name="PlaceNameEntry" Placeholder="Tên địa điểm" />
                <Editor x:Name="NoteEditor" AutoSize="TextChanges" HeightRequest="80" Placeholder="Nội dung ghi chú" />
                <Button Text="Thêm ghi chú" Clicked="OnAddNoteClicked" BackgroundColor="#0F3460" TextColor="White"/>
            </VerticalStackLayout>
        </Frame>

        <CollectionView x:Name="NotesCollection" SelectionMode="None" EmptyView="Chưa có ghi chú">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold"/>
                                <Label Text="{Binding Content}" FontSize="12" TextColor="Gray"/>
                                <Label Text="{Binding CreatedAt, StringFormat='{0:G}'}" FontSize="12" TextColor="Gray"/>
                            </VerticalStackLayout>
                            <Button Text="Xóa" Clicked="OnRemoveNoteClicked" CommandParameter="{Binding PlaceId}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
