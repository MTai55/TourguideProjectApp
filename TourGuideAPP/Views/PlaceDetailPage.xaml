<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:TourGuideAPP.Resources.Strings"
             x:Class="TourGuideAPP.Views.PlaceDetailPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══ HEADER ảnh + overlay ═══ -->
        <Grid Grid.Row="0" HeightRequest="260">
            <Image x:Name="MainImage"
                   Aspect="AspectFill"
                   HeightRequest="260"/>
            <!-- Gradient overlay -->
            <BoxView BackgroundColor="#0F0E0D"
                     Opacity="0.45"
                     VerticalOptions="Fill"/>
            <!-- Top bar: back + tên -->
            <Grid RowDefinitions="Auto,*"
                  Padding="20,52,20,20">
                <!-- Back button -->
                <Border Grid.Row="0"
                        BackgroundColor="#26201A"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        WidthRequest="36" HeightRequest="36"
                        HorizontalOptions="Start">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="‹" FontSize="22" FontAttributes="Bold"
                           TextColor="#C8A96E"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <!-- Tên + rating ở dưới ảnh -->
                <VerticalStackLayout Grid.Row="1" VerticalOptions="End" Spacing="6">
                    <Label x:Name="NameLabel"
                           FontSize="24" FontAttributes="Bold"
                           TextColor="#F0E6D3"
                           LineBreakMode="TailTruncation" MaxLines="2"/>
                    <HorizontalStackLayout Spacing="8">
                        <Label x:Name="RatingLabel"
                               FontSize="13" TextColor="#C8A96E"/>
                        <Label x:Name="ReviewsLabel"
                               FontSize="13" TextColor="#8A7560"/>
                        <!-- Badge mở/đóng -->
                        <Border x:Name="StatusBadge"
                                BackgroundColor="#1B3A28"
                                StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                Padding="8,3">
                            <Label x:Name="StatusLabel"
                                   Text="{x:Static res:AppResources.PlaceOpenNow}" FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"/>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- ═══ CONTENT ═══ -->
        <ScrollView Grid.Row="1" BackgroundColor="#0F0E0D">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

                <!-- Action buttons -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10"
                      Padding="20,16,20,0">

                    <!-- Chỉ đường -->
                    <Border Grid.Column="0"
                            BackgroundColor="#C8A96E"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            Padding="0,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDirectionsClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="🧭" FontSize="16" HorizontalOptions="Center"/>
                            <Label Text="{x:Static res:AppResources.PlaceDirections}" FontSize="10" FontAttributes="Bold"
                                   TextColor="#1A1410" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Google Maps -->
                    <Border Grid.Column="1"
                            BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#3A2D22" StrokeThickness="1"
                            Padding="0,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGoogleMapsClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="🗺️" FontSize="16" HorizontalOptions="Center"/>
                            <Label Text="{x:Static res:AppResources.PlaceGoogleMaps}" FontSize="10" FontAttributes="Bold"
                                   TextColor="#C8A96E" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Gọi ngay -->
                    <Border Grid.Column="2"
                            BackgroundColor="#26201A"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#3A2D22" StrokeThickness="1"
                            Padding="0,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCallClicked"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="📞" FontSize="16" HorizontalOptions="Center"/>
                            <Label Text="{x:Static res:AppResources.PlaceCall}" FontSize="10" FontAttributes="Bold"
                                   TextColor="#C8A96E" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Thông tin chi tiết -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="10">

                    <Label Text="{x:Static res:AppResources.PlaceInfo}"
                           FontSize="9" CharacterSpacing="3"
                           TextColor="#C8A96E" FontAttributes="Bold"
                           Margin="0,0,0,4"/>

                    <Border BackgroundColor="#1A1410"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#2A2018" StrokeThickness="1">
                        <VerticalStackLayout Padding="16" Spacing="14">

                            <!-- Mô tả -->
                            <Label x:Name="DescriptionLabel"
                                   FontSize="13" TextColor="#A09080"
                                   LineBreakMode="WordWrap"/>

                            <BoxView BackgroundColor="#2A2018" HeightRequest="1"/>

                            <!-- Địa chỉ -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="📍" FontSize="16" VerticalOptions="Start"/>
                                <Label Grid.Column="1" x:Name="AddressLabel"
                                       FontSize="13" TextColor="#F0E6D3"
                                       LineBreakMode="WordWrap"/>
                            </Grid>

                            <!-- Giờ mở cửa -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="🕐" FontSize="16" VerticalOptions="Center"/>
                                <Label Grid.Column="1" x:Name="OpenTimeLabel"
                                       FontSize="13" TextColor="#F0E6D3" VerticalOptions="Center"/>
                            </Grid>

                            <!-- Giá -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="💰" FontSize="16" VerticalOptions="Center"/>
                                <Label Grid.Column="1" x:Name="PriceLabel"
                                       FontSize="13" TextColor="#F0E6D3" VerticalOptions="Center"/>
                            </Grid>

                            <!-- Website -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12"
                                  x:Name="WebsiteRow">
                                <Label Grid.Column="0" Text="🌐" FontSize="16" VerticalOptions="Center"/>
                                <Label Grid.Column="1" x:Name="WebsiteLabel"
                                       FontSize="13" TextColor="#4FC3F7"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" MaxLines="1">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnWebsiteClicked"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

                <!-- ═══ TTS SCRIPT ═══ -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="10">

                    <Label Text="— CẨU CHUYỆN HƯỚNG DẪN"
                           FontSize="9" CharacterSpacing="3"
                           TextColor="#C8A96E" FontAttributes="Bold"
                           Margin="0,0,0,4"/>

                    <Border BackgroundColor="#1A1410"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#2A2018" StrokeThickness="1"
                            Padding="0,0,0,0">
                        <VerticalStackLayout Padding="0,0,0,0" Spacing="0">
                            <!-- TTS Script display -->
                            <Label x:Name="TtsScriptLabel"
                                   FontSize="13" TextColor="#F0E6D3"
                                   LineBreakMode="WordWrap"
                                   Padding="16,14,16,0"
                                   Text="Chưa có cẩu chuyện hướng dẫn"/>

                            <!-- Action buttons -->
                            <HorizontalStackLayout Padding="12,10,12,12" Spacing="8" HorizontalOptions="End">
                                <!-- Copy button -->
                                <Border BackgroundColor="#26201A"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="#3A2D22" StrokeThickness="1"
                                        Padding="10,6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCopyTtsClicked"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="📋 Sao chép" FontSize="10" FontAttributes="Bold"
                                           TextColor="#C8A96E" VerticalOptions="Center"/>
                                </Border>

                                <!-- Play button -->
                                <Border BackgroundColor="#26201A"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="#3A2D22" StrokeThickness="1"
                                        Padding="10,6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayTtsClicked"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="🔊 Nghe" FontSize="10" FontAttributes="Bold"
                                           TextColor="#C8A96E" VerticalOptions="Center"/>
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

                <!-- ═══ GHI CHÚ QUÁN ═══ -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="10">

                    <Label Text="— GHI CHÚ LẦN TRƯỚC"
                           FontSize="9" CharacterSpacing="3"
                           TextColor="#C8A96E" FontAttributes="Bold"
                           Margin="0,0,0,4"/>

                    <!-- Danh sách ghi chú cũ -->
                    <VerticalStackLayout x:Name="NotesHistoryStack" Spacing="6">
                        <Label Text="Chưa có ghi chú nào"
                               TextColor="#5A4A3A"
                               FontSize="12"
                               HorizontalOptions="Center"
                               Padding="0,12"/>
                    </VerticalStackLayout>

                    <!-- Thêm ghi chú mới -->
                    <Border BackgroundColor="#1A1410"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#2A2018" StrokeThickness="1"
                            Padding="0,0,0,0"
                            Margin="0,0,0,0">
                        <VerticalStackLayout Padding="12,10,12,10" Spacing="8">
                            <Entry x:Name="NoteInputEntry"
                                   Placeholder="Ghi chú lần tới (vd: nên thử món...)"
                                   PlaceholderColor="#5A4A3A"
                                   TextColor="#F0E6D3"
                                   BackgroundColor="#26201A"
                                   FontSize="13"
                                   Margin="0,4"/>

                            <Border BackgroundColor="#C8A96E"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="Transparent"
                                    Padding="0,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAddNoteClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="💾 Lưu ghi chú" FontSize="12" FontAttributes="Bold"
                                       TextColor="#1A1410" HorizontalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
