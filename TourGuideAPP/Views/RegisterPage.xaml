<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.RegisterPage"
             BackgroundColor="#1A1A2E"
             Title="Đăng ký">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="4" Margin="0,40,0,30">
                <Label Text="Tạo tài khoản"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
                <Label Text="Tham gia cộng đồng TourGuide"
                       FontSize="14"
                       TextColor="#8888AA"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Full Name -->
            <Frame BackgroundColor="#16213E" CornerRadius="12" Padding="0" BorderColor="#0F3460">
                <Entry x:Name="FullNameEntry"
                       Placeholder="Họ và tên"
                       PlaceholderColor="#8888AA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Margin="16,12"/>
            </Frame>

            <!-- Email -->
            <Frame BackgroundColor="#16213E" CornerRadius="12" Padding="0" BorderColor="#0F3460">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       PlaceholderColor="#8888AA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       Margin="16,12"/>
            </Frame>

            <!-- Password -->
            <Frame BackgroundColor="#16213E" CornerRadius="12" Padding="0" BorderColor="#0F3460">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Mật khẩu (ít nhất 6 ký tự)"
                       PlaceholderColor="#8888AA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Margin="16,12"/>
            </Frame>

            <!-- Confirm Password -->
            <Frame BackgroundColor="#16213E" CornerRadius="12" Padding="0" BorderColor="#0F3460">
                <Entry x:Name="ConfirmPasswordEntry"
                       Placeholder="Xác nhận mật khẩu"
                       PlaceholderColor="#8888AA"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Margin="16,12"/>
            </Frame>

            <!-- Error label -->
            <Label x:Name="ErrorLabel"
                   Text=""
                   TextColor="#E94560"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Success label -->
            <Label x:Name="SuccessLabel"
                   Text=""
                   TextColor="#4CAF50"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Register button -->
            <Button Text="Đăng ký"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#0F3460"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontAttributes="Bold"
                    Margin="0,8,0,0"/>

            <!-- Back to login -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Đã có tài khoản?"
                       TextColor="#8888AA"
                       FontSize="14"
                       VerticalOptions="Center"/>
                <Label Text="Đăng nhập"
                       TextColor="#4FC3F7"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>