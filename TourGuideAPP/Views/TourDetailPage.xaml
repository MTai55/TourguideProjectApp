<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.TourDetailPage"
             Title="Chi tiết tour">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">
        <Border BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16"
                Margin="0,8,0,12">
            <VerticalStackLayout Spacing="6">
                <Label x:Name="TitleLabel"
                       Text="Tour"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />
                <Label x:Name="MetaLabel"
                       Text=""
                       FontSize="13"
                       TextColor="{StaticResource Muted}" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1"
                        x:Name="StopsCollection"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Gray100}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="14"
                            Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12" RowSpacing="6">
                            <Border Grid.RowSpan="2"
                                    Grid.Column="0"
                                    BackgroundColor="{StaticResource Secondary}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="10">
                                <Label Text="📍"
                                       FontSize="18"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Address}"
                                   FontSize="12"
                                   TextColor="{StaticResource Muted}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Text="Bắt đầu (đi tới điểm đầu tiên)"
                BackgroundColor="{StaticResource Tertiary}"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="52"
                Clicked="OnStartClicked"
                Margin="0,0,0,8" />
    </Grid>
</ContentPage>

