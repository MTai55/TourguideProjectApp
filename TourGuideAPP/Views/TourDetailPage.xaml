<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:TourGuideAPP.Resources.Strings"
             x:Class="TourGuideAPP.Views.TourDetailPage"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                BackgroundColor="#1A1410"
                StrokeShape="RoundRectangle 0"
                Stroke="Transparent"
                Padding="20,52,20,20">
            <Grid ColumnDefinitions="Auto,*">
                <!-- Back button -->
                <Border Grid.Column="0"
                        BackgroundColor="#26201A"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        WidthRequest="36" HeightRequest="36"
                        VerticalOptions="Center"
                        Margin="0,0,14,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="‹"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#C8A96E"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="{x:Static res:AppResources.TourDetailLabel}"
                           FontSize="10"
                           CharacterSpacing="4"
                           TextColor="#C8A96E"
                           FontAttributes="Bold"/>
                    <Label x:Name="TitleLabel"
                           Text="Tour"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#F0E6D3"/>
                    <Label x:Name="MetaLabel"
                           Text=""
                           FontSize="12"
                           TextColor="#5A4A3A"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- ═══ STOPS LIST ═══ -->
        <ScrollView Grid.Row="1" BackgroundColor="#0F0E0D">
            <VerticalStackLayout Padding="20,20,20,16" Spacing="0">

                <Label Text="{x:Static res:AppResources.TourDetailItinerary}"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,14"/>

                <CollectionView x:Name="StopsCollection"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1A1410"
                                    StrokeShape="RoundRectangle 14"
                                    Stroke="#2A2018"
                                    StrokeThickness="1"
                                    Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Padding="14,14"
                                      ColumnSpacing="12">

                                    <!-- Index dot -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="#26201A"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="Transparent"
                                            WidthRequest="36" HeightRequest="36"
                                            VerticalOptions="Center">
                                        <Label Text="📍"
                                               FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Name + address -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Spacing="3">
                                        <Label Text="{Binding Name}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#F0E6D3"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"/>
                                        <Label Text="{Binding Address}"
                                               FontSize="11"
                                               TextColor="#5A4A3A"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"/>
                                    </VerticalStackLayout>

                                    <!-- Chỉ đường button -->
                                    <Border Grid.Column="2"
                                            BackgroundColor="#26201A"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="#3A2D22"
                                            StrokeThickness="1"
                                            Padding="12,8"
                                            VerticalOptions="Center">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnStopDirectionsClicked"
                                                                  CommandParameter="{Binding PlaceId}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="🧭"
                                               FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ BOTTOM BUTTON ═══ -->
        <Border Grid.Row="2"
                BackgroundColor="#1A1410"
                StrokeShape="RoundRectangle 0"
                Stroke="#2A2018"
                StrokeThickness="1"
                Padding="20,14,20,36">
            <Border BackgroundColor="#C8A96E"
                    StrokeShape="RoundRectangle 14"
                    Stroke="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnStartClicked"/>
                </Border.GestureRecognizers>
                <Label Text="{x:Static res:AppResources.TourDetailStart}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#1A1410"
                       HorizontalOptions="Center"
                       Padding="0,16"/>
            </Border>
        </Border>

    </Grid>
</ContentPage>
