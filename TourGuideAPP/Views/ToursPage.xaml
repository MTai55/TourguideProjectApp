<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:TourGuideAPP.Resources.Strings"
             x:Class="TourGuideAPP.Views.ToursPage"
             Title="Tour"
             BackgroundColor="#0F0E0D"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- ═══ HEADER ═══ -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="#1A1410"
                             Padding="20,52,20,18"
                             Spacing="4">

            <Label Text="{x:Static res:AppResources.TourExplore}"
                   FontSize="10"
                   CharacterSpacing="4"
                   TextColor="#C8A96E"
                   FontAttributes="Bold"/>

            <Label Text="{x:Static res:AppResources.TourPageTitle}"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#F0E6D3"/>

            <Label Text="{x:Static res:AppResources.TourSubtitle}"
                   FontSize="12"
                   TextColor="#5A4A3A"
                   Margin="0,0,0,14"/>

            <!-- Search + Filter -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                <Border Grid.Column="0"
                        BackgroundColor="#26201A"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#3A2D22"
                        StrokeThickness="1"
                        Padding="14,10">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0"
                               Text="🔍"
                               FontSize="14"
                               VerticalOptions="Center"
                               TextColor="#5A4A3A"/>
                        <Entry x:Name="SearchEntry"
                               Grid.Column="1"
                               Placeholder="{x:Static res:AppResources.TourSearchPlaceholder}"
                               PlaceholderColor="#5A4A3A"
                               TextColor="#F0E6D3"
                               BackgroundColor="Transparent"
                               Margin="8,0,0,0"
                               FontSize="12"
                               TextChanged="OnSearchTextChanged"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#C8A96E"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="18,10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static res:AppResources.TourFilterLabel}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#1A1410"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

            </Grid>
        </VerticalStackLayout>

        <!-- ═══ FILTER PANEL ═══ -->
        <Border Grid.Row="1"
                x:Name="FilterPanel"
                IsVisible="False"
                BackgroundColor="#1A1410"
                StrokeShape="RoundRectangle 0"
                Stroke="Transparent"
                StrokeThickness="0"
                Padding="20,14,20,16">
            <VerticalStackLayout Spacing="14">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <!-- Thời gian -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="{x:Static res:AppResources.TourTimeFilter}"
                               FontSize="9"
                               CharacterSpacing="2"
                               TextColor="#C8A96E"
                               FontAttributes="Bold"/>
                        <Border BackgroundColor="#26201A"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#3A2D22"
                                StrokeThickness="1"
                                Padding="10,6">
                            <Picker x:Name="DurationPicker"
                                    Title="Chọn thời gian"
                                    TextColor="#F0E6D3"
                                    TitleColor="#5A4A3A"
                                    BackgroundColor="Transparent"
                                    FontSize="12"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Ngân sách -->
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="{x:Static res:AppResources.TourBudgetFilter}"
                                   FontSize="9"
                                   CharacterSpacing="2"
                                   TextColor="#C8A96E"
                                   FontAttributes="Bold"/>
                            <Label x:Name="BudgetValueLabel"
                                   Grid.Column="1"
                                   Text="200k"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#C8A96E"/>
                        </Grid>
                        <Slider x:Name="BudgetSlider"
                                Minimum="50"
                                Maximum="500"
                                Value="200"
                                ValueChanged="OnBudgetChanged"
                                MinimumTrackColor="#C8A96E"
                                MaximumTrackColor="#3A2D22"
                                ThumbColor="#C8A96E"/>
                    </VerticalStackLayout>

                </Grid>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                    <!-- Ưu tiên đi bộ ít -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="{x:Static res:AppResources.TourPriorityFilter}"
                               FontSize="9"
                               CharacterSpacing="2"
                               TextColor="#C8A96E"
                               FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="{x:Static res:AppResources.TourWalkLess}"
                                   FontSize="12"
                                   TextColor="#F0E6D3"
                                   VerticalOptions="Center"/>
                            <Switch x:Name="LowWalkingSwitch"
                                    OnColor="#C8A96E"
                                    ThumbColor="#F0E6D3"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Áp dụng -->
                    <Border Grid.Column="1"
                            BackgroundColor="#C8A96E"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            Padding="18,10"
                            VerticalOptions="End">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnApplyFiltersClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static res:AppResources.TourApply}"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#1A1410"
                               HorizontalOptions="Center"/>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </Border>



        <!-- ═══ TOUR LIST ═══ -->
        <ScrollView Grid.Row="2"
                    BackgroundColor="#0F0E0D">
            <VerticalStackLayout Spacing="0" Padding="20,16,20,100">

                <!-- Section label -->
                <Label Text="{x:Static res:AppResources.TourCuratedLabel}"
                       FontSize="9"
                       CharacterSpacing="3"
                       TextColor="#C8A96E"
                       FontAttributes="Bold"
                       Margin="0,0,0,14"/>

                <CollectionView x:Name="ToursCollection"
                                ItemsSource="{Binding Tours}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <!-- Tour Card -->
                            <Border BackgroundColor="#1A1410"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="#2A2018"
                                    StrokeThickness="1"
                                    Margin="0,0,0,12">

                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="0"
                                      Padding="16">

                                    <!-- Row 0: Title + Badge -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="#F0E6D3"
                                           Margin="0,0,0,6"/>

                                    <Border Grid.Row="0" Grid.Column="1"
                                            BackgroundColor="#2A2018"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="10,5"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding Tag}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#C8A96E"/>
                                    </Border>

                                    <!-- Row 1: Description -->
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="#5A4A3A"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"
                                           Margin="0,0,0,12"/>

                                    <!-- Row 2: Meta chips + Chọn button -->
                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="0"
                                                           Spacing="6"
                                                           VerticalOptions="Center">

                                        <Border BackgroundColor="#26201A"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                Padding="9,5">
                                            <Label Text="{Binding DurationText, StringFormat='⏱ {0}'}"
                                                   FontSize="10"
                                                   TextColor="#C8A96E"/>
                                        </Border>

                                        <Border BackgroundColor="#26201A"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                Padding="9,5">
                                            <Label Text="{Binding BudgetText, StringFormat='💰 {0}'}"
                                                   FontSize="10"
                                                   TextColor="#C8A96E"/>
                                        </Border>

                                        <Border BackgroundColor="#26201A"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                Padding="9,5">
                                            <Label Text="{Binding StopsText}"
                                                   FontSize="10"
                                                   TextColor="#C8A96E"/>
                                        </Border>

                                    </HorizontalStackLayout>

                                    <Border Grid.Row="2" Grid.Column="1"
                                            BackgroundColor="#C8A96E"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="Transparent"
                                            Padding="18,9"
                                            VerticalOptions="Center">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSelectTourClicked"
                                                                  CommandParameter="{Binding Id}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{x:Static res:AppResources.TourSelect}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#1A1410"
                                               HorizontalOptions="Center"/>
                                    </Border>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
