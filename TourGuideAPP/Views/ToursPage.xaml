<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.ToursPage"
             Title="Tour"
             BackgroundColor="#1A1008"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,52,20,0">

        <!-- ═══ HEADER + SEARCH ═══ -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,20">

            <!-- Title -->
            <Label Text="KHÁM PHÁ" FontSize="10" CharacterSpacing="4"
                   TextColor="#C8853A" FontAttributes="Bold"/>
            <Label Text="Gói Tour" FontSize="30" FontAttributes="Bold"
                   TextColor="#F5ECD7"/>
            <Label Text="Gợi ý theo sở thích, ngân sách, thời gian."
                   FontSize="13" TextColor="#7A5C3A" Margin="0,0,0,16"/>

            <!-- Search + Filter button -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border Grid.Column="0"
                        BackgroundColor="#2E1F0E"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#3D2A15"
                        StrokeThickness="1"
                        Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🔍" FontSize="15"
                               VerticalOptions="Center"/>
                        <Entry x:Name="SearchEntry"
                               Grid.Column="1"
                               Placeholder="Tìm tour (ăn vặt, hải sản, cafe...)"
                               PlaceholderColor="#7A5C3A"
                               TextColor="#F5ECD7"
                               BackgroundColor="Transparent"
                               Margin="8,0,0,0"
                               FontSize="13"/>
                    </Grid>
                </Border>
                <Border Grid.Column="1"
                        BackgroundColor="#C8853A"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="18,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="Lọc" FontSize="14" FontAttributes="Bold"
                           TextColor="#1A1008" HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>
        </VerticalStackLayout>

        <!-- ═══ FILTER PANEL ═══ -->
        <Border Grid.Row="1"
                x:Name="FilterPanel"
                IsVisible="False"
                BackgroundColor="#2E1F0E"
                StrokeShape="RoundRectangle 16"
                Stroke="#3D2A15"
                StrokeThickness="1"
                Padding="16"
                Margin="0,0,0,16">
            <VerticalStackLayout Spacing="14">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Thời gian -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="THỜI GIAN" FontSize="10" CharacterSpacing="2"
                               TextColor="#C8853A" FontAttributes="Bold"/>
                        <Border BackgroundColor="#3D2A15" StrokeShape="RoundRectangle 10"
                                Stroke="Transparent" Padding="8,4">
                            <Picker x:Name="DurationPicker"
                                    Title="Chọn thời gian"
                                    TextColor="#F5ECD7"
                                    TitleColor="#7A5C3A"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                    <!-- Ngân sách -->
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="NGÂN SÁCH" FontSize="10"
                                   CharacterSpacing="2" TextColor="#C8853A"
                                   FontAttributes="Bold"/>
                            <Label x:Name="BudgetValueLabel"
                                   Grid.Column="1"
                                   Text="200k"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#C8853A"/>
                        </Grid>
                        <Slider x:Name="BudgetSlider"
                                Minimum="50"
                                Maximum="500"
                                Value="200"
                                ValueChanged="OnBudgetChanged"
                                MinimumTrackColor="#C8853A"
                                MaximumTrackColor="#3D2A15"
                                ThumbColor="#C8853A"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <!-- Ưu tiên đi bộ ít -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="ƯU TIÊN" FontSize="10" CharacterSpacing="2"
                               TextColor="#C8853A" FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="Đi bộ ít" FontSize="13"
                                   TextColor="#F5ECD7" VerticalOptions="Center"/>
                            <Switch x:Name="LowWalkingSwitch"
                                    OnColor="#C8853A"
                                    ThumbColor="#F5ECD7"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <!-- Áp dụng -->
                    <Border Grid.Column="1"
                            BackgroundColor="#C8853A"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            Padding="18,12"
                            VerticalOptions="End">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnApplyFiltersClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Áp dụng" FontSize="13" FontAttributes="Bold"
                               TextColor="#1A1008" HorizontalOptions="Center"/>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ═══ TOUR LIST ═══ -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,100">

                <!-- Section label -->
                <Label Text="— CÁC GÓI TOUR BIÊN TẬP" FontSize="10"
                       CharacterSpacing="2" TextColor="#C8853A"
                       FontAttributes="Bold" Margin="0,0,0,16"/>

                <CollectionView x:Name="ToursCollection"
                                ItemsSource="{Binding Tours}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#2E1F0E"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="Transparent"
                                    Margin="0,0,0,14">

                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="0"
                                      Padding="16,16,16,16">

                                    <!-- Row 0: Title + Tag badge -->
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0"
                                                         Spacing="3" Margin="0,0,0,8">
                                        <Label Text="{Binding Title}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#F5ECD7"/>
                                    </VerticalStackLayout>

                                    <Border Grid.Row="0" Grid.Column="1"
                                            BackgroundColor="#C8853A"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="12,5"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding Tag}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#1A1008"/>
                                    </Border>

                                    <!-- Row 1: Description -->
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="#A07850"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"
                                           Margin="0,0,0,12"/>

                                    <!-- Row 2: Meta chips + Chọn button -->
                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="0"
                                                           Spacing="8"
                                                           VerticalOptions="Center">
                                        <Border BackgroundColor="#3D2A15"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent" Padding="10,5">
                                            <Label Text="{Binding DurationText, StringFormat='⏱ {0}'}"
                                                   FontSize="11" TextColor="#C8853A"/>
                                        </Border>
                                        <Border BackgroundColor="#3D2A15"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent" Padding="10,5">
                                            <Label Text="{Binding BudgetText, StringFormat='💰 {0}'}"
                                                   FontSize="11" TextColor="#C8853A"/>
                                        </Border>
                                        <Border BackgroundColor="#3D2A15"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent" Padding="10,5">
                                            <Label Text="{Binding StopsText}"
                                                   FontSize="11" TextColor="#C8853A"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Border Grid.Row="2" Grid.Column="1"
                                            BackgroundColor="#C8853A"
                                            StrokeShape="RoundRectangle 12"
                                            Stroke="Transparent"
                                            Padding="20,10"
                                            VerticalOptions="Center">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSelectTourClicked"
                                                                  CommandParameter="{Binding Id}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Chọn" FontSize="14"
                                               FontAttributes="Bold" TextColor="#1A1008"
                                               HorizontalOptions="Center"/>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
