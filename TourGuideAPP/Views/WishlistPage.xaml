<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideAPP.Views.WishlistPage"
             Title="Danh sách muốn đi">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="Danh sách muốn đi" FontSize="20" FontAttributes="Bold"/>
        <CollectionView x:Name="WishlistCollection" SelectionMode="None" EmptyView="Chưa có mục nào">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold"/>
                                <Label Text="{Binding Address}" FontSize="12" TextColor="Gray"/>
                                <Label Text="{Binding AddedAt, StringFormat='{0:G}'}" FontSize="12" TextColor="Gray"/>
                            </VerticalStackLayout>
                            <Button Text="Xóa" Clicked="OnRemoveClicked" CommandParameter="{Binding PlaceId}"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="Xóa toàn bộ" Clicked="OnClearAllClicked" BackgroundColor="#E94560" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>
