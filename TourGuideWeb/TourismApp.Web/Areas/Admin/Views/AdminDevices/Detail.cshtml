@model List<TourismApp.Web.Services.ApiService.DeviceVisitDto>
@{
    ViewData["Title"] = "Chi tiết thiết bị";
    var deviceId = ViewBag.DeviceId as string ?? string.Empty;
}

<div class="pt-6 space-y-6">

  <!-- Back + Header -->
  <div class="flex items-center gap-4">
    <a asp-area="Admin" asp-controller="AdminDevices" asp-action="Index"
       class="p-2 text-on-surface-variant hover:bg-surface-container rounded-xl transition-colors">
      <span class="material-symbols-outlined">arrow_back</span>
    </a>
    <div>
      <h2 class="text-xl font-extrabold text-on-surface">Lịch sử ghé thăm</h2>
      <p class="text-sm text-on-surface-variant mt-0.5 font-mono">Device: <span class="font-bold text-on-surface">@deviceId</span></p>
    </div>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-4">
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 text-center">
      <p class="text-2xl font-extrabold text-on-surface">@Model.Count</p>
      <p class="text-xs text-on-surface-variant mt-1 font-bold uppercase tracking-wide">Tổng lượt</p>
    </div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 text-center">
      <p class="text-2xl font-extrabold text-on-surface">@Model.Select(v => v.PlaceId).Distinct().Count()</p>
      <p class="text-xs text-on-surface-variant mt-1 font-bold uppercase tracking-wide">POI khác nhau</p>
    </div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 text-center">
      <p class="text-2xl font-extrabold text-on-surface">
        @(Model.Max(v => v.VisitedAt) is DateTime last ? last.ToLocalTime().ToString("dd/MM") : "—")
      </p>
      <p class="text-xs text-on-surface-variant mt-1 font-bold uppercase tracking-wide">Lần cuối</p>
    </div>
  </div>

  <!-- History table -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-container-low text-on-surface-variant text-xs font-bold uppercase tracking-wide">
          <th class="px-5 py-3.5 text-left">Địa điểm</th>
          <th class="px-5 py-3.5 text-center">Place ID</th>
          <th class="px-5 py-3.5 text-center">Phương thức</th>
          <th class="px-5 py-3.5 text-left">Thời gian</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        @if (Model.Count == 0)
        {
          <tr>
            <td colspan="4" class="px-5 py-12 text-center text-on-surface-variant text-sm">
              <span class="material-symbols-outlined text-4xl block mb-2 text-outline-variant">history</span>
              Chưa có lịch sử
            </td>
          </tr>
        }
        @foreach (var v in Model)
        {
          <tr class="hover:bg-surface-container-lowest transition-colors">
            <td class="px-5 py-3.5 font-semibold text-on-surface">@(v.PlaceName ?? "—")</td>
            <td class="px-5 py-3.5 text-center text-on-surface-variant font-mono text-xs">#@v.PlaceId</td>
            <td class="px-5 py-3.5 text-center">
              @if (v.VisitMethod == "GPS")
              {
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-blue-50 text-blue-700 border border-blue-100">
                  <span class="material-symbols-outlined text-xs">gps_fixed</span> GPS
                </span>
              }
              else if (v.VisitMethod == "QR Code")
              {
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-purple-50 text-purple-700 border border-purple-100">
                  <span class="material-symbols-outlined text-xs">qr_code</span> QR
                </span>
              }
              else
              {
                <span class="px-2.5 py-1 rounded-full text-xs font-bold bg-surface-container text-on-surface-variant">@v.VisitMethod</span>
              }
            </td>
            <td class="px-5 py-3.5 text-on-surface-variant text-xs">
              @(v.VisitedAt.HasValue ? v.VisitedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") : "—")
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

</div>
