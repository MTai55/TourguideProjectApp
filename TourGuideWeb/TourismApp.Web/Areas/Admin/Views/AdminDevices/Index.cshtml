@model List<TourismApp.Web.Services.ApiService.DeviceStatItem>
@{
    ViewData["Title"] = "Người dùng thiết bị";
    var search     = ViewBag.Search as string ?? string.Empty;
    var page       = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total      = (int)ViewBag.Total;

    string IsActive(DateTime? lastVisit)
    {
        if (lastVisit == null) return "no";
        return (DateTime.UtcNow - lastVisit.Value).TotalDays <= 7 ? "yes" : "no";
    }
}

<div class="pt-6 space-y-6">

  <!-- Header + Search -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <h2 class="text-xl font-extrabold text-on-surface">Người dùng thiết bị</h2>
      <p class="text-sm text-on-surface-variant mt-0.5">@total thiết bị đã check-in qua GPS</p>
    </div>
    <form method="get" class="flex gap-2">
      <input name="search" value="@search" placeholder="Tìm Device ID..."
             class="border border-outline-variant rounded-xl px-4 py-2 text-sm bg-surface-container-low focus:outline-none focus:ring-2 focus:ring-primary/30 w-56" />
      <button type="submit"
              class="px-4 py-2 rounded-xl text-sm font-bold text-white"
              style="background:linear-gradient(135deg,#954400,#fc8127)">
        Tìm
      </button>
      @if (!string.IsNullOrEmpty(search))
      {
        <a href="/Admin/AdminDevices" class="px-4 py-2 rounded-xl text-sm font-bold text-on-surface-variant border border-outline-variant hover:bg-surface-container">Xóa</a>
      }
    </form>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-container-low text-on-surface-variant text-xs font-bold uppercase tracking-wide">
          <th class="px-5 py-3.5 text-left">Device ID</th>
          <th class="px-5 py-3.5 text-center">Lượt thăm</th>
          <th class="px-5 py-3.5 text-center">POI đã ghé</th>
          <th class="px-5 py-3.5 text-left">Lần đầu</th>
          <th class="px-5 py-3.5 text-left">Lần cuối</th>
          <th class="px-5 py-3.5 text-center">Active</th>
          <th class="px-5 py-3.5 text-center">Chi tiết</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        @if (Model.Count == 0)
        {
          <tr>
            <td colspan="7" class="px-5 py-12 text-center text-on-surface-variant text-sm">
              <span class="material-symbols-outlined text-4xl block mb-2 text-outline-variant">smartphone</span>
              Chưa có dữ liệu thiết bị nào
            </td>
          </tr>
        }
        @foreach (var d in Model)
        {
          var active = IsActive(d.LastVisit);
          <tr class="hover:bg-surface-container-lowest transition-colors">
            <td class="px-5 py-3.5">
              <span class="font-mono font-bold text-on-surface text-sm tracking-wider bg-surface-container-low px-2.5 py-1 rounded-lg">@d.DeviceId</span>
            </td>
            <td class="px-5 py-3.5 text-center font-bold text-on-surface">@d.VisitCount</td>
            <td class="px-5 py-3.5 text-center font-bold text-on-surface">@d.PoiCount</td>
            <td class="px-5 py-3.5 text-on-surface-variant text-xs">
              @(d.FirstVisit.HasValue ? d.FirstVisit.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")
            </td>
            <td class="px-5 py-3.5 text-on-surface-variant text-xs">
              @(d.LastVisit.HasValue ? d.LastVisit.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")
            </td>
            <td class="px-5 py-3.5 text-center">
              @if (active == "yes")
              {
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span> Active
                </span>
              }
              else
              {
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-slate-50 text-slate-500 border border-slate-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-slate-300 inline-block"></span> Inactive
                </span>
              }
            </td>
            <td class="px-5 py-3.5 text-center">
              <a asp-area="Admin" asp-controller="AdminDevices" asp-action="Detail" asp-route-deviceId="@d.DeviceId"
                 class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-bold rounded-lg border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors">
                <span class="material-symbols-outlined text-sm">open_in_new</span> Xem
              </a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  @if (totalPages > 1)
  {
    <div class="flex justify-center gap-2">
      @for (int i = 1; i <= totalPages; i++)
      {
        var isCurrentPage = i == page;
        <a href="?page=@i&search=@search"
           class="w-9 h-9 flex items-center justify-center rounded-xl text-sm font-bold transition-all
                  @(isCurrentPage ? "text-white shadow" : "text-on-surface-variant border border-outline-variant hover:bg-surface-container")"
           style="@(isCurrentPage ? "background:linear-gradient(135deg,#954400,#fc8127)" : "")">
          @i
        </a>
      }
    </div>
  }

</div>
