@model List<TourismApp.Web.Services.ApiService.AccessPackageDto>
@{
    ViewData["Title"] = "Quản lý gói truy cập";

    string DurationLabel(double hours) => hours switch
    {
        1  => "1 giờ",
        2  => "2 giờ",
        24 => "1 ngày",
        72 => "3 ngày",
        _  => $"{hours}h"
    };
}

<div class="pt-6 space-y-6">

  <!-- Header -->
  <div>
    <h2 class="text-xl font-extrabold text-on-surface">Quản lý gói truy cập</h2>
    <p class="text-sm text-on-surface-variant mt-0.5">Chỉnh giá và thời hạn các gói khách du lịch mua trên app</p>
  </div>

  <!-- Info banner -->
  <div class="flex items-start gap-3 p-4 bg-blue-50 border border-blue-100 rounded-xl text-blue-700 text-sm">
    <span class="material-symbols-outlined mt-0.5">info</span>
    <span>Thay đổi giá sẽ có hiệu lực ngay lần tiếp theo app tải trang mua gói. App cũ đang mở sẽ cần khởi động lại.</span>
  </div>

  <!-- Package cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    @foreach (var pkg in Model)
    {
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">

        <!-- Card header -->
        <div class="px-6 py-4 border-b border-slate-50 flex items-center justify-between"
             style="background:linear-gradient(135deg,#fdf6ee,#fff)">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-black text-sm"
                 style="background:linear-gradient(135deg,#954400,#fc8127)">
              @pkg.PackageId.ToUpper()[0]
            </div>
            <div>
              <p class="font-extrabold text-on-surface text-base">@pkg.PackageId.ToUpper()</p>
              <p class="text-xs text-on-surface-variant">@DurationLabel(pkg.DurationHours)</p>
            </div>
          </div>
          <div class="text-right">
            <p class="text-xl font-extrabold text-primary">@pkg.PriceVnd.ToString("N0").Replace(",",".")đ</p>
            @if (pkg.IsActive)
            {
              <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">Đang bán</span>
            }
            else
            {
              <span class="text-xs font-bold text-slate-500 bg-slate-50 px-2 py-0.5 rounded-full">Ẩn</span>
            }
          </div>
        </div>

        <!-- Edit form -->
        <form method="post" asp-action="Update" asp-controller="AdminPackages" asp-area="Admin"
              class="px-6 py-5 space-y-4">
          <input type="hidden" name="packageId" value="@pkg.PackageId" />

          <div class="grid grid-cols-2 gap-4">
            <!-- Giá -->
            <div>
              <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wide block mb-1.5">
                Giá (VNĐ)
              </label>
              <input type="number" name="priceVnd" value="@pkg.PriceVnd" min="1000" step="1000"
                     class="w-full border border-outline-variant rounded-xl px-3 py-2.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-primary/30 bg-surface-container-low" />
            </div>

            <!-- Thời gian -->
            <div>
              <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wide block mb-1.5">
                Thời hạn (giờ)
              </label>
              <input type="number" name="durationHours" value="@pkg.DurationHours" min="0.5" step="0.5"
                     class="w-full border border-outline-variant rounded-xl px-3 py-2.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-primary/30 bg-surface-container-low" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <!-- Thứ tự -->
            <div>
              <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wide block mb-1.5">
                Thứ tự hiển thị
              </label>
              <input type="number" name="sortOrder" value="@pkg.SortOrder" min="1"
                     class="w-full border border-outline-variant rounded-xl px-3 py-2.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-primary/30 bg-surface-container-low" />
            </div>

            <!-- Trạng thái -->
            <div>
              <label class="text-xs font-bold text-on-surface-variant uppercase tracking-wide block mb-1.5">
                Trạng thái
              </label>
              <select name="isActive"
                      class="w-full border border-outline-variant rounded-xl px-3 py-2.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-primary/30 bg-surface-container-low">
                <option value="true"  @(pkg.IsActive ? "selected" : "")>Đang bán</option>
                <option value="false" @(!pkg.IsActive ? "selected" : "")>Ẩn khỏi app</option>
              </select>
            </div>
          </div>

          <button type="submit"
                  class="w-full py-2.5 rounded-xl text-white text-sm font-bold transition-all hover:opacity-90 active:scale-[0.98]"
                  style="background:linear-gradient(135deg,#954400,#fc8127)">
            Lưu thay đổi
          </button>
        </form>

      </div>
    }
  </div>

</div>
