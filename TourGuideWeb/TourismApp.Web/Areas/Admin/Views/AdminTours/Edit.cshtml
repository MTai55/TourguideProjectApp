@using TourismApp.Web.Models
@model CreateTourViewModel
@{ ViewData["Title"] = "Chỉnh sửa Tour"; }

<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 pt-2">
  <div>
    <span class="font-bold text-sm tracking-widest uppercase mb-1 block" style="color:#954400">
      Quản trị viên
    </span>
    <h1 class="text-4xl font-extrabold tracking-tight text-on-surface leading-tight">
      Chỉnh sửa Tour
    </h1>
  </div>
  <a asp-action="Index"
     class="px-4 py-2 bg-slate-100 text-slate-700 font-bold rounded-xl text-sm hover:bg-slate-200 transition-colors">
    ← Quay lại
  </a>
</div>

<form asp-action="Edit" asp-route-id="@ViewBag.TourId" method="post" class="max-w-2xl">
  <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm">
    <div class="space-y-6">
      <!-- Title -->
      <div>
        <label asp-for="Title" class="block text-sm font-bold text-slate-700 mb-2">Tiêu đề tour *</label>
        <input asp-for="Title" type="text"
               class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
               placeholder="Ví dụ: Foodie Khánh Hội" />
        <span asp-validation-for="Title" class="text-red-600 text-sm"></span>
      </div>

      <!-- Description -->
      <div>
        <label asp-for="Description" class="block text-sm font-bold text-slate-700 mb-2">Mô tả *</label>
        <textarea asp-for="Description" rows="3"
                  class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary resize-none"
                  placeholder="Mô tả chi tiết về tour..."></textarea>
        <span asp-validation-for="Description" class="text-red-600 text-sm"></span>
      </div>

      <!-- Duration & Budget -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label asp-for="DurationText" class="block text-sm font-bold text-slate-700 mb-2">Thời gian *</label>
          <input asp-for="DurationText" type="text"
                 class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                 placeholder="Ví dụ: 2–3 giờ" />
          <span asp-validation-for="DurationText" class="text-red-600 text-sm"></span>
        </div>
        <div>
          <label asp-for="BudgetText" class="block text-sm font-bold text-slate-700 mb-2">Ngân sách *</label>
          <input asp-for="BudgetText" type="text"
                 class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
                 placeholder="Ví dụ: 100k–250k" />
          <span asp-validation-for="BudgetText" class="text-red-600 text-sm"></span>
        </div>
      </div>

      <!-- Tag -->
      <div>
        <label asp-for="Tag" class="block text-sm font-bold text-slate-700 mb-2">Tag *</label>
        <input asp-for="Tag" type="text"
               class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
               placeholder="Ví dụ: Ăn vặt, Cafe, Văn hóa..." />
        <span asp-validation-for="Tag" class="text-red-600 text-sm"></span>
      </div>

      <!-- Places Selection -->
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-3">Chọn điểm dừng * (tối thiểu 2 điểm)</label>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-h-60 overflow-y-auto border border-slate-200 rounded-xl p-4">
          @foreach (var place in ViewBag.Places as IEnumerable<PlaceViewModel> ?? new List<PlaceViewModel>())
          {
            var isSelected = Model.StopPlaceIds?.Contains(place.PlaceId) ?? false;
            <label class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-100 hover:bg-slate-50 cursor-pointer">
              <input type="checkbox" name="StopPlaceIds" value="@place.PlaceId"
                     @(isSelected ? "checked" : "")
                     class="w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary" />
              <div class="flex-1">
                <div class="font-medium text-sm">@place.Name</div>
                <div class="text-xs text-slate-500 truncate">@place.Address</div>
              </div>
            </label>
          }
        </div>
        <span asp-validation-for="StopPlaceIds" class="text-red-600 text-sm"></span>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex gap-3 mt-8 pt-6 border-t border-slate-100">
      <button type="submit"
              class="flex-1 px-6 py-3 text-white font-bold rounded-xl text-sm"
              style="background:linear-gradient(135deg,#954400,#fc8127)">
        Cập nhật Tour
      </button>
      <a asp-action="Index"
         class="px-6 py-3 bg-slate-100 text-slate-700 font-bold rounded-xl text-sm hover:bg-slate-200 transition-colors">
        Hủy
      </a>
    </div>
  </div>
</form>

@section Scripts {
  <script>
    // Auto-generate StopsText when places are selected
    document.querySelectorAll('input[name="StopPlaceIds"]').forEach(checkbox => {
      checkbox.addEventListener('change', updateStopsCount);
    });

    function updateStopsCount() {
      const checkedBoxes = document.querySelectorAll('input[name="StopPlaceIds"]:checked');
      // Just visual feedback, actual calculation happens on server
    }
  </script>
}