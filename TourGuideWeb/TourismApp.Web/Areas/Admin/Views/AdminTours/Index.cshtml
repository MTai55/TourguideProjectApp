@using TourismApp.Web.Models
@model IEnumerable<TourViewModel>
@{ ViewData["Title"] = "Quản lý Tours"; }

<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 pt-2">
  <div>
    <span class="font-bold text-sm tracking-widest uppercase mb-1 block" style="color:#954400">
      Quản trị viên
    </span>
    <h1 class="text-4xl font-extrabold tracking-tight text-on-surface leading-tight">
      Quản lý Tours
    </h1>
  </div>
  <div class="flex gap-3">
    <form asp-action="SyncToMobile" method="post" class="inline">
      <button type="submit"
              class="px-4 py-2 bg-blue-50 text-blue-700 font-bold rounded-xl text-sm hover:bg-blue-100 transition-colors">
        🔄 Sync to Mobile
      </button>
    </form>
    <a asp-action="Create"
       class="px-6 py-3 text-white font-bold rounded-xl text-sm"
       style="background:linear-gradient(135deg,#954400,#fc8127)">
      + Tạo Tour Mới
    </a>
  </div>
</div>

@if (TempData["Success"] != null)
{
  <div class="flex items-center gap-3 p-4 bg-green-50 border border-green-100 rounded-xl mb-6">
    <span class="material-symbols-outlined text-green-600">check_circle</span>
    <p class="text-sm font-semibold text-green-700">@TempData["Success"]</p>
  </div>
}

@if (TempData["Error"] != null)
{
  <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-100 rounded-xl mb-6">
    <span class="material-symbols-outlined text-red-600">error</span>
    <p class="text-sm font-semibold text-red-700">@TempData["Error"]</p>
  </div>
}

<!-- Tours Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  @foreach (var tour in Model ?? new List<TourViewModel>())
  {
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all group">
      <div class="p-6">
        <div class="flex justify-between items-start mb-3">
          <h3 class="font-bold text-lg">@tour.Title</h3>
          <span class="px-2 py-1 bg-secondary-container text-on-secondary-container text-xs font-bold rounded-lg">
            @tour.Tag
          </span>
        </div>

        <p class="text-sm text-slate-600 mb-4 line-clamp-2">@tour.Description</p>

        <div class="space-y-2 mb-4">
          <div class="flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-sm">schedule</span>
            <span>@tour.DurationText</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-sm">payments</span>
            <span>@tour.BudgetText</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-sm">place</span>
            <span>@tour.StopsText</span>
          </div>
        </div>

        <div class="flex gap-2 pt-4 border-t border-slate-100">
          <a asp-action="Detail" asp-route-id="@tour.Id"
             class="flex-1 px-3 py-2 bg-blue-50 text-blue-700 font-bold rounded-lg text-sm text-center hover:bg-blue-100 transition-colors">
            Xem
          </a>
          <a asp-action="Edit" asp-route-id="@tour.Id"
             class="flex-1 px-3 py-2 bg-amber-50 text-amber-700 font-bold rounded-lg text-sm text-center hover:bg-amber-100 transition-colors">
            Sửa
          </a>
          <form asp-action="Delete" asp-route-id="@tour.Id" method="post"
                class="flex-1" onsubmit="return confirm('Bạn có chắc muốn xóa tour này?')">
            <button type="submit"
                    class="w-full px-3 py-2 bg-red-50 text-red-700 font-bold rounded-lg text-sm hover:bg-red-100 transition-colors">
              Xóa
            </button>
          </form>
        </div>
      </div>
    </div>
  }
</div>

@if (!(Model?.Any() ?? false))
{
  <div class="text-center py-16">
    <div class="text-6xl mb-4">🗺️</div>
    <h3 class="font-bold text-lg mb-2">Chưa có tour nào</h3>
    <a asp-action="Create"
       class="mt-2 px-6 py-3 text-white font-bold rounded-xl text-sm inline-block"
       style="background:linear-gradient(135deg,#954400,#fc8127)">
      + Tạo Tour Đầu Tiên
    </a>
  </div>
}