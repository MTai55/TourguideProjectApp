@using TourismApp.Web.Models
@model TourismApp.Web.Models.AdminStatsViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 pt-2">
  <div>
    <span class="font-bold text-sm tracking-widest uppercase mb-1 block" style="color:#954400">
      Quản trị viên
    </span>
    <h1 class="text-4xl font-extrabold tracking-tight text-on-surface leading-tight">
      Admin Dashboard
    </h1>
  </div>
  <span class="px-5 py-2.5 bg-white font-bold rounded-xl shadow-sm border border-outline-variant/20 text-sm text-on-surface-variant">
    📅 @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
  </span>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">
  @{
    var stats = new (string icon, string val, string label, string bg, string color)[] {
      ("people",       (Model?.TotalUsers ?? 0).ToString(),        "Tổng users",      "bg-primary/10",   "text-primary"),
      ("storefront",   (Model?.TotalPlaces ?? 0).ToString(),       "Tổng quán",       "bg-emerald-100",  "text-emerald-600"),
      ("schedule",     (Model?.PendingPlaces ?? 0).ToString(),     "Chờ duyệt",       "bg-amber-100",    "text-amber-600"),
      ("rate_review",  (Model?.TotalReviews ?? 0).ToString(),      "Tổng review",     "bg-blue-100",     "text-blue-600"),
      ("visibility_off",(Model?.HiddenReviews ?? 0).ToString(),    "Review ẩn",       "bg-slate-100",    "text-slate-600"),
      ("warning",      (Model?.PendingComplaints ?? 0).ToString(), "Khiếu nại mới",   "bg-red-100",      "text-red-600"),
    };
  }
  @foreach (var (icon, val, label, bg, color) in stats)
  {
    <div class="bg-surface-container-lowest p-5 rounded-xl hover:shadow-xl transition-all group cursor-default">
      <div class="p-2.5 rounded-xl @bg @color mb-3 inline-block">
        <span class="material-symbols-outlined text-xl">@icon</span>
      </div>
      <h3 class="text-3xl font-black">@val</h3>
      <p class="text-xs text-slate-500 font-medium mt-1">@label</p>
    </div>
  }
</div>

<!-- Quick Actions -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
  <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm hover:shadow-md transition-all">
    <div class="flex items-center gap-3 mb-3">
      <div class="p-2.5 bg-red-100 text-red-600 rounded-xl">
        <span class="material-symbols-outlined">warning</span>
      </div>
      <h3 class="font-bold">Khiếu nại mới</h3>
    </div>
    <p class="text-3xl font-black mb-3">@(Model?.PendingComplaints ?? 0)</p>
    <a asp-controller="AdminComplaints" asp-action="Index"
       class="flex items-center gap-2 px-4 py-2.5 bg-red-50 text-red-700 font-bold rounded-xl text-sm hover:bg-red-100 transition-colors">
      <span class="material-symbols-outlined text-sm">open_in_new</span> Xử lý
    </a>
  </div>

  <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm hover:shadow-md transition-all">
    <div class="flex items-center gap-3 mb-3">
      <div class="p-2.5 bg-primary/10 text-primary rounded-xl">
        <span class="material-symbols-outlined">people</span>
      </div>
      <h3 class="font-bold">Tài khoản</h3>
    </div>
    <p class="text-3xl font-black mb-3">@(Model?.TotalUsers ?? 0)</p>
    <a asp-controller="AdminUsers" asp-action="Index"
       class="flex items-center gap-2 px-4 py-2.5 bg-primary/10 text-primary font-bold rounded-xl text-sm hover:bg-primary/20 transition-colors">
      <span class="material-symbols-outlined text-sm">open_in_new</span> Quản lý
    </a>
  </div>
</div>

<!-- Quick Nav -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
  @foreach (var (ctrl, act, icon, label, color) in new (string, string, string, string, string)[] {
    ("AdminPlaces",    "Index", "storefront",      "Duyệt quán",     "text-emerald-600"),
    ("AdminUsers",     "Index", "people",          "Quản lý Users",  "text-primary"),
    ("AdminReviews",   "Index", "shield_check",    "Kiểm duyệt",     "text-violet-600"),
    ("AdminComplaints","Index", "feedback",        "Khiếu nại",      "text-red-600"),
  })
  {
    <a asp-controller="@ctrl" asp-action="@act"
       class="bg-surface-container-lowest p-5 rounded-xl shadow-sm hover:shadow-md transition-all text-center group">
      <span class="material-symbols-outlined text-3xl @color mb-2 block group-hover:scale-110 transition-transform">@icon</span>
      <p class="text-sm font-bold">@label</p>
    </a>
  }
</div>
