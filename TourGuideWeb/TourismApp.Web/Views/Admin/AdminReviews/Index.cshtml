@using TourismApp.Web.Models
@model List<TourismApp.Web.Models.ReviewViewModel>
@{ ViewData["Title"] = "Kiểm duyệt Review"; }

<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 pt-2">
  <div>
    <h2 class="text-4xl font-extrabold tracking-tight text-on-surface">Kiểm duyệt Review</h2>
    <p class="text-on-surface-variant text-sm font-medium mt-1">Ẩn các review vi phạm chính sách cộng đồng.</p>
  </div>
  <div class="flex gap-2">
    <a asp-controller="AdminReviews" asp-action="Index"
       class="px-5 py-2.5 font-bold rounded-xl text-sm transition-all
              @(ViewBag.HiddenOnly != true ? "text-white" : "bg-surface-container-low text-on-surface")"
       style="@(ViewBag.HiddenOnly != true ? "background:linear-gradient(135deg,#954400,#fc8127)" : "")">
      Tất cả
    </a>
    <a asp-controller="AdminReviews" asp-action="Index" asp-route-hiddenOnly="true"
       class="px-5 py-2.5 font-bold rounded-xl text-sm flex items-center gap-2
              @(ViewBag.HiddenOnly == true ? "bg-slate-700 text-white" : "bg-surface-container-low text-on-surface hover:bg-surface-container-high")">
      <span class="material-symbols-outlined text-sm">visibility_off</span> Đang ẩn
    </a>
  </div>
</div>

@if (!(Model?.Any() ?? false))
{
  <div class="flex flex-col items-center py-20 text-center bg-surface-container-lowest rounded-xl">
    <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">rate_review</span>
    <p class="font-bold text-on-surface">Không có review nào</p>
  </div>
}

<div class="space-y-4">
  @foreach (var r in Model ?? new List<ReviewViewModel>())
  {
    <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm @(r.IsHidden ? "opacity-60 border-2 border-dashed border-slate-300" : "")">
      @if (r.IsHidden)
      {
        <div class="flex items-center gap-2 mb-3 px-3 py-2 bg-slate-100 rounded-lg">
          <span class="material-symbols-outlined text-sm text-slate-500">visibility_off</span>
          <span class="text-xs font-bold text-slate-600">Review đang bị ẩn</span>
        </div>
      }
      <div class="flex items-start justify-between mb-3">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm"
               style="background:linear-gradient(135deg,#535b71,#dae2fd);color:#535b71">
            @r.UserName?[0]
          </div>
          <div>
            <p class="font-bold text-sm">@r.UserName</p>
            <p class="text-[10px] text-on-surface-variant">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
          </div>
        </div>
        <div class="flex items-center gap-1">
          @for (int i = 1; i <= 5; i++) {
            <span class="material-symbols-outlined text-sm @(i <= r.Rating ? "text-amber-500" : "text-slate-200")"
                  style="@(i <= r.Rating ? "font-variation-settings:'FILL' 1" : "")">star</span>
          }
        </div>
      </div>

      <p class="text-sm text-on-surface leading-relaxed mb-4">@r.Comment</p>

      <div class="flex items-center gap-3">
        @if (!r.IsHidden)
        {
          <div class="flex gap-2 flex-1">
            <input id="note-@r.ReviewId" type="text" placeholder="Lý do ẩn review..."
                   class="flex-1 px-4 py-2.5 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
            <form method="post" asp-controller="AdminReviews" asp-action="Hide" asp-route-reviewId="@r.ReviewId">
              @Html.AntiForgeryToken()
              <input type="hidden" name="note" id="note-val-@r.ReviewId" />
              <button type="submit"
                      onclick="document.getElementById('note-val-@r.ReviewId').value=document.getElementById('note-@r.ReviewId').value"
                      class="px-4 py-2.5 bg-slate-700 text-white font-bold rounded-xl text-sm hover:bg-slate-800 transition-colors flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">visibility_off</span> Ẩn
              </button>
            </form>
          </div>
        }
        else
        {
          <form method="post" asp-controller="AdminReviews" asp-action="Show" asp-route-reviewId="@r.ReviewId">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="px-4 py-2.5 bg-emerald-50 text-emerald-700 font-bold rounded-xl text-sm hover:bg-emerald-100 transition-colors flex items-center gap-1.5">
              <span class="material-symbols-outlined text-sm">visibility</span> Hiện lại
            </button>
          </form>
        }
      </div>
    </div>
  }
</div>
