@using TourismApp.Web.Models
@model TourismApp.Web.Models.AdminStatsViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<h4 class="fw-bold mb-4">🔴 Quản trị hệ thống</h4>

<div class="row g-3 mb-4">
  @foreach (var stat in new[] {
    ("👥", Model?.TotalUsers.ToString(), "Tổng users", "primary"),
    ("🍜", Model?.TotalPlaces.ToString(), "Tổng quán", "success"),
    ("⏳", Model?.PendingPlaces.ToString(), "Chờ duyệt", "warning"),
    ("⭐", Model?.TotalReviews.ToString(), "Tổng review", "info"),
    ("🙈", Model?.HiddenReviews.ToString(), "Review ẩn", "secondary"),
    ("⚠️", Model?.PendingComplaints.ToString(), "Khiếu nại mới", "danger")
  }) {
    <div class="col-md-2">
      <div class="card p-3 text-center border-0 shadow-sm">
        <div class="fs-1">@stat.Item1</div>
        <div class="fs-2 fw-bold text-@stat.Item4">@stat.Item2</div>
        <small class="text-muted">@stat.Item3</small>
      </div>
    </div>
  }
</div>

<!-- Quick Actions -->
<div class="row g-3">
  <div class="col-md-4">
    <div class="card shadow-sm p-3">
      <h6 class="fw-bold">⏳ Quán chờ duyệt (@Model?.PendingPlaces)</h6>
      <a asp-controller="AdminPlaces" asp-action="Index"
         asp-route-pendingOnly="true" class="btn btn-warning btn-sm">Duyệt ngay →</a>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm p-3">
      <h6 class="fw-bold">⚠️ Khiếu nại (@Model?.PendingComplaints)</h6>
      <a asp-controller="AdminComplaints" asp-action="Index" class="btn btn-danger btn-sm">Xử lý →</a>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm p-3">
      <h6 class="fw-bold">👥 Tài khoản (@Model?.TotalUsers)</h6>
      <a asp-controller="AdminUsers" asp-action="Index" class="btn btn-primary btn-sm">Quản lý →</a>
    </div>
  </div>
</div>