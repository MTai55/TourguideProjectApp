@using TourismApp.Web.Models
@model List<TourismApp.Web.Models.PlaceViewModel>
@{ ViewData["Title"] = "Duyệt quán"; }

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-slate-900">✅ Kiểm duyệt quán ăn</h1>
  <p class="text-slate-500 mt-2">Xét duyệt các quán ăn được đăng ký trên hệ thống</p>
</div>

<!-- Filter Tabs -->
<div class="flex gap-3 mb-6">
  <a asp-controller="AdminPlaces" asp-action="Index"
     class="px-6 py-3 font-bold rounded-lg transition @(ViewBag.PendingOnly != true ? "bg-primary text-white shadow-lg" : "border border-slate-300 text-slate-700 hover:bg-slate-50")">
    Tất cả quán
  </a>
  <a asp-controller="AdminPlaces" asp-action="Index" asp-route-pendingOnly="true"
     class="px-6 py-3 font-bold rounded-lg transition @(ViewBag.PendingOnly == true ? "bg-amber-500 text-white shadow-lg" : "border border-slate-300 text-slate-700 hover:bg-slate-50")">
    <span class="inline-block">⏳ Chờ duyệt</span>
  </a>
</div>

<!-- Places Table -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr class="text-left text-sm font-semibold text-slate-700">
          <th class="px-6 py-4">Tên quán</th>
          <th class="px-6 py-4">Chủ quán</th>
          <th class="px-6 py-4">Địa chỉ</th>
          <th class="px-6 py-4">Loại</th>
          <th class="px-6 py-4">Trạng thái</th>
          <th class="px-6 py-4 text-center">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        @if (!Model.Any()) {
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-slate-500">
              <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-4xl text-slate-300">storefront</span>
                <p class="font-semibold">Không có quán cần duyệt</p>
              </div>
            </td>
          </tr>
        }
        @foreach (var p in Model) {
          <tr class="hover:bg-slate-50 transition">
            <td class="px-6 py-4">
              <div class="font-semibold text-slate-900">@p.Name</div>
            </td>
            <td class="px-6 py-4">
              <small class="text-slate-600">@p.OwnerName</small>
            </td>
            <td class="px-6 py-4">
              <small class="text-slate-600">@p.Address</small>
            </td>
            <td class="px-6 py-4">
              <span class="text-slate-600">@p.CategoryName</span>
            </td>
            <td class="px-6 py-4">
              @switch(p.Status) {
                case "Active":
                  <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold rounded-full">
                    ✅ Hoạt động
                  </span>
                  break;
                case "Pending":
                  <span class="inline-block px-3 py-1 bg-amber-50 text-amber-700 text-xs font-semibold rounded-full">
                    ⏳ Chờ duyệt
                  </span>
                  break;
                case "Suspended":
                  <span class="inline-block px-3 py-1 bg-red-50 text-red-700 text-xs font-semibold rounded-full">
                    🔒 Tạm khóa
                  </span>
                  break;
              }
            </td>
            <td class="px-6 py-4">
              <div class="flex gap-2 justify-center">
                @if (p.Status == "Pending") {
                  <form method="post" asp-action="Approve" asp-route-id="@p.PlaceId" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-lg transition text-sm">
                      ✅ Duyệt
                    </button>
                  </form>
                }
                @if (p.Status == "Active") {
                  <form method="post" asp-action="Suspend" asp-route-id="@p.PlaceId" class="inline"
                        onsubmit="return confirm('Tạm khóa quán này?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg transition text-sm">
                      🔒 Tạm khóa
                    </button>
                  </form>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>