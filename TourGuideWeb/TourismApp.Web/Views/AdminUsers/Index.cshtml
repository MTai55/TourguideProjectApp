@model List<TourismApp.Web.Models.UserViewModel>
@{ ViewData["Title"] = "Quản lý Users"; }

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-slate-900">👥 Quản lý Tài khoản</h1>
  <p class="text-slate-500 mt-2">Quản lý người dùng và phân quyền trên hệ thống</p>
</div>

<!-- Search & Filter -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-8">
  <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <!-- Search -->
    <div class="md:col-span-2">
      <label class="block text-sm font-semibold text-slate-700 mb-2">Tìm kiếm</label>
      <input name="search" value="@ViewBag.Search" type="text"
        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white" 
        placeholder="Email hoặc tên...">
    </div>

    <!-- Role -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-2">Role</label>
      <select name="role" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white">
        <option value="">Tất cả role</option>
        <option value="Admin">Admin</option>
        <option value="Owner">Chủ quán</option>
        <option value="User">Người dùng</option>
      </select>
    </div>

    <!-- Search Button -->
    <div class="flex items-end">
      <button type="submit" class="w-full px-6 py-2 text-white font-bold rounded-lg transition hover:shadow-lg"
        style="background: linear-gradient(135deg, #954400, #fc8127)">
        Tìm kiếm
      </button>
    </div>
  </form>
</div>

<!-- Users Table -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr class="text-left text-sm font-semibold text-slate-700">
          <th class="px-6 py-4">Tên</th>
          <th class="px-6 py-4">Email</th>
          <th class="px-6 py-4">Điện thoại</th>
          <th class="px-6 py-4">Role</th>
          <th class="px-6 py-4">Trạng thái</th>
          <th class="px-6 py-4 text-center">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        @if (!Model.Any()) {
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-slate-500">
              <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-4xl text-slate-300">people</span>
                <p class="font-semibold">Không tìm thấy tài khoản</p>
              </div>
            </td>
          </tr>
        }
        @foreach (var u in Model) {
          <tr class="hover:bg-slate-50 transition">
            <td class="px-6 py-4">
              <div class="font-semibold text-slate-900">@u.FullName</div>
            </td>
            <td class="px-6 py-4">
              <span class="text-slate-600 text-sm">@u.Email</span>
            </td>
            <td class="px-6 py-4">
              <span class="text-slate-600 text-sm">@u.Phone</span>
            </td>
            <td class="px-6 py-4">
              @switch(u.Role) {
                case "Admin":
                  <span class="inline-block px-3 py-1 bg-purple-50 text-purple-700 text-xs font-semibold rounded-full">
                    👑 Admin
                  </span>
                  break;
                case "Owner":
                  <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold rounded-full">
                    🍜 Chủ quán
                  </span>
                  break;
                default:
                  <span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 text-xs font-semibold rounded-full">
                    👤 Người dùng
                  </span>
                  break;
              }
            </td>
            <td class="px-6 py-4">
              @if (u.IsActive) {
                <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold rounded-full">
                  ✅ Hoạt động
                </span>
              } else {
                <span class="inline-block px-3 py-1 bg-red-50 text-red-700 text-xs font-semibold rounded-full">
                  🔒 Đã khóa
                </span>
              }
            </td>
            <td class="px-6 py-4">
              <div class="flex gap-2 justify-center">
                <!-- Lock/Unlock Button -->
                <form method="post" asp-action="ToggleLock" asp-route-id="@u.UserId" class="inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="px-3 py-2 rounded-lg transition text-sm font-bold @(u.IsActive ? "bg-red-50 text-red-700 hover:bg-red-100" : "bg-emerald-50 text-emerald-700 hover:bg-emerald-100")">
                    @(u.IsActive ? "🔒 Khóa" : "🔓 Mở")
                  </button>
                </form>

                <!-- Role Selector -->
                <form method="post" asp-action="ChangeRole" class="inline">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@u.UserId">
                  <select name="role" class="px-3 py-2 rounded-lg border border-slate-300 text-sm font-bold text-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white"
                          onchange="this.form.submit()">
                    <option value="User"  @Html.Raw(u.Role=="User" ?"selected":"")>User</option>
                    <option value="Owner" @Html.Raw(u.Role=="Owner"?"selected":"")>Owner</option>
                    <option value="Admin" @Html.Raw(u.Role=="Admin"?"selected":"")>Admin</option>
                  </select>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>