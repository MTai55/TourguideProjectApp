@{ ViewData["Title"] = "Thống kê quán"; }

<h4 class="fw-bold mb-4">📈 Thống kê quán</h4>

<div class="row g-3 mb-4">
  <div class="col-md-8">
    <div class="card shadow-sm p-4">
      <h6 class="fw-bold">📍 Lượt ghé thăm 30 ngày</h6>
      <canvas id="visitsChart" height="100"></canvas>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm p-4">
      <h6 class="fw-bold">⭐ Phân bổ đánh giá</h6>
      <canvas id="ratingChart" height="160"></canvas>
    </div>
  </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
new Chart(document.getElementById('ratingChart'), {
  type: 'bar',
  data: {
    labels: ['1⭐','2⭐','3⭐','4⭐','5⭐'],
    datasets: [{ data: [2,3,8,25,40], backgroundColor: ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6'] }]
  },
  options: { plugins: { legend: { display: false } } }
});
</script>
}