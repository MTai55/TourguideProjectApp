@model TourismApp.Web.Models.LoginViewModel
@{ ViewData["Title"] = "Đăng nhập"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="min-h-screen w-full flex items-center justify-center" style="background: linear-gradient(135deg,#1e293b,#3182ce)">
  <div class="bg-white rounded-2xl shadow-2xl overflow-hidden" style="width:420px">
    <div class="p-8">
      <h2 class="text-center text-2xl font-bold mb-2">🗺️ TourGuide</h2>

      @if (!ViewData.ModelState.IsValid) {
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
          <div class="text-red-700 text-sm">
            @Html.ValidationSummary(false)
          </div>
        </div>
      }

      <form asp-action="Login" method="post" class="space-y-4">
        @Html.AntiForgeryToken()
        <div>
          <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
          <input asp-for="Email" type="email" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="email@example.com">
          <span asp-validation-for="Email" class="text-red-600 text-xs mt-1 block"></span>
        </div>
        <div>
          <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-2">Mật khẩu</label>
          <input asp-for="Password" type="password" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="••••••">
          <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
        </div>
        <button type="submit" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition mt-6">Đăng nhập</button>
      </form>

      <p class="text-center mt-6 text-gray-600 text-sm">
        Chưa có tài khoản? <a asp-action="Register" class="text-blue-600 hover:text-blue-700 font-semibold">Đăng ký ngay</a>
      </p>
    </div>
  </div>
</div>
