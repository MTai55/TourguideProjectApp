@model TourismApp.Web.Models.RegisterViewModel
@{ ViewData["Title"] = "Đăng ký"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="min-h-screen flex items-center justify-center p-4" style="background: linear-gradient(135deg,#1e293b,#3182ce)">
  <div class="bg-white rounded-2xl shadow-2xl p-8" style="width:100%;max-width:460px">
    <h2 class="text-center text-2xl font-black mb-1">🗺️ Đăng Ký</h2>
    <p class="text-center text-gray-600 mb-6 text-sm">Tạo tài khoản chủ địa điểm</p>

    @if (!ViewData.ModelState.IsValid) {
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-4 text-sm">
        @Html.ValidationSummary(false)
      </div>
    }

    <form asp-action="Register" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Role" value="Owner">
      
      <div class="mb-4">
        <label asp-for="FullName" class="block text-sm font-semibold text-gray-700 mb-2"></label>
        <input asp-for="FullName" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="Nguyễn Văn A">
        <span asp-validation-for="FullName" class="text-red-600 text-sm block mt-1"></span>
      </div>
      
      <div class="mb-4">
        <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-2"></label>
        <input asp-for="Email" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="email@example.com">
        <span asp-validation-for="Email" class="text-red-600 text-sm block mt-1"></span>
      </div>
      
      <div class="mb-4">
        <label asp-for="Phone" class="block text-sm font-semibold text-gray-700 mb-2"></label>
        <input asp-for="Phone" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="0901234567">
      </div>
      
      <div class="mb-6">
        <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-2"></label>
        <input asp-for="Password" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="Tối thiểu 6 ký tự">
        <span asp-validation-for="Password" class="text-red-600 text-sm block mt-1"></span>
      </div>
      
      <button type="submit" class="w-full py-3 px-6 bg-gradient-to-r from-blue-600 to-blue-700 text-white font-bold rounded-xl hover:shadow-lg transition-all duration-200 hover:scale-104">
        Tạo tài khoản
      </button>
    </form>
    
    <p class="text-center mt-4 text-gray-600 text-sm">
      Đã có tài khoản? <a asp-action="Login" class="text-blue-600 font-semibold hover:underline">Đăng nhập</a>
    </p>
  </div>
</div>