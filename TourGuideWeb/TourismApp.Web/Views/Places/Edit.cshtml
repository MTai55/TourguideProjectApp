@using TourismApp.Web.Models
@model TourismApp.Web.Models.CreatePlaceViewModel
@{ ViewData["Title"] = "Chỉnh sửa quán"; }

<div class="flex items-center gap-3 mb-6 pt-2">
  <a asp-controller="Places" asp-action="Index"
     class="flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors text-sm font-semibold">
    <span class="material-symbols-outlined text-lg">arrow_back</span> Quay lại
  </a>
  <span class="text-slate-300">/</span>
  <h2 class="text-2xl font-bold tracking-tight">Chỉnh sửa quán</h2>
</div>

<!-- Tabs -->
<div class="flex gap-1 mb-6 bg-surface-container-low p-1 rounded-xl w-fit flex-wrap">
  @foreach (var (tab, label, icon) in new (string, string, string)[] {
    ("info",    "Thông tin",    "edit_note"),
    ("tts",     "TTS Script",  "record_voice_over"),
    ("images",  "Hình ảnh",    "photo_library"),
    ("danger",  "Xóa quán",    "delete_forever"),
  })
  {
    <button onclick="switchTab('@tab')" id="tab-btn-@tab"
            class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold transition-all
                   @(tab == "info" ? "bg-white shadow-sm text-on-surface" : "text-on-surface-variant hover:text-on-surface")">
      <span class="material-symbols-outlined text-base">@icon</span> @label
    </button>
  }
</div>

<!-- Tab: Thông tin -->
<div id="tab-info" class="tab-panel">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main form -->
    <div class="lg:col-span-2">
      <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-surface-container">
          <h3 class="font-bold text-base">Thông tin cơ bản</h3>
          <p class="text-xs text-on-surface-variant mt-0.5">Cập nhật tên, địa chỉ, giờ mở cửa và mô tả quán.</p>
        </div>
        <form asp-action="Edit" asp-route-id="@ViewBag.PlaceId" method="post" class="p-6">
          @Html.AntiForgeryToken()
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Tên quán *</label>
          <input asp-for="Name" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="Tên quán ăn" />
          <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Số điện thoại</label>
          <input asp-for="Phone" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="0901234567" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Loại hình</label>
          <div class="relative">
            <select asp-for="CategoryId" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm appearance-none focus:ring-2 focus:ring-primary/20">
              <option value="">Chọn loại hình...</option>
              <option value="1">🍽️ Nhà hàng</option>
              <option value="2">🥢 Quán ăn vặt</option>
              <option value="3">☕ Cà phê</option>
              <option value="4">🧋 Trà sữa & Đồ uống</option>
              <option value="5">🍰 Bánh & Tráng miệng</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none text-sm">expand_more</span>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Món đặc trưng</label>
          <input asp-for="Specialty" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="VD: Bún bò, Cơm tấm, Cà phê trứng..." />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Quận / Huyện</label>
          <div class="relative">
            <select asp-for="District" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm appearance-none focus:ring-2 focus:ring-primary/20">
              <option value="">Chọn quận...</option>
              @foreach (var q in new[]{"Quận 1","Quận 2","Quận 3","Quận 4","Quận 5","Quận 6","Quận 7","Quận 8","Quận 9","Quận 10","Quận 11","Quận 12","Bình Thạnh","Phú Nhuận","Gò Vấp","Tân Bình","Tân Phú","Bình Tân","Thủ Đức"})
              {
                <option value="@q" @(Model?.District == q ? "selected" : "")>@q</option>
              }
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none text-sm">expand_more</span>
          </div>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Địa chỉ *</label>
          <input asp-for="Address" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="123 Đường ABC, Quận 1, TP.HCM" />
          <span asp-validation-for="Address" class="text-xs text-red-500 mt-1 block"></span>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Vĩ độ (Latitude)</label>
          <input asp-for="Latitude" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="10.7769" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Kinh độ (Longitude)</label>
          <input asp-for="Longitude" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="106.7009" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giờ mở cửa</label>
          <input id="OpenTime" asp-for="OpenTime" type="time" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giờ đóng cửa</label>
          <input id="CloseTime" asp-for="CloseTime" type="time" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá thấp nhất (VNĐ)</label>
          <input id="PriceMin" asp-for="PriceMin" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="35000" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá cao nhất (VNĐ)</label>
          <input id="PriceMax" asp-for="PriceMax" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="150000" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá/người (VNĐ)</label>
          <input asp-for="PricePerPerson" type="number" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="50000" />
        </div>
        <div class="flex flex-col gap-3 justify-center">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" asp-for="HasParking" class="w-4 h-4 rounded" />
            <span class="text-sm font-semibold">🅿️ Có bãi đỗ xe</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" asp-for="HasAircon" class="w-4 h-4 rounded" />
            <span class="text-sm font-semibold">❄️ Có điều hòa</span>
          </label>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Mô tả quán</label>
          <textarea asp-for="Description" rows="4"
                    class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20 resize-none"
                    placeholder="Mô tả về quán, phong cách ẩm thực, điểm nổi bật..."></textarea>
        </div>
        <div class="md:col-span-2 flex gap-3 pt-2">
          <button type="submit"
                  class="flex-1 md:flex-none flex items-center justify-center gap-2 px-8 py-3.5 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all"
                  style="background:linear-gradient(135deg,#954400,#fc8127)">
            <span class="material-symbols-outlined text-sm">save</span> Lưu thay đổi
          </button>
          <a asp-controller="Places" asp-action="Index"
             class="px-6 py-3.5 bg-surface-container-low text-on-surface font-bold rounded-xl text-sm hover:bg-surface-container-high transition-colors">
            Hủy
          </a>
        </div>
      </div>
    </form>
      </div>
    </div>

    <!-- Side Panel: Last Saved Values -->
    <div class="lg:col-span-1">
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 sticky top-4 space-y-4">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-blue-600">history</span>
          <h4 class="font-bold text-blue-900">Lần sửa trước</h4>
        </div>
        
        <p class="text-xs text-blue-700 leading-relaxed">
          Những thông tin dưới đây là giá trị từ lần sửa cuối cùng. Bạn có thể tham khảo để chỉnh sửa chính xác hơn.
        </p>

        <!-- Giờ mở cửa cũ -->
        @if (!string.IsNullOrEmpty(Model.PreviousOpenTime))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">⏰ Giờ mở cửa (cũ)</p>
            <div class="flex gap-2 items-center">
              <p class="text-sm text-blue-700 bg-white rounded px-3 py-2 flex-1">@Model.PreviousOpenTime</p>
              <button type="button" onclick="copyOldValue('OpenTime', '@Model.PreviousOpenTime')"
                      title="Copy giá trị cũ"
                      class="p-2 text-blue-600 hover:bg-blue-100 rounded transition-colors">
                <span class="material-symbols-outlined text-sm">content_copy</span>
              </button>
            </div>
          </div>
        }

        <!-- Giờ đóng cửa cũ -->
        @if (!string.IsNullOrEmpty(Model.PreviousCloseTime))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">🕐 Giờ đóng cửa (cũ)</p>
            <div class="flex gap-2 items-center">
              <p class="text-sm text-blue-700 bg-white rounded px-3 py-2 flex-1">@Model.PreviousCloseTime</p>
              <button type="button" onclick="copyOldValue('CloseTime', '@Model.PreviousCloseTime')"
                      title="Copy giá trị cũ"
                      class="p-2 text-blue-600 hover:bg-blue-100 rounded transition-colors">
                <span class="material-symbols-outlined text-sm">content_copy</span>
              </button>
            </div>
          </div>
        }

        <!-- Giá cũ -->
        @if (Model.PreviousPriceMin.HasValue || Model.PreviousPriceMax.HasValue)
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">💰 Giá (cũ)</p>
            <div class="flex gap-2 items-start">
              <div class="flex-1">
                @if (Model.PreviousPriceMin.HasValue)
                {
                  <button type="button" onclick="copyOldValue('PriceMin', '@Model.PreviousPriceMin')"
                          title="Copy giá thấp"
                          class="w-full text-sm text-blue-700 bg-white rounded px-3 py-2 hover:bg-blue-50 transition-colors text-left flex justify-between items-center">
                    <span>Từ: @Model.PreviousPriceMin:N0đ</span>
                    <span class="material-symbols-outlined text-xs ml-2">content_copy</span>
                  </button>
                }
              </div>
            </div>
            @if (Model.PreviousPriceMax.HasValue)
            {
              <div class="flex gap-2 items-start mt-1">
                <button type="button" onclick="copyOldValue('PriceMax', '@Model.PreviousPriceMax')"
                        title="Copy giá cao"
                        class="w-full text-sm text-blue-700 bg-white rounded px-3 py-2 hover:bg-blue-50 transition-colors text-left flex justify-between items-center">
                  <span>Đến: @Model.PreviousPriceMax:N0đ</span>
                  <span class="material-symbols-outlined text-xs ml-2">content_copy</span>
                </button>
              </div>
            }
          </div>
        }

        <!-- TTS Script cũ -->
        @if (!string.IsNullOrEmpty(Model.PreviousTtsScript))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">🎙️ TTS Script (cũ)</p>
            <div class="text-sm text-blue-700 bg-white rounded px-3 py-2 max-h-32 overflow-y-auto mb-2">
              @Model.PreviousTtsScript
            </div>
            <button type="button" onclick="copyOldValue('TtsScript', @System.Text.Json.JsonSerializer.Serialize(Model.PreviousTtsScript))"
                    title="Copy TTS Script"
                    class="w-full px-3 py-2 text-sm font-semibold text-blue-700 bg-blue-100 hover:bg-blue-200 rounded transition-colors flex items-center justify-center gap-1">
              <span class="material-symbols-outlined text-sm">content_copy</span> Copy Script
            </button>
          </div>
        }

        <!-- Không có dữ liệu cũ -->
        @if (string.IsNullOrEmpty(Model.PreviousOpenTime) && 
             string.IsNullOrEmpty(Model.PreviousCloseTime) && 
             !Model.PreviousPriceMin.HasValue && 
             !Model.PreviousPriceMax.HasValue && 
             string.IsNullOrEmpty(Model.PreviousTtsScript))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-sm text-blue-600 italic">ℹ️ Chưa có dữ liệu lần sửa trước. Đây là lần đầu tiên chỉnh sửa.</p>
          </div>
        }

        <!-- Last Modified -->
        @if (Model.LastModifiedAt.HasValue)
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs text-blue-600">
              <strong>Sửa lần cuối:</strong> @Model.LastModifiedAt.Value.ToString("dd/MM/yyyy HH:mm")
            </p>
          </div>
        }
      </div>
    </div>
  </div>
</div>

<!-- ══ Tab: TTS Script ════════════════════════════════════════════ -->
<div id="tab-tts" class="tab-panel hidden">
  <div class="space-y-5">

    <!-- TTS Contents by Locale -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-surface-container flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-blue-100 text-blue-600 rounded-xl">
            <span class="material-symbols-outlined">language</span>
          </div>
          <div>
            <h3 class="font-bold text-base">TTS Scripts by Language</h3>
            <p class="text-xs text-on-surface-variant mt-0.5">Quản lý nội dung TTS cho từng ngôn ngữ</p>
          </div>
        </div>
      </div>
      <div class="p-6">
        <div id="ttsContentsContainer" class="space-y-4">
          <div class="flex items-center justify-center py-8">
            <div class="animate-spin">
              <span class="material-symbols-outlined text-3xl text-slate-400">hourglass_empty</span>
            </div>
            <span class="text-slate-500 ml-2">Đang tải...</span>
          </div>
        </div>
        
        <button type="button" onclick="showAddTtsContentModal()"
                class="mt-6 w-full flex items-center justify-center gap-2 px-4 py-3 bg-blue-50 text-blue-700 font-bold rounded-xl text-sm hover:bg-blue-100 transition-colors">
          <span class="material-symbols-outlined text-sm">add_circle</span> Thêm Script Mới
        </button>
      </div>
    </div>

    <!-- Modal Add/Edit TTS Content -->
    <div id="ttsContentModal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4">
      <div class="bg-surface-container-lowest rounded-2xl shadow-lg w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <div class="sticky top-0 px-6 py-4 border-b border-surface-container flex items-center justify-between bg-surface-container-lowest">
          <h2 class="text-xl font-bold">Quản lý TTS Script</h2>
          <button onclick="closeModal()" type="button" class="text-on-surface-variant hover:text-on-surface">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        
        <div class="p-6 space-y-4">
          <div>
            <label class="text-sm font-bold text-on-surface-variant uppercase tracking-wider">Ngôn ngữ (Locale)</label>
            <select id="localeSelect" class="w-full mt-2 px-4 py-2 bg-surface-container-high border border-surface-container rounded-xl text-on-surface font-semibold">
              <option value="">-- Chọn ngôn ngữ --</option>
              <option value="vi-VN">Tiếng Việt (vi-VN)</option>
              <option value="en-US">English (en-US)</option>
              <option value="zh-CN">中文 简体 (zh-CN)</option>
              <option value="ko-KR">한국어 (ko-KR)</option>
              <option value="ja-JP">日本語 (ja-JP)</option>
              <option value="fr-FR">Français (fr-FR)</option>
              <option value="th-TH">ไทย (th-TH)</option>
            </select>
          </div>
          
          <div>
            <label class="text-sm font-bold text-on-surface-variant uppercase tracking-wider">Script Content</label>
            <textarea id="scriptInput" class="w-full mt-2 px-4 py-3 bg-surface-container-high border border-surface-container rounded-xl text-on-surface font-mono text-sm resize-none"
                      placeholder="Nhập nội dung TTS script..." rows="8"></textarea>
            <p class="text-xs text-on-surface-variant mt-2">
              <span id="charCount">0</span> ký tự (tối đa 500)
            </p>
          </div>
          
          <div class="flex gap-3 pt-4">
            <button onclick="closeModal()" type="button"
                    class="flex-1 px-4 py-2 bg-surface-container-high text-on-surface font-bold rounded-xl hover:bg-surface-container-high/80 transition-colors">
              Hủy
            </button>
            <button onclick="saveTtsContent()" type="button"
                    class="flex-1 px-4 py-2 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors">
              <span class="material-symbols-outlined align-middle">save</span> Lưu
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
<!-- Tab: Hình ảnh -->
<div id="tab-images" class="tab-panel hidden">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main content -->
    <div class="lg:col-span-2">
      <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-surface-container">
          <h3 class="font-bold text-base">Quản lý hình ảnh</h3>
          <p class="text-xs text-on-surface-variant mt-0.5">Thêm URL hình ảnh để giới thiệu quán với khách hàng.</p>
        </div>
        <div class="p-6 space-y-6">
          <form method="post" asp-action="AddImage" asp-route-id="@ViewBag.PlaceId" class="">
            @Html.AntiForgeryToken()
            <div class="flex flex-col sm:flex-row gap-3">
              <input name="imageUrl"
                     class="flex-1 px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                     placeholder="https://example.com/image.jpg" required />
              <div class="flex items-center gap-3">
                <label class="flex items-center gap-2 text-sm font-semibold cursor-pointer">
                  <input type="checkbox" name="isMain" class="rounded" />
                  Ảnh chính
                </label>
                <button type="submit"
                        class="px-5 py-3 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all flex items-center gap-2 shrink-0"
                        style="background:linear-gradient(135deg,#954400,#fc8127)">
                  <span class="material-symbols-outlined text-sm">add_photo_alternate</span> Thêm ảnh
                </button>
              </div>
            </div>
          </form>
          
          <div>
            <h4 class="text-sm font-semibold mb-4">Danh sách hình ảnh</h4>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              @foreach (var img in (ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>) ?? new List<TourismApp.Web.Models.PlaceImageViewModel>())
              {
                <div class="relative group rounded-xl overflow-hidden">
                  <img src="@img.ImageUrl" alt="Place image" class="w-full h-40 object-cover" />
                  <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center">
                    <form method="post" asp-action="DeleteImage" asp-route-imageId="@img.ImageId">
                      @Html.AntiForgeryToken()
                      <button type="submit" class="p-2 bg-red-600 text-white rounded-full hover:bg-red-700 transition-colors">
                        <span class="material-symbols-outlined text-sm">delete</span>
                      </button>
                    </form>
                  </div>
                  @if (img.IsMain)
                  {
                    <span class="absolute top-2 left-2 px-2 py-1 bg-primary text-white text-[10px] font-bold rounded-lg">Ảnh chính</span>
                  }
                </div>
              }
              
              @if (!((ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>)?.Any() ?? false))
              {
                <div class="flex flex-col items-center py-12 text-center">
                  <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">photo_library</span>
                  <p class="text-sm text-on-surface-variant">Chưa có hình ảnh nào. Thêm URL ảnh ở trên.</p>
                </div>
              }
            </div>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 sticky top-4 space-y-4">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-amber-600">image</span>
          <h4 class="font-bold text-amber-900">Ảnh hiện tại</h4>
        </div>
        
        @{
          var mainImage = (ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>)?.FirstOrDefault(x => x.IsMain);
        }

        @if (mainImage != null)
        {
          <div class="space-y-3">
            <div class="pt-3 border-t border-amber-200">
              <p class="text-xs font-semibold text-amber-900 mb-2">🖼️ Ảnh chính sử dụng</p>
              <div class="relative rounded-xl overflow-hidden bg-white shadow-md">
                <img src="@mainImage.ImageUrl" alt="Main place image" class="w-full h-40 object-cover" />
                <span class="absolute top-2 right-2 px-2 py-1 bg-amber-600 text-white text-[10px] font-bold rounded-lg">CHÍNH</span>
              </div>
            </div>
            <div class="pt-3 border-t border-amber-200">
              <p class="text-xs font-semibold text-amber-900 mb-1">🔗 URL</p>
              <div class="text-xs text-amber-700 bg-white rounded px-3 py-2 break-all max-h-20 overflow-y-auto">
                @mainImage.ImageUrl
              </div>
            </div>
            <button type="button" onclick="copyToClipboard('@mainImage.ImageUrl')"
                    class="w-full px-3 py-2 text-sm font-semibold text-amber-700 bg-amber-100 hover:bg-amber-200 rounded-xl transition-colors flex items-center justify-center gap-1">
              <span class="material-symbols-outlined text-sm">content_copy</span> Copy URL
            </button>
          </div>
        }
        else
        {
          <div class="pt-3 border-t border-amber-200">
            <p class="text-sm text-amber-600 italic">ℹ️ Chưa có ảnh chính nào được chọn.</p>
            <p class="text-xs text-amber-600 mt-2">Thêm ảnh mới rồi chọn "Ảnh chính" khi thêm.</p>
          </div>
        }

        @{
          var otherImages = (ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>)?.Where(x => !x.IsMain).ToList() ?? new();
        }

        @if (otherImages.Count > 0)
        {
          <div class="pt-3 border-t border-amber-200">
            <p class="text-xs font-semibold text-amber-900 mb-2">📸 Hình ảnh khác (@otherImages.Count)</p>
            <div class="grid grid-cols-2 gap-2">
              @foreach (var img in otherImages.Take(4))
              {
                <div class="relative rounded-lg overflow-hidden shadow-sm cursor-pointer hover:opacity-80 transition-opacity"
                     onclick="showImagePreview('@img.ImageUrl', '@System.Web.HttpUtility.JavaScriptStringEncode(img.ImageUrl)')">
                  <img src="@img.ImageUrl" alt="Place thumbnail" class="w-full h-20 object-cover" />
                </div>
              }
            </div>
          </div>
        }
      </div>
    </div>
  </div>

<!-- Tab: Nguy hiểm -->
<div id="tab-danger" class="tab-panel hidden">
  <div class="bg-surface-container-lowest rounded-xl shadow-sm border-2 border-red-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-red-100 bg-red-50">
      <h3 class="font-bold text-base text-red-700">⚠️ Vùng nguy hiểm</h3>
      <p class="text-xs text-red-600 mt-0.5">Các thao tác không thể hoàn tác. Hãy cẩn thận!</p>
    </div>
    <div class="p-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-5 bg-red-50 rounded-xl border border-red-100">
        <div>
          <h4 class="font-bold text-red-800">Xóa quán này</h4>
          <p class="text-sm text-red-600 mt-1">Quán sẽ bị ẩn khỏi hệ thống. Dữ liệu vẫn được lưu trữ nhưng khách không thể tìm thấy.</p>
        </div>
        <form method="post" asp-controller="Places" asp-action="Delete" asp-route-id="@ViewBag.PlaceId"
              onsubmit="return confirm('Bạn chắc chắn muốn xóa quán này?')">
          @Html.AntiForgeryToken()
          <button type="submit"
                  class="px-6 py-3 bg-red-600 text-white font-bold rounded-xl text-sm hover:bg-red-700 transition-colors flex items-center gap-2 shrink-0">
            <span class="material-symbols-outlined text-sm">delete_forever</span> Xóa quán
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script id="tts-script-block">
  const JWT_TOKEN = '@Html.Raw(Context.Session.GetString("JwtToken") ?? "")';
  const PLACE_ID  = '@ViewBag.PlaceId';
  const API_BASE  = 'http://localhost:5010';

  // Lưu translations hiện có
  let currentTranslations = {};
  try {
    const raw = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TtsTranslations ?? "{}").Trim('"'))';
    if (raw && raw !== '{}') currentTranslations = JSON.parse(raw.replace(/\\"/g, '"'));
  } catch(e) {}

  // ── Tab switching ─────────────────────────────────────────────
  function switchTab(tab) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById('tab-' + tab).classList.remove('hidden');
    document.querySelectorAll('[id^="tab-btn-"]').forEach(b => {
      b.classList.remove('bg-white','shadow-sm','text-on-surface');
      b.classList.add('text-on-surface-variant','hover:text-on-surface');
    });
    const btn = document.getElementById('tab-btn-' + tab);
    btn.classList.remove('text-on-surface-variant','hover:text-on-surface');
    btn.classList.add('bg-white','shadow-sm','text-on-surface');
    if (tab === 'tts') setTimeout(updateCharCount, 50);
  }

  // ── Char counter ──────────────────────────────────────────────
  const ta = document.getElementById('tts-textarea');
  function updateCharCount() {
    const len = ta?.value?.length ?? 0;
    const el  = document.getElementById('char-count');
    if (!el) return;
    el.textContent = `${len} / 1000 ký tự`;
    el.className   = `text-xs font-medium ${len > 900 ? 'text-red-500' : len > 700 ? 'text-amber-600' : 'text-on-surface-variant'}`;
  }
  ta?.addEventListener('input', updateCharCount);
  updateCharCount();

  // ── TTS Preview ───────────────────────────────────────────────
  function previewTts(lang) {
    let text = '';
    if (lang === 'vi') {
      text = ta?.value?.trim() || '';
    } else {
      text = currentTranslations[lang] || document.getElementById('text-' + lang)?.textContent?.trim() || '';
    }
    if (!text || text.includes('Bấm')) { alert('Chưa có nội dung!'); return; }
    if (!window.speechSynthesis) { alert('Trình duyệt không hỗ trợ TTS.'); return; }

    stopPreview();
    const u = new SpeechSynthesisUtterance(text);
    u.lang  = { vi:'vi-VN', en:'en-US', zh:'zh-CN', ko:'ko-KR', ja:'ja-JP', fr:'fr-FR' }[lang] || 'vi-VN';
    u.rate  = 0.95;

    document.getElementById('preview-text').textContent = text;
    document.getElementById('preview-box').classList.remove('hidden');
    u.onend = () => document.getElementById('preview-box').classList.add('hidden');
    window.speechSynthesis.speak(u);
  }

  function stopPreview() {
    window.speechSynthesis?.cancel();
    document.getElementById('preview-box')?.classList.add('hidden');
  }

  function clearScript() {
    if (!confirm('Xóa toàn bộ nội dung script?')) return;
    if (ta) { ta.value = ''; updateCharCount(); }
    stopPreview();
  }

  // ── Translate ─────────────────────────────────────────────────
  async function translateScript() {
    // Tính năng dịch tự động - coming soon
    showToast('🚧 Tính năng dịch tự động sắp ra mắt. Vui lòng quay lại sau!', 'error');
    return;
  }

  function showToast(msg, type) {
    const cfg = { success:'bg-emerald-50 border-emerald-100 text-emerald-700', error:'bg-red-50 border-red-100 text-red-700' };
    const el = document.createElement('div');
    el.className = `flex items-center gap-3 px-4 py-3 rounded-xl border text-sm font-semibold shadow-lg min-w-[260px] ${cfg[type]||cfg.success}`;
    el.textContent = msg;
    let c = document.getElementById('toast-container');
    if (!c) { c = document.createElement('div'); c.id='toast-container'; c.className='fixed bottom-6 right-6 z-[9999] flex flex-col gap-3'; document.body.appendChild(c); }
    c.appendChild(el);
    setTimeout(() => el.remove(), 5000);
  }

  if (window.location.hash === '#tts') switchTab('tts');

  // Copy giá trị cũ vào form
  function copyOldValue(fieldName, value) {
    const field = document.getElementById(fieldName);
    
    if (fieldName === 'TtsScript') {
      // TtsScript là textarea trong tab TTS → chuyển tab TTS trước
      switchTab('tts');
      setTimeout(() => {
        const ttsTextarea = document.getElementById('tts-textarea');
        if (ttsTextarea) {
          ttsTextarea.value = value;
          ttsTextarea.classList.add('ring-2', 'ring-emerald-400');
          ttsTextarea.focus();
          ttsTextarea.scrollIntoView({ behavior: 'smooth', block: 'center' });
          setTimeout(() => ttsTextarea.classList.remove('ring-2', 'ring-emerald-400'), 1500);
          showToast('✅ Đã copy TTS Script cũ vào form!', 'success');
        }
      }, 300);
    } else if (field) {
      // Input fields (OpenTime, CloseTime, PriceMin, PriceMax)
      field.value = value;
      field.classList.add('ring-2', 'ring-emerald-400');
      field.focus();
      field.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(() => field.classList.remove('ring-2', 'ring-emerald-400'), 1500);
      showToast(`✅ Đã copy ${fieldName} cũ!`, 'success');
    }
  }

  // Copy URL ảnh vào clipboard
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
      showToast('✅ Đã copy URL ảnh!', 'success');
    }).catch(err => {
      showToast('❌ Không thể copy URL', 'error');
    });
  }

  // Xem trước ảnh toàn màn hình
  function showImagePreview(imageUrl, title) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4';
    modal.innerHTML = `
      <div class="relative max-w-4xl max-h-[90vh] bg-white rounded-xl overflow-auto">
        <button onclick="this.closest('.fixed').remove()" 
                class="absolute top-2 right-2 p-2 bg-black/50 text-white rounded-full hover:bg-black/70 z-10">
          <span class="material-symbols-outlined">close</span>
        </button>
        <img src="${imageUrl}" alt="Preview" class="w-full h-auto" />
      </div>
    `;
    document.body.appendChild(modal);
  }

  // ── TTS CONTENTS BY LOCALE ────────────────────────────────────
  let placeId = '@ViewBag.PlaceId';
  let currentEditingId = null;

  // Load TTS Contents on page load
  document.addEventListener('DOMContentLoaded', () => {
    loadTtsContents();
    
    // Character counter
    document.getElementById('scriptInput')?.addEventListener('input', (e) => {
      document.getElementById('charCount').textContent = e.target.value.length;
    });
  });

  async function loadTtsContents() {
    try {
      const response = await fetch(`/api/places/${placeId}/tts-contents`);
      if (!response.ok) throw new Error('Failed to load TTS contents');
      
      const data = await response.json();
      const container = document.getElementById('ttsContentsContainer');
      
      if (!data.contents || data.contents.length === 0) {
        container.innerHTML = `
          <div class="flex flex-col items-center py-10 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">language</span>
            <p class="font-bold text-on-surface-variant">Chưa có script cho ngôn ngữ nào</p>
            <p class="text-xs text-on-surface-variant mt-1">Hãy thêm script đầu tiên cho quán này.</p>
          </div>
        `;
        return;
      }
      
      container.innerHTML = data.contents.map(content => `
        <div class="bg-surface-container-high rounded-xl p-4 border border-surface-container">
          <div class="flex items-start justify-between mb-3">
            <div>
              <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider">Ngôn ngữ</p>
              <p class="font-semibold text-on-surface">${getLocaleName(content.locale)}</p>
              <p class="text-[10px] text-on-surface-variant mt-0.5">${content.locale}</p>
            </div>
            <div class="flex gap-2">
              <button onclick="editTtsContent(${content.id}, '${content.locale}', \`${content.script.replace(/`/g, '\\`')}\`)" 
                      type="button" class="px-3 py-1.5 bg-blue-50 text-blue-700 rounded-lg text-xs font-bold hover:bg-blue-100 transition-colors">
                <span class="material-symbols-outlined text-sm align-middle">edit</span>
              </button>
              <button onclick="deleteTtsContent(${content.id}, '${content.locale}')" type="button" 
                      class="px-3 py-1.5 bg-red-50 text-red-700 rounded-lg text-xs font-bold hover:bg-red-100 transition-colors">
                <span class="material-symbols-outlined text-sm align-middle">delete</span>
              </button>
            </div>
          </div>
          <p class="text-sm text-on-surface leading-relaxed bg-surface-container rounded-lg p-3 mb-2">
            ${escapeHtml(content.script)}
          </p>
          <p class="text-[10px] text-on-surface-variant">${content.script.length} ký tự</p>
        </div>
      `).join('');
    } catch (error) {
      console.error('Error loading TTS contents:', error);
      document.getElementById('ttsContentsContainer').innerHTML = `
        <div class="text-center py-8 text-red-600">
          Lỗi tải dữ liệu. Vui lòng tải lại trang.
        </div>
      `;
    }
  }

  function getLocaleName(locale) {
    const names = {
      'vi-VN': 'Tiếng Việt',
      'en-US': 'English',
      'zh-CN': '中文 简体',
      'ko-KR': '한국어',
      'ja-JP': '日本語',
      'fr-FR': 'Français',
      'th-TH': 'ไทย'
    };
    return names[locale] || locale;
  }

  function showAddTtsContentModal() {
    currentEditingId = null;
    document.getElementById('localeSelect').value = '';
    document.getElementById('scriptInput').value = '';
    document.getElementById('charCount').textContent = '0';
    document.getElementById('ttsContentModal').classList.remove('hidden');
  }

  function editTtsContent(contentId, locale, script) {
    currentEditingId = contentId;
    document.getElementById('localeSelect').value = locale;
    document.getElementById('localeSelect').disabled = true;
    document.getElementById('scriptInput').value = script;
    document.getElementById('charCount').textContent = script.length;
    document.getElementById('ttsContentModal').classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('ttsContentModal').classList.add('hidden');
    document.getElementById('localeSelect').disabled = false;
    currentEditingId = null;
  }

  async function saveTtsContent() {
    const locale = document.getElementById('localeSelect').value;
    const script = document.getElementById('scriptInput').value.trim();
    
    if (!locale) {
      alert('Vui lòng chọn ngôn ngữ');
      return;
    }
    
    if (!script) {
      alert('Vui lòng nhập nội dung script');
      return;
    }
    
    try {
      let url, method, body;
      
      if (currentEditingId) {
        // Update existing
        url = `/api/places/${placeId}/tts-contents/${currentEditingId}`;
        method = 'PUT';
        body = { script };
      } else {
        // Create new
        url = `/api/places/${placeId}/tts-contents`;
        method = 'POST';
        body = { locale, script };
      }
      
      const response = await fetch(url, {
        method: method,
        headers: {
          'Content-Type': 'application/json',
          'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
        },
        body: JSON.stringify(body)
      });
      
      if (!response.ok) {
        const errorData = await response.json();
        alert('Lỗi: ' + (errorData.message || 'Không thể lưu script'));
        return;
      }
      
      closeModal();
      await loadTtsContents();
      showToast('✅ Đã lưu TTS script thành công!', 'success');
    } catch (error) {
      console.error('Error saving TTS content:', error);
      alert('Lỗi: ' + error.message);
    }
  }

  async function deleteTtsContent(contentId, locale) {
    if (!confirm(`Bạn chắc chắn muốn xóa script cho ngôn ngữ ${getLocaleName(locale)}?`)) {
      return;
    }
    
    try {
      const response = await fetch(`/api/places/${placeId}/tts-contents/${contentId}`, {
        method: 'DELETE',
        headers: {
          'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
        }
      });
      
      if (!response.ok) {
        alert('Lỗi khi xóa script');
        return;
      }
      
      await loadTtsContents();
      showToast('✅ Đã xóa TTS script thành công!', 'success');
    } catch (error) {
      console.error('Error deleting TTS content:', error);
      alert('Lỗi: ' + error.message);
    }
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

</script>
}
