@using TourismApp.Web.Models
@model TourismApp.Web.Models.CreatePlaceViewModel
@{ ViewData["Title"] = "Chỉnh sửa quán"; }

<div class="flex items-center gap-3 mb-6 pt-2">
  <a asp-controller="Places" asp-action="Index"
     class="flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors text-sm font-semibold">
    <span class="material-symbols-outlined text-lg">arrow_back</span> Quay lại
  </a>
  <span class="text-slate-300">/</span>
  <h2 class="text-2xl font-bold tracking-tight">Chỉnh sửa quán</h2>
</div>

<!-- Tabs -->
<div class="flex gap-1 mb-6 bg-surface-container-low p-1 rounded-xl w-fit flex-wrap">
  @foreach (var (tab, label, icon) in new (string, string, string)[] {
    ("info",    "Thông tin",    "edit_note"),
    ("tts",     "TTS Script",  "record_voice_over"),
    ("images",  "Hình ảnh",    "photo_library"),
    ("danger",  "Xóa quán",    "delete_forever"),
  })
  {
    <button onclick="switchTab('@tab')" id="tab-btn-@tab"
            class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold transition-all
                   @(tab == "info" ? "bg-white shadow-sm text-on-surface" : "text-on-surface-variant hover:text-on-surface")">
      <span class="material-symbols-outlined text-base">@icon</span> @label
    </button>
  }
</div>

<!-- Tab: Thông tin -->
<div id="tab-info" class="tab-panel">
  <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-surface-container">
      <h3 class="font-bold text-base">Thông tin cơ bản</h3>
      <p class="text-xs text-on-surface-variant mt-0.5">Cập nhật tên, địa chỉ, giờ mở cửa và mô tả quán.</p>
    </div>
    <form asp-action="Edit" asp-route-id="@ViewBag.PlaceId" method="post" class="p-6">
      @Html.AntiForgeryToken()
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Tên quán *</label>
          <input asp-for="Name" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="Tên quán ăn" />
          <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Số điện thoại</label>
          <input asp-for="Phone" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="0901234567" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Loại hình</label>
          <div class="relative">
            <select asp-for="CategoryId" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm appearance-none focus:ring-2 focus:ring-primary/20">
              <option value="">Chọn loại hình...</option>
              <option value="1">🍽️ Nhà hàng</option>
              <option value="2">🥢 Quán ăn vặt</option>
              <option value="3">☕ Cà phê</option>
              <option value="4">🧋 Trà sữa & Đồ uống</option>
              <option value="5">🍰 Bánh & Tráng miệng</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none text-sm">expand_more</span>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Món đặc trưng</label>
          <input asp-for="Specialty" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="VD: Bún bò, Cơm tấm, Cà phê trứng..." />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Quận / Huyện</label>
          <div class="relative">
            <select asp-for="District" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm appearance-none focus:ring-2 focus:ring-primary/20">
              <option value="">Chọn quận...</option>
              @foreach (var q in new[]{"Quận 1","Quận 2","Quận 3","Quận 4","Quận 5","Quận 6","Quận 7","Quận 8","Quận 9","Quận 10","Quận 11","Quận 12","Bình Thạnh","Phú Nhuận","Gò Vấp","Tân Bình","Tân Phú","Bình Tân","Thủ Đức"})
              {
                <option value="@q" @(Model?.District == q ? "selected" : "")>@q</option>
              }
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none text-sm">expand_more</span>
          </div>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Địa chỉ *</label>
          <input asp-for="Address" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="123 Đường ABC, Quận 1, TP.HCM" />
          <span asp-validation-for="Address" class="text-xs text-red-500 mt-1 block"></span>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Vĩ độ (Latitude)</label>
          <input asp-for="Latitude" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="10.7769" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Kinh độ (Longitude)</label>
          <input asp-for="Longitude" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="106.7009" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giờ mở cửa</label>
          <input asp-for="OpenTime" type="time" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giờ đóng cửa</label>
          <input asp-for="CloseTime" type="time" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá thấp nhất (VNĐ)</label>
          <input asp-for="PriceMin" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="35000" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá cao nhất (VNĐ)</label>
          <input asp-for="PriceMax" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="150000" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá/người (VNĐ)</label>
          <input asp-for="PricePerPerson" type="number" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="50000" />
        </div>
        <div class="flex flex-col gap-3 justify-center">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" asp-for="HasParking" class="w-4 h-4 rounded" />
            <span class="text-sm font-semibold">🅿️ Có bãi đỗ xe</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" asp-for="HasAircon" class="w-4 h-4 rounded" />
            <span class="text-sm font-semibold">❄️ Có điều hòa</span>
          </label>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Mô tả quán</label>
          <textarea asp-for="Description" rows="4"
                    class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20 resize-none"
                    placeholder="Mô tả về quán, phong cách ẩm thực, điểm nổi bật..."></textarea>
        </div>
        <div class="md:col-span-2 flex gap-3 pt-2">
          <button type="submit"
                  class="flex-1 md:flex-none flex items-center justify-center gap-2 px-8 py-3.5 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all"
                  style="background:linear-gradient(135deg,#954400,#fc8127)">
            <span class="material-symbols-outlined text-sm">save</span> Lưu thay đổi
          </button>
          <a asp-controller="Places" asp-action="Index"
             class="px-6 py-3.5 bg-surface-container-low text-on-surface font-bold rounded-xl text-sm hover:bg-surface-container-high transition-colors">
            Hủy
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- ══ Tab: TTS Script ════════════════════════════════════════════ -->
<div id="tab-tts" class="tab-panel hidden">
  <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-surface-container">
      <div class="flex items-start gap-3">
        <div class="p-2.5 bg-violet-100 text-violet-600 rounded-xl">
          <span class="material-symbols-outlined">record_voice_over</span>
        </div>
        <div>
          <h3 class="font-bold text-base">TTS Narration Script</h3>
          <p class="text-xs text-on-surface-variant mt-0.5">
            Đoạn văn bản sẽ được đọc tự động khi khách du lịch đến gần quán của bạn.
            Hệ thống dùng Text-to-Speech để phát âm thanh giới thiệu qua ứng dụng di động.
          </p>
        </div>
      </div>
    </div>

    <div class="p-6 space-y-5">
      <!-- Tips box -->
      <div class="p-4 bg-violet-50 border border-violet-100 rounded-xl space-y-2">
        <p class="text-xs font-bold text-violet-700 flex items-center gap-1.5">
          <span class="material-symbols-outlined text-sm">lightbulb</span>
          Gợi ý viết script hiệu quả
        </p>
        <ul class="text-xs text-violet-600 space-y-1 ml-5 list-disc">
          <li>Ngắn gọn, súc tích — tối đa 200 từ</li>
          <li>Bắt đầu bằng tên quán và điểm nổi bật nhất</li>
          <li>Nêu món đặc trưng, giờ mở cửa, hoặc ưu đãi hiện tại</li>
          <li>Dùng ngôn ngữ thân thiện, mời gọi khách ghé thăm</li>
          <li>Tránh dùng ký tự đặc biệt như &#33;, &#64;, &#35;, &amp;</li>
        </ul>
      </div>

      <!-- Script textarea -->
      <form asp-action="UpdateTtsScript" asp-route-id="@ViewBag.PlaceId" method="post">
        @Html.AntiForgeryToken()
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <label class="block text-sm font-semibold">Nội dung script</label>
            <span id="char-count" class="text-xs text-on-surface-variant font-medium">0 / 1000 ký tự</span>
          </div>
          <textarea id="tts-textarea" name="ttsScript" rows="8"
                    class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-violet-400/30 resize-none leading-relaxed"
                    maxlength="1000"
                    placeholder="Ví dụ: Chào mừng bạn đến với Nhà Hàng Ngon tại 160 Pasteur, Quận 3. Chúng tôi tự hào phục vụ hơn 40 món ăn Nam Bộ truyền thống. Đặc biệt hôm nay có bánh xèo giòn tan và gỏi cuốn tươi mát. Mở cửa từ 7 giờ sáng đến 10 giờ tối. Hẹn gặp bạn tại đây!">@ViewBag.TtsScript</textarea>

          <!-- Preview -->
          <div id="preview-box" class="hidden p-4 bg-slate-900 rounded-xl">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-sm text-violet-400">volume_up</span>
              Preview — Âm thanh sẽ phát
            </p>
            <p id="preview-text" class="text-sm text-white leading-relaxed"></p>
            <button type="button" onclick="stopPreview()"
                    class="mt-3 text-xs text-slate-400 hover:text-white font-semibold flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">stop_circle</span> Dừng
            </button>
          </div>

          <div class="flex gap-3 pt-2">
            <!-- Preview button -->
            <button type="button" onclick="previewTts()"
                    class="flex items-center gap-2 px-5 py-3 bg-violet-50 text-violet-700 font-bold rounded-xl text-sm hover:bg-violet-100 transition-colors">
              <span class="material-symbols-outlined text-sm">play_circle</span> Nghe thử
            </button>

            <!-- Clear button -->
            <button type="button" onclick="clearScript()"
                    class="flex items-center gap-2 px-5 py-3 bg-surface-container-low text-on-surface-variant font-bold rounded-xl text-sm hover:bg-surface-container-high transition-colors">
              <span class="material-symbols-outlined text-sm">clear</span> Xóa script
            </button>

            <!-- Save button -->
            <button type="submit"
                    class="flex items-center gap-2 px-7 py-3 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all ml-auto"
                    style="background:linear-gradient(135deg,#7c3aed,#a855f7)">
              <span class="material-symbols-outlined text-sm">save</span> Lưu script
            </button>
          </div>
        </div>
      </form>

      <!-- Current script info -->
      @if (!string.IsNullOrEmpty(ViewBag.TtsScript as string))
      {
        <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-xl flex items-start gap-3">
          <span class="material-symbols-outlined text-emerald-600 mt-0.5">check_circle</span>
          <div>
            <p class="text-sm font-bold text-emerald-700">Script đang hoạt động</p>
            <p class="text-xs text-emerald-600 mt-0.5">
              Script của bạn sẽ được phát khi khách đến trong bán kính
              <strong>@(ViewBag.Radius ?? 100)m</strong> quanh quán.
            </p>
          </div>
        </div>
      }
      else
      {
        <div class="p-4 bg-amber-50 border border-amber-100 rounded-xl flex items-start gap-3">
          <span class="material-symbols-outlined text-amber-600 mt-0.5">info</span>
          <div>
            <p class="text-sm font-bold text-amber-700">Chưa có script</p>
            <p class="text-xs text-amber-600 mt-0.5">Nhập script ở trên để kích hoạt tính năng narration cho quán của bạn.</p>
          </div>
        </div>
      }
    </div>
  </div>
</div>

<!-- Tab: Hình ảnh -->
<div id="tab-images" class="tab-panel hidden">
  <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-surface-container">
      <h3 class="font-bold text-base">Quản lý hình ảnh</h3>
      <p class="text-xs text-on-surface-variant mt-0.5">Thêm URL hình ảnh để giới thiệu quán với khách hàng.</p>
    </div>
    <div class="p-6">
      <form method="post" asp-action="AddImage" asp-route-id="@ViewBag.PlaceId" class="mb-6">
        @Html.AntiForgeryToken()
        <div class="flex flex-col sm:flex-row gap-3">
          <input name="imageUrl"
                 class="flex-1 px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="https://example.com/image.jpg" required />
          <div class="flex items-center gap-3">
            <label class="flex items-center gap-2 text-sm font-semibold cursor-pointer">
              <input type="checkbox" name="isMain" class="rounded" />
              Ảnh chính
            </label>
            <button type="submit"
                    class="px-5 py-3 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all flex items-center gap-2 shrink-0"
                    style="background:linear-gradient(135deg,#954400,#fc8127)">
              <span class="material-symbols-outlined text-sm">add_photo_alternate</span> Thêm ảnh
            </button>
          </div>
        </div>
      </form>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        @foreach (var img in (ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>) ?? new List<TourismApp.Web.Models.PlaceImageViewModel>())
        {
          <div class="relative group rounded-xl overflow-hidden">
            <img src="@img.ImageUrl" alt="Place image" class="w-full h-40 object-cover" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center">
              <form method="post" asp-action="DeleteImage" asp-route-imageId="@img.ImageId">
                @Html.AntiForgeryToken()
                <button type="submit" class="p-2 bg-red-600 text-white rounded-full hover:bg-red-700 transition-colors">
                  <span class="material-symbols-outlined text-sm">delete</span>
                </button>
              </form>
            </div>
            @if (img.IsMain)
            {
              <span class="absolute top-2 left-2 px-2 py-1 bg-primary text-white text-[10px] font-bold rounded-lg">Ảnh chính</span>
            }
          </div>
        }
        @if (!((ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>)?.Any() ?? false))
        {
          <div class="col-span-full flex flex-col items-center py-12 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">photo_library</span>
            <p class="text-sm text-on-surface-variant">Chưa có hình ảnh nào. Thêm URL ảnh ở trên.</p>
          </div>
        }
      </div>
    </div>
  </div>
</div>

<!-- Tab: Nguy hiểm -->
<div id="tab-danger" class="tab-panel hidden">
  <div class="bg-surface-container-lowest rounded-xl shadow-sm border-2 border-red-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-red-100 bg-red-50">
      <h3 class="font-bold text-base text-red-700">⚠️ Vùng nguy hiểm</h3>
      <p class="text-xs text-red-600 mt-0.5">Các thao tác không thể hoàn tác. Hãy cẩn thận!</p>
    </div>
    <div class="p-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-5 bg-red-50 rounded-xl border border-red-100">
        <div>
          <h4 class="font-bold text-red-800">Xóa quán này</h4>
          <p class="text-sm text-red-600 mt-1">Quán sẽ bị ẩn khỏi hệ thống. Dữ liệu vẫn được lưu trữ nhưng khách không thể tìm thấy.</p>
        </div>
        <form method="post" asp-controller="Places" asp-action="Delete" asp-route-id="@ViewBag.PlaceId"
              onsubmit="return confirm('Bạn chắc chắn muốn xóa quán này?')">
          @Html.AntiForgeryToken()
          <button type="submit"
                  class="px-6 py-3 bg-red-600 text-white font-bold rounded-xl text-sm hover:bg-red-700 transition-colors flex items-center gap-2 shrink-0">
            <span class="material-symbols-outlined text-sm">delete_forever</span> Xóa quán
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
  // ── Tab switching ─────────────────────────────────────────────
  function switchTab(tab) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById('tab-' + tab).classList.remove('hidden');
    document.querySelectorAll('[id^="tab-btn-"]').forEach(b => {
      b.classList.remove('bg-white', 'shadow-sm', 'text-on-surface');
      b.classList.add('text-on-surface-variant', 'hover:text-on-surface');
    });
    const btn = document.getElementById('tab-btn-' + tab);
    btn.classList.remove('text-on-surface-variant', 'hover:text-on-surface');
    btn.classList.add('bg-white', 'shadow-sm', 'text-on-surface');
    // Invalidate mini map if exists
    if (tab === 'tts') setTimeout(() => updateCharCount(), 50);
  }

  // ── Char counter ──────────────────────────────────────────────
  const ta = document.getElementById('tts-textarea');
  function updateCharCount() {
    const len = ta?.value?.length ?? 0;
    const el  = document.getElementById('char-count');
    if (el) {
      el.textContent = `${len} / 1000 ký tự`;
      el.className   = `text-xs font-medium ${len > 900 ? 'text-red-500' : len > 700 ? 'text-amber-600' : 'text-on-surface-variant'}`;
    }
  }
  ta?.addEventListener('input', updateCharCount);
  updateCharCount();

  // ── TTS Preview (Web Speech API) ─────────────────────────────
  let utterance = null;
  function previewTts() {
    const text = ta?.value?.trim();
    if (!text) { alert('Chưa có nội dung script!'); return; }
    if (!window.speechSynthesis) { alert('Trình duyệt không hỗ trợ TTS.'); return; }
    stopPreview();
    utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'vi-VN';
    utterance.rate = 0.95;
    utterance.pitch = 1;

    // Show preview box
    document.getElementById('preview-text').textContent = text;
    document.getElementById('preview-box').classList.remove('hidden');

    utterance.onend = () => document.getElementById('preview-box').classList.add('hidden');
    window.speechSynthesis.speak(utterance);
  }

  function stopPreview() {
    window.speechSynthesis?.cancel();
    document.getElementById('preview-box')?.classList.add('hidden');
  }

  function clearScript() {
    if (!confirm('Xóa toàn bộ nội dung script?')) return;
    if (ta) { ta.value = ''; updateCharCount(); }
    stopPreview();
  }

  // ── Open TTS tab if hash ──────────────────────────────────────
  if (window.location.hash === '#tts') switchTab('tts');
</script>
}
