@section Scripts {
<script id="tts-script-block">
  const JWT_TOKEN = '@Html.Raw(Context.Session.GetString("JwtToken") ?? "")';
  const PLACE_ID  = '@ViewBag.PlaceId';
  const API_BASE  = 'http://localhost:5010';

  // Lưu translations hiện có
  let currentTranslations = {};
  try {
    const raw = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TtsTranslations ?? "{}").Trim('"'))';
    if (raw && raw !== '{}') currentTranslations = JSON.parse(raw.replace(/\\"/g, '"'));
  } catch(e) {}

  // ── Tab switching ─────────────────────────────────────────────
  function switchTab(tab) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById('tab-' + tab).classList.remove('hidden');
    document.querySelectorAll('[id^="tab-btn-"]').forEach(b => {
      b.classList.remove('bg-white','shadow-sm','text-on-surface');
      b.classList.add('text-on-surface-variant','hover:text-on-surface');
    });
    const btn = document.getElementById('tab-btn-' + tab);
    btn.classList.remove('text-on-surface-variant','hover:text-on-surface');
    btn.classList.add('bg-white','shadow-sm','text-on-surface');
    if (tab === 'tts') setTimeout(updateCharCount, 50);
  }

  // ── Char counter ──────────────────────────────────────────────
  const ta = document.getElementById('tts-textarea');
  function updateCharCount() {
    const len = ta?.value?.length ?? 0;
    const el  = document.getElementById('char-count');
    if (!el) return;
    el.textContent = `${len} / 1000 ký tự`;
    el.className   = `text-xs font-medium ${len > 900 ? 'text-red-500' : len > 700 ? 'text-amber-600' : 'text-on-surface-variant'}`;
  }
  ta?.addEventListener('input', updateCharCount);
  updateCharCount();

  // ── TTS Preview ───────────────────────────────────────────────
  function previewTts(lang) {
    let text = '';
    if (lang === 'vi') {
      text = ta?.value?.trim() || '';
    } else {
      text = currentTranslations[lang] || document.getElementById('text-' + lang)?.textContent?.trim() || '';
    }
    if (!text || text.includes('Bấm')) { alert('Chưa có nội dung!'); return; }
    if (!window.speechSynthesis) { alert('Trình duyệt không hỗ trợ TTS.'); return; }

    stopPreview();
    const u = new SpeechSynthesisUtterance(text);
    u.lang  = { vi:'vi-VN', en:'en-US', zh:'zh-CN', ko:'ko-KR', ja:'ja-JP', fr:'fr-FR' }[lang] || 'vi-VN';
    u.rate  = 0.95;

    document.getElementById('preview-text').textContent = text;
    document.getElementById('preview-box').classList.remove('hidden');
    u.onend = () => document.getElementById('preview-box').classList.add('hidden');
    window.speechSynthesis.speak(u);
  }

  function stopPreview() {
    window.speechSynthesis?.cancel();
    document.getElementById('preview-box')?.classList.add('hidden');
  }

  function clearScript() {
    if (!confirm('Xóa toàn bộ nội dung script?')) return;
    if (ta) { ta.value = ''; updateCharCount(); }
    stopPreview();
  }

  // ── Translate ─────────────────────────────────────────────────
  async function translateScript() {
    // Tính năng dịch tự động - coming soon
    showToast('🚧 Tính năng dịch tự động sắp ra mắt. Vui lòng quay lại sau!', 'error');
    return;
  }

  function showToast(msg, type) {
    const cfg = { success:'bg-emerald-50 border-emerald-100 text-emerald-700', error:'bg-red-50 border-red-100 text-red-700' };
    const el = document.createElement('div');
    el.className = `flex items-center gap-3 px-4 py-3 rounded-xl border text-sm font-semibold shadow-lg min-w-[260px] ${cfg[type]||cfg.success}`;
    el.textContent = msg;
    let c = document.getElementById('toast-container');
    if (!c) { c = document.createElement('div'); c.id='toast-container'; c.className='fixed bottom-6 right-6 z-[9999] flex flex-col gap-3'; document.body.appendChild(c); }
    c.appendChild(el);
    setTimeout(() => el.remove(), 5000);
  }

  if (window.location.hash === '#tts') switchTab('tts');

  // Copy giá trị cũ vào form
  function copyOldValue(fieldName, value) {
    const field = document.getElementById(fieldName);
    
    if (fieldName === 'TtsScript') {
      // TtsScript là textarea trong tab TTS → chuyển tab TTS trước
      switchTab('tts');
      setTimeout(() => {
        const ttsTextarea = document.getElementById('tts-textarea');
        if (ttsTextarea) {
          ttsTextarea.value = value;
          ttsTextarea.classList.add('ring-2', 'ring-emerald-400');
          ttsTextarea.focus();
          ttsTextarea.scrollIntoView({ behavior: 'smooth', block: 'center' });
          setTimeout(() => ttsTextarea.classList.remove('ring-2', 'ring-emerald-400'), 1500);
          showToast('✅ Đã copy TTS Script cũ vào form!', 'success');
        }
      }, 300);
    } else if (field) {
      // Input fields (OpenTime, CloseTime, PriceMin, PriceMax)
      field.value = value;
      field.classList.add('ring-2', 'ring-emerald-400');
      field.focus();
      field.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(() => field.classList.remove('ring-2', 'ring-emerald-400'), 1500);
      showToast(`✅ Đã copy ${fieldName} cũ!`, 'success');
    }
  }

  // Copy URL ảnh vào clipboard
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
      showToast('✅ Đã copy URL ảnh!', 'success');
    }).catch(err => {
      showToast('❌ Không thể copy URL', 'error');
    });
  }

  // Xem trước ảnh toàn màn hình
  function showImagePreview(imageUrl, title) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4';
    modal.innerHTML = `
      <div class="relative max-w-4xl max-h-[90vh] bg-white rounded-xl overflow-auto">
        <button onclick="this.closest('.fixed').remove()" 
                class="absolute top-2 right-2 p-2 bg-black/50 text-white rounded-full hover:bg-black/70 z-10">
          <span class="material-symbols-outlined">close</span>
        </button>
        <img src="${imageUrl}" alt="Preview" class="w-full h-auto" />
      </div>
    `;
    document.body.appendChild(modal);
  }

</script>
}
