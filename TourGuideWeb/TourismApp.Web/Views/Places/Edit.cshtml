                  <span class="material-symbols-outlined text-sm">add_photo_alternate</span> Thêm ảnh
                </button>
              </div>
            </div>
          </form>
          
          <div>
            <h4 class="text-sm font-semibold mb-4">Danh sách hình ảnh</h4>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              @foreach (var img in (ViewBag.Images as List<TourismApp.Web.Models.PlaceImageViewModel>) ?? new List<TourismApp.Web.Models.PlaceImageViewModel>())
