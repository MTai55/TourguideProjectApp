@using TourismApp.Web.Models
@model TourismApp.Web.Models.CreatePlaceViewModel
@{ ViewData["Title"] = "Chỉnh sửa quán"; }

<div class="flex items-center gap-3 mb-6 pt-2">
  <a asp-controller="Places" asp-action="Index"
     class="flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors text-sm font-semibold">
    <span class="material-symbols-outlined text-lg">arrow_back</span> Quay lại
  </a>
  <span class="text-slate-300">/</span>
  <h2 class="text-2xl font-bold tracking-tight">Chỉnh sửa quán</h2>
</div>

<!-- Tabs -->
<div class="flex gap-1 mb-6 bg-surface-container-low p-1 rounded-xl w-fit flex-wrap">
  @foreach (var (tab, label, icon) in new (string, string, string)[] {
    ("info",    "Thông tin",    "edit_note"),
    ("tts",     "TTS Script",  "record_voice_over"),
    ("images",  "Hình ảnh",    "photo_library"),
    ("danger",  "Xóa quán",    "delete_forever"),
  })
  {
    <button onclick="switchTab('@tab')" id="tab-btn-@tab"
            class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold transition-all
                   @(tab == "info" ? "bg-white shadow-sm text-on-surface" : "text-on-surface-variant hover:text-on-surface")">
      <span class="material-symbols-outlined text-base">@icon</span> @label
    </button>
  }
</div>

<!-- Tab: Thông tin -->
<div id="tab-info" class="tab-panel">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main form -->
    <div class="lg:col-span-2">
      <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-surface-container">
          <h3 class="font-bold text-base">Thông tin cơ bản</h3>
          <p class="text-xs text-on-surface-variant mt-0.5">Cập nhật tên, địa chỉ, giờ mở cửa và mô tả quán.</p>
        </div>
        <form asp-action="Edit" asp-route-id="@ViewBag.PlaceId" method="post" class="p-6">
          @Html.AntiForgeryToken()
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Tên quán *</label>
          <input asp-for="Name" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="Tên quán ăn" />
          <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Số điện thoại</label>
          <input asp-for="Phone" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="0901234567" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Loại hình</label>
          <div class="relative">
            <select asp-for="CategoryId" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm appearance-none focus:ring-2 focus:ring-primary/20">
              <option value="">Chọn loại hình...</option>
              <option value="1">🍽️ Nhà hàng</option>
              <option value="2">🥢 Quán ăn vặt</option>
              <option value="3">☕ Cà phê</option>
              <option value="4">🧋 Trà sữa & Đồ uống</option>
              <option value="5">🍰 Bánh & Tráng miệng</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none text-sm">expand_more</span>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Món đặc trưng</label>
          <input asp-for="Specialty" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="VD: Bún bò, Cơm tấm, Cà phê trứng..." />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Quận / Huyện</label>
          <div class="relative">
            <select asp-for="District" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm appearance-none focus:ring-2 focus:ring-primary/20">
              <option value="">Chọn quận...</option>
              @foreach (var q in new[]{"Quận 1","Quận 2","Quận 3","Quận 4","Quận 5","Quận 6","Quận 7","Quận 8","Quận 9","Quận 10","Quận 11","Quận 12","Bình Thạnh","Phú Nhuận","Gò Vấp","Tân Bình","Tân Phú","Bình Tân","Thủ Đức"})
              {
                <option value="@q" @(Model?.District == q ? "selected" : "")>@q</option>
              }
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none text-sm">expand_more</span>
          </div>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Địa chỉ *</label>
          <input asp-for="Address" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="123 Đường ABC, Quận 1, TP.HCM" />
          <span asp-validation-for="Address" class="text-xs text-red-500 mt-1 block"></span>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Vĩ độ (Latitude)</label>
          <input asp-for="Latitude" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="10.7769" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Kinh độ (Longitude)</label>
          <input asp-for="Longitude" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="106.7009" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giờ mở cửa</label>
          <input id="OpenTime" asp-for="OpenTime" type="time" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giờ đóng cửa</label>
          <input id="CloseTime" asp-for="CloseTime" type="time" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá thấp nhất (VNĐ)</label>
          <input id="PriceMin" asp-for="PriceMin" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="35000" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá cao nhất (VNĐ)</label>
          <input id="PriceMax" asp-for="PriceMax" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="150000" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-2">Giá/người (VNĐ)</label>
          <input asp-for="PricePerPerson" type="number" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="50000" />
        </div>
        <div class="flex flex-col gap-3 justify-center">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" asp-for="HasParking" class="w-4 h-4 rounded" />
            <span class="text-sm font-semibold">🅿️ Có bãi đỗ xe</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" asp-for="HasAircon" class="w-4 h-4 rounded" />
            <span class="text-sm font-semibold">❄️ Có điều hòa</span>
          </label>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold mb-2">Mô tả quán</label>
          <textarea asp-for="Description" rows="4"
                    class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20 resize-none"
                    placeholder="Mô tả về quán, phong cách ẩm thực, điểm nổi bật..."></textarea>
        </div>
        <div class="md:col-span-2 flex gap-3 pt-2">
          <button type="submit"
                  class="flex-1 md:flex-none flex items-center justify-center gap-2 px-8 py-3.5 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all"
                  style="background:linear-gradient(135deg,#954400,#fc8127)">
            <span class="material-symbols-outlined text-sm">save</span> Lưu thay đổi
          </button>
          <a asp-controller="Places" asp-action="Index"
             class="px-6 py-3.5 bg-surface-container-low text-on-surface font-bold rounded-xl text-sm hover:bg-surface-container-high transition-colors">
            Hủy
          </a>
        </div>
      </div>
    </form>
      </div>
    </div>

    <!-- Side Panel: Last Saved Values -->
    <div class="lg:col-span-1">
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 sticky top-4 space-y-4">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-blue-600">history</span>
          <h4 class="font-bold text-blue-900">Lần sửa trước</h4>
        </div>
        
        <p class="text-xs text-blue-700 leading-relaxed">
          Những thông tin dưới đây là giá trị từ lần sửa cuối cùng. Bạn có thể tham khảo để chỉnh sửa chính xác hơn.
        </p>

        <!-- Giờ mở cửa cũ -->
        @if (!string.IsNullOrEmpty(Model.PreviousOpenTime))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">⏰ Giờ mở cửa (cũ)</p>
            <div class="flex gap-2 items-center">
              <p class="text-sm text-blue-700 bg-white rounded px-3 py-2 flex-1">@Model.PreviousOpenTime</p>
              <button type="button" onclick="copyOldValue('OpenTime', '@Model.PreviousOpenTime')"
                      title="Copy giá trị cũ"
                      class="p-2 text-blue-600 hover:bg-blue-100 rounded transition-colors">
                <span class="material-symbols-outlined text-sm">content_copy</span>
              </button>
            </div>
          </div>
        }

        <!-- Giờ đóng cửa cũ -->
        @if (!string.IsNullOrEmpty(Model.PreviousCloseTime))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">🕐 Giờ đóng cửa (cũ)</p>
            <div class="flex gap-2 items-center">
              <p class="text-sm text-blue-700 bg-white rounded px-3 py-2 flex-1">@Model.PreviousCloseTime</p>
              <button type="button" onclick="copyOldValue('CloseTime', '@Model.PreviousCloseTime')"
                      title="Copy giá trị cũ"
                      class="p-2 text-blue-600 hover:bg-blue-100 rounded transition-colors">
                <span class="material-symbols-outlined text-sm">content_copy</span>
              </button>
            </div>
          </div>
        }

        <!-- Giá cũ -->
        @if (Model.PreviousPriceMin.HasValue || Model.PreviousPriceMax.HasValue)
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">💰 Giá (cũ)</p>
            <div class="flex gap-2 items-start">
              <div class="flex-1">
                @if (Model.PreviousPriceMin.HasValue)
                {
                  <button type="button" onclick="copyOldValue('PriceMin', '@Model.PreviousPriceMin')"
                          title="Copy giá thấp"
                          class="w-full text-sm text-blue-700 bg-white rounded px-3 py-2 hover:bg-blue-50 transition-colors text-left flex justify-between items-center">
                    <span>Từ: @Model.PreviousPriceMin:N0đ</span>
                    <span class="material-symbols-outlined text-xs ml-2">content_copy</span>
                  </button>
                }
              </div>
            </div>
            @if (Model.PreviousPriceMax.HasValue)
            {
              <div class="flex gap-2 items-start mt-1">
                <button type="button" onclick="copyOldValue('PriceMax', '@Model.PreviousPriceMax')"
                        title="Copy giá cao"
                        class="w-full text-sm text-blue-700 bg-white rounded px-3 py-2 hover:bg-blue-50 transition-colors text-left flex justify-between items-center">
                  <span>Đến: @Model.PreviousPriceMax:N0đ</span>
                  <span class="material-symbols-outlined text-xs ml-2">content_copy</span>
                </button>
              </div>
            }
          </div>
        }

        <!-- TTS Script cũ -->
        @if (!string.IsNullOrEmpty(Model.PreviousTtsScript))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs font-semibold text-blue-900 mb-1">🎙️ TTS Script (cũ)</p>
            <div class="text-sm text-blue-700 bg-white rounded px-3 py-2 max-h-32 overflow-y-auto mb-2">
              @Model.PreviousTtsScript
            </div>
            <button type="button" onclick="copyOldValue('TtsScript', @System.Text.Json.JsonSerializer.Serialize(Model.PreviousTtsScript))"
                    title="Copy TTS Script"
                    class="w-full px-3 py-2 text-sm font-semibold text-blue-700 bg-blue-100 hover:bg-blue-200 rounded transition-colors flex items-center justify-center gap-1">
              <span class="material-symbols-outlined text-sm">content_copy</span> Copy Script
            </button>
          </div>
        }

        <!-- Không có dữ liệu cũ -->
        @if (string.IsNullOrEmpty(Model.PreviousOpenTime) && 
             string.IsNullOrEmpty(Model.PreviousCloseTime) && 
             !Model.PreviousPriceMin.HasValue && 
             !Model.PreviousPriceMax.HasValue && 
             string.IsNullOrEmpty(Model.PreviousTtsScript))
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-sm text-blue-600 italic">ℹ️ Chưa có dữ liệu lần sửa trước. Đây là lần đầu tiên chỉnh sửa.</p>
          </div>
        }

        <!-- Last Modified -->
        @if (Model.LastModifiedAt.HasValue)
        {
          <div class="pt-3 border-t border-blue-200">
            <p class="text-xs text-blue-600">
              <strong>Sửa lần cuối:</strong> @Model.LastModifiedAt.Value.ToString("dd/MM/yyyy HH:mm")
            </p>
          </div>
        }
      </div>
    </div>
  </div>
</div>

<!-- ══ Tab: TTS Script ════════════════════════════════════════════ -->
<div id="tab-tts" class="tab-panel hidden">
  <div class="space-y-5">

    <!-- Script chính -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-surface-container">
        <div class="flex items-start gap-3">
          <div class="p-2.5 bg-violet-100 text-violet-600 rounded-xl">
            <span class="material-symbols-outlined">record_voice_over</span>
          </div>
          <div>
            <h3 class="font-bold text-base">TTS Narration Script</h3>
            <p class="text-xs text-on-surface-variant mt-0.5">
              Viết script bằng tiếng Việt, sau đó bấm <strong>Dịch tự động</strong>
              để tạo bản dịch cho các ngôn ngữ khác.
            </p>
          </div>
        </div>
      </div>

      <div class="p-6 space-y-4">
        <!-- Tips -->
        <div class="p-4 bg-violet-50 border border-violet-100 rounded-xl space-y-2">
          <p class="text-xs font-bold text-violet-700 flex items-center gap-1.5">
            <span class="material-symbols-outlined text-sm">lightbulb</span>
            Gợi ý viết script hiệu quả
          </p>
          <ul class="text-xs text-violet-600 space-y-1 ml-5 list-disc">
            <li>Ngắn gọn, súc tích — tối đa 200 từ</li>
            <li>Bắt đầu bằng tên quán và điểm nổi bật nhất</li>
            <li>Nêu món đặc trưng, giờ mở cửa, ưu đãi hiện tại</li>
            <li>Tránh ký tự đặc biệt, viết tắt khó đọc</li>
          </ul>
        </div>

        <form asp-action="UpdateTtsScript" asp-route-id="@ViewBag.PlaceId" method="post" id="tts-form">
          @Html.AntiForgeryToken()
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label class="block text-sm font-semibold">Nội dung script (Tiếng Việt) *</label>
              <span id="char-count" class="text-xs text-on-surface-variant font-medium">0 / 1000 ký tự</span>
            </div>
            <textarea id="tts-textarea" name="ttsScript" rows="7"
                      class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-violet-400/30 resize-none leading-relaxed"
                      maxlength="1000"
                      placeholder="Chào mừng bạn đến với... Chúng tôi tự hào phục vụ... Hẹn gặp bạn tại đây!">@ViewBag.TtsScript</textarea>

            <!-- Preview box -->
            <div id="preview-box" class="hidden p-4 bg-slate-900 rounded-xl">
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm text-violet-400">volume_up</span>
                Đang phát...
              </p>
              <p id="preview-text" class="text-sm text-white leading-relaxed"></p>
              <button type="button" onclick="stopPreview()"
                      class="mt-3 text-xs text-slate-400 hover:text-white font-semibold flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">stop_circle</span> Dừng
              </button>
            </div>

            <div class="flex flex-wrap gap-2 pt-1">
              <button type="button" onclick="previewTts('vi')"
                      class="flex items-center gap-1.5 px-4 py-2.5 bg-violet-50 text-violet-700 font-bold rounded-xl text-sm hover:bg-violet-100 transition-colors">
                <span class="material-symbols-outlined text-sm">play_circle</span> Nghe thử
              </button>
              <button type="button" onclick="clearScript()"
                      class="flex items-center gap-1.5 px-4 py-2.5 bg-surface-container-low text-on-surface-variant font-bold rounded-xl text-sm hover:bg-surface-container-high transition-colors">
                <span class="material-symbols-outlined text-sm">clear</span> Xóa
              </button>
              <button type="submit"
                      class="flex items-center gap-1.5 px-6 py-2.5 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all"
                      style="background:linear-gradient(135deg,#7c3aed,#a855f7)">
                <span class="material-symbols-outlined text-sm">save</span> Lưu script
              </button>
              <!-- Nút dịch tự động - Coming Soon -->
              <div class="flex items-center gap-1.5 px-6 py-2.5 font-bold rounded-xl text-sm ml-auto cursor-not-allowed opacity-50"
                   style="background:linear-gradient(135deg,#0891b2,#06b6d4);color:white"
                   title="Tính năng dịch tự động sắp ra mắt">
                <span class="material-symbols-outlined text-sm">construction</span> Đang phát triển
              </div>
            </div>
          </div>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.TtsScript as string))
        {
          <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <div>
              <p class="text-sm font-bold text-emerald-700">Script đang hoạt động</p>
              <p class="text-xs text-emerald-600 mt-0.5">
                Bán kính kích hoạt: <strong>@(ViewBag.Radius ?? 100)m</strong>
              </p>
            </div>
          </div>
        }
      </div>
    </div>

    <!-- Bản dịch -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-surface-container flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="p-2.5 bg-cyan-100 text-cyan-600 rounded-xl">
            <span class="material-symbols-outlined">translate</span>
          </div>
          <div>
            <h3 class="font-bold text-base">Bản dịch đa ngôn ngữ</h3>
            <p class="text-xs text-on-surface-variant mt-0.5">
              Tự động dịch bởi AI — App mobile dùng đúng ngôn ngữ của khách
            </p>
          </div>
        </div>
        <span id="translate-status" class="text-xs font-bold px-3 py-1.5 rounded-xl
              @(string.IsNullOrEmpty(ViewBag.TtsTranslations as string) ? "bg-slate-100 text-slate-500" : "bg-emerald-50 text-emerald-700")">
          @(string.IsNullOrEmpty(ViewBag.TtsTranslations as string) ? "Chưa dịch" : "Đã dịch")
        </span>
      </div>

      <!-- Loading state -->
      <div id="translate-loading" class="hidden p-8 text-center">
        <div class="flex flex-col items-center gap-3">
          <div class="w-10 h-10 rounded-full border-4 border-cyan-200 border-t-cyan-600 animate-spin"></div>
          <p class="text-sm font-semibold text-on-surface-variant">Đang dịch tự động bằng AI...</p>
          <p class="text-xs text-on-surface-variant">Quá trình này mất khoảng 10-20 giây</p>
        </div>
      </div>

      <!-- Translations grid -->
      <div id="translations-grid" class="p-6">
        @{
          var langs = new (string code, string name, string flag)[] {
            ("vi","Tiếng Việt","🇻🇳"),
            ("en","English","🇺🇸"),
            ("zh","中文","🇨🇳"),
            ("ko","한국어","🇰🇷"),
            ("ja","日本語","🇯🇵"),
            ("fr","Français","🇫🇷"),
          };

          Dictionary<string, string>? existing = null;
          try {
            var raw = ViewBag.TtsTranslations as string;
            if (!string.IsNullOrEmpty(raw))
              existing = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(raw);
          } catch { }
        }

        @if (existing == null && string.IsNullOrEmpty(ViewBag.TtsScript as string))
        {
          <div class="flex flex-col items-center py-10 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">translate</span>
            <p class="font-bold text-on-surface-variant">Chưa có script để dịch</p>
            <p class="text-xs text-on-surface-variant mt-1">Nhập script tiếng Việt ở trên trước, sau đó bấm Dịch tự động.</p>
          </div>
        }
        else
        {
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="lang-cards">
            @foreach (var (code, name, flag) in langs)
            {
              string? txt = null;
              var hasText = existing != null && existing.TryGetValue(code, out txt) && !string.IsNullOrEmpty(txt);
              <div class="p-4 bg-surface-container-low rounded-xl" id="card-@code">
                <div class="flex items-center justify-between mb-2">
                  <span class="flex items-center gap-2 text-sm font-bold">
                    <span class="text-xl">@flag</span> @name
                  </span>
                  <div class="flex items-center gap-2">
                    @if (hasText)
                    {
                      <button type="button" onclick="previewTts('@code')"
                              class="p-1.5 text-violet-600 hover:bg-violet-100 rounded-lg transition-colors" title="Nghe thử">
                        <span class="material-symbols-outlined text-sm">play_circle</span>
                      </button>
                    }
                    <span class="text-[10px] font-bold px-2 py-1 rounded-lg @(hasText ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-400")">
                      @(code == "vi" ? (string.IsNullOrEmpty(ViewBag.TtsScript as string) ? "Trống" : "Có sẵn") : (hasText ? "Đã dịch" : "Chưa dịch"))
                    </span>
                  </div>
                </div>
                <p class="text-xs text-on-surface-variant leading-relaxed line-clamp-3" id="text-@code">
                  @if (code == "vi")
                  {
                    @(ViewBag.TtsScript as string ?? "—")
                  }
                  else if (hasText)
                  {
                    @txt
                  }
                  else
                  {
                    <span class="italic">Bấm "Dịch tự động" để tạo bản dịch...</span>
                  }
                </p>
              </div>
            }
          </div>

          @if (existing != null)
          {
            <div class="mt-4 p-3 bg-cyan-50 border border-cyan-100 rounded-xl flex items-center gap-2">
              <span class="material-symbols-outlined text-cyan-600 text-sm">info</span>
              <p class="text-xs text-cyan-700">
                Bản dịch được tạo tự động bởi AI. Bạn có thể bấm <strong>Dịch tự động</strong> lại sau khi cập nhật script để đồng bộ.
              </p>
            </div>
          }
        }
      </div>
    </div>

  </div>
</div>
<!-- Tab: Hình ảnh -->
