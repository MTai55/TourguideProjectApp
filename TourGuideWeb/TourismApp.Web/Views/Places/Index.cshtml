@using TourismApp.Web.Models
@model List<TourismApp.Web.Models.PlaceViewModel>
@{ ViewData["Title"] = "Quán của tôi"; }

<!-- Error Alert -->
@if (TempData["Error"] != null) {
  <div class="mb-6 px-6 py-3 bg-red-50 border border-red-200 rounded-lg text-red-700 font-semibold">
    @TempData["Error"]
  </div>
}
@{
  var catId    = (string?)ViewBag.CategoryId ?? "";
  var approved = (string?)ViewBag.IsApproved ?? "";
  var sort     = (string?)ViewBag.SortBy ?? "";
  var dist     = (string?)ViewBag.District ?? "";
  var maxPrc   = (string?)ViewBag.MaxPrice ?? "";
}

<!-- Header -->
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
  <div>
    <h1 class="text-3xl font-bold text-slate-900">🍜 Quán của tôi</h1>
    <p class="text-slate-500 mt-2">Quản lý <span class="font-bold text-slate-700">@ViewBag.Total</span> quán ăn của bạn</p>
  </div>
  <a asp-controller="Places" asp-action="Create" class="flex items-center gap-2 px-6 py-3 text-white font-bold rounded-lg transition hover:shadow-lg hover:scale-105"
    style="background: linear-gradient(135deg, #954400, #fc8127)">
    <span class="material-symbols-outlined">add_circle</span>
    Thêm quán mới
  </a>
</div>

<!-- Search & Filter -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-8">
  <form method="get" class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4">
      <!-- Tìm kiếm -->
      <div class="lg:col-span-2">
        <label class="block text-sm font-semibold text-slate-700 mb-2">Tìm kiếm</label>
        <input name="search" value="@ViewBag.Search" type="text"
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white" 
          placeholder="Tên quán, món ăn...">
      </div>

      <!-- Loại hình -->
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Loại hình</label>
        <select name="categoryId" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white">
          <option value="">Tất cả loại</option>
          <option value="1" @Html.Raw(catId=="1"?"selected":"")>🍽️ Nhà hàng</option>
          <option value="2" @Html.Raw(catId=="2"?"selected":"")>🥢 Ăn vặt</option>
          <option value="3" @Html.Raw(catId=="3"?"selected":"")>☕ Cà phê</option>
          <option value="4" @Html.Raw(catId=="4"?"selected":"")>🧋 Trà sữa</option>
          <option value="5" @Html.Raw(catId=="5"?"selected":"")>🍰 Bánh & Tráng miệng</option>
        </select>
      </div>

      <!-- Quận -->
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Quận</label>
        <select name="district" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white">
          <option value="">Tất cả quận</option>
          @foreach (var q in new[]{"Quận 1","Quận 3","Quận 4","Quận 5","Quận 10","Phú Nhuận","Bình Thạnh","Gò Vấp"}) {
            <option value="@q" @Html.Raw(dist==q?"selected":"")>@q</option>
          }
        </select>
      </div>

      <!-- Giá -->
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Giá/người</label>
        <select name="maxPrice" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white">
          <option value="">Mọi giá</option>
          <option value="30000"  @Html.Raw(maxPrc=="30000" ?"selected":"")>Dưới 30k</option>
          <option value="50000"  @Html.Raw(maxPrc=="50000" ?"selected":"")>Dưới 50k</option>
          <option value="100000" @Html.Raw(maxPrc=="100000"?"selected":"")>Dưới 100k</option>
          <option value="200000" @Html.Raw(maxPrc=="200000"?"selected":"")>Dưới 200k</option>
        </select>
      </div>

      <!-- Sắp xếp -->
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Sắp xếp</label>
        <select name="sortBy" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white">
          <option value=""           @Html.Raw(sort==""          ?"selected":"")>Sao cao nhất</option>
          <option value="name"       @Html.Raw(sort=="name"      ?"selected":"")>Tên A-Z</option>
          <option value="visits"     @Html.Raw(sort=="visits"    ?"selected":"")>Đông khách nhất</option>
          <option value="price_asc"  @Html.Raw(sort=="price_asc" ?"selected":"")>Giá thấp nhất</option>
          <option value="price_desc" @Html.Raw(sort=="price_desc"?"selected":"")>Giá cao nhất</option>
        </select>
      </div>

      <!-- Trạng thái -->
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Trạng thái</label>
        <select name="isApproved" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition bg-white">
          <option value="">Tất cả</option>
          <option value="true"  @Html.Raw(approved=="true" ?"selected":"")>✅ Duyệt</option>
          <option value="false" @Html.Raw(approved=="false"?"selected":"")>⏳ Chờ</option>
        </select>
      </div>
    </div>

    <!-- Buttons -->
    <div class="flex gap-3 pt-2">
      <button type="submit" class="flex items-center gap-2 px-6 py-2 text-white font-bold rounded-lg transition hover:shadow-lg"
        style="background: linear-gradient(135deg, #954400, #fc8127)">
        <span class="material-symbols-outlined text-lg">search</span>
        Lọc
      </button>
      <a asp-controller="Places" asp-action="Index" class="flex items-center gap-2 px-6 py-2 border border-slate-300 text-slate-700 font-bold rounded-lg hover:bg-slate-50 transition">
        <span class="material-symbols-outlined text-lg">refresh</span>
        Xóa lọc
      </a>
    </div>
  </form>
</div>

<!-- Places List -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr class="text-left text-sm font-semibold text-slate-700">
          <th class="px-6 py-4">Tên quán</th>
          <th class="px-6 py-4">Địa chỉ</th>
          <th class="px-6 py-4">Loại</th>
          <th class="px-6 py-4">Đặc trưng</th>
          <th class="px-6 py-4">Giá/người</th>
          <th class="px-6 py-4 text-center">⭐ Đánh giá</th>
          <th class="px-6 py-4 text-center">👥 Ghé</th>
          <th class="px-6 py-4">Trạng thái</th>
          <th class="px-6 py-4 text-center">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        @if (!Model.Any()) {
          <tr>
            <td colspan="9" class="px-6 py-12 text-center text-slate-500">
              <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-4xl text-slate-300">storefront</span>
                <p class="font-semibold">Chưa có quán nào</p>
                <a asp-controller="Places" asp-action="Create" class="text-primary hover:text-primary/80 font-semibold mt-2">
                  Thêm quán đầu tiên →
                </a>
              </div>
            </td>
          </tr>
        }
        @foreach (var p in Model) {
          <tr class="hover:bg-slate-50 transition">
            <td class="px-6 py-4">
              <div class="font-semibold text-slate-900">@p.Name</div>
            </td>
            <td class="px-6 py-4">
              <small class="text-slate-600">@p.Address</small>
            </td>
            <td class="px-6 py-4">
              <span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 text-xs font-semibold rounded-full">
                @p.CategoryName
              </span>
            </td>
            <td class="px-6 py-4">
              <small class="text-slate-600">@p.Specialty</small>
            </td>
            <td class="px-6 py-4">
              @if (p.PricePerPerson.HasValue) {
                <span class="font-semibold text-primary">~@p.PricePerPerson.Value.ToString("N0")đ</span>
              } else {
                <span class="text-slate-400 text-sm">-</span>
              }
            </td>
            <td class="px-6 py-4 text-center">
              <span class="text-yellow-500">★</span>
              <span class="font-semibold text-slate-700">@p.AverageRating.ToString("F1")</span>
            </td>
            <td class="px-6 py-4 text-center">
              <span class="font-semibold text-slate-700">@p.TotalVisits</span>
            </td>
            <td class="px-6 py-4">
              @if (p.IsApproved) {
                <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-700 text-xs font-semibold rounded-full">
                  ✅ Duyệt
                </span>
              } else {
                <span class="inline-block px-3 py-1 bg-amber-50 text-amber-700 text-xs font-semibold rounded-full">
                  ⏳ Chờ duyệt
                </span>
              }
            </td>
            <td class="px-6 py-4">
              <div class="flex gap-2 justify-center">
                <a asp-controller="Places" asp-action="Edit" asp-route-id="@p.PlaceId"
                   title="Chỉnh sửa"
                   class="p-2 text-primary hover:bg-primary/10 rounded-lg transition">
                  <span class="material-symbols-outlined text-lg">edit</span>
                </a>
                <a asp-controller="Reviews" asp-action="Index" asp-route-placeId="@p.PlaceId"
                   title="Xem đánh giá"
                   class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition">
                  <span class="material-symbols-outlined text-lg">rate_review</span>
                </a>
                <a asp-controller="Places" asp-action="Map"
                   title="Xem bản đồ"
                   class="p-2 text-emerald-600 hover:bg-emerald-50 rounded-lg transition">
                  <span class="material-symbols-outlined text-lg">map</span>
                </a>
                <form method="post" asp-controller="Places" asp-action="Delete"
                      asp-route-id="@p.PlaceId" class="inline"
                      onsubmit="return confirm('Xóa quán này? Hành động này không thể hoàn tác.')">
                  @Html.AntiForgeryToken()
                  <button type="submit" title="Xóa"
                    class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition">
                    <span class="material-symbols-outlined text-lg">delete</span>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  @{
    var totalPages  = (int)Math.Ceiling((double)ViewBag.Total / 20);
    var currentPage = (int)(ViewBag.Page ?? 1);
  }
  @if (totalPages > 1) {
    <div class="flex justify-between items-center px-6 py-4 border-t border-slate-200 bg-slate-50">
      <small class="text-slate-600 font-semibold">Trang <span class="text-slate-900">@currentPage</span> / @totalPages</small>
      <nav class="flex gap-1">
        @if (currentPage > 1) {
          <a href="?page=@(currentPage-1)&search=@ViewBag.Search&categoryId=@catId&isApproved=@approved&sortBy=@sort&district=@dist&maxPrice=@maxPrc"
             class="px-3 py-2 border border-slate-300 rounded-lg hover:bg-white transition text-slate-600 hover:text-slate-900">
            <span class="material-symbols-outlined text-lg">chevron_left</span>
          </a>
        }
        
        @for (int i = Math.Max(1, currentPage-2); i <= Math.Min(totalPages, currentPage+2); i++) {
          <a href="?page=@i&search=@ViewBag.Search&categoryId=@catId&isApproved=@approved&sortBy=@sort&district=@dist&maxPrice=@maxPrc"
             class="px-3 py-2 rounded-lg font-semibold transition @(i==currentPage ? "bg-primary text-white" : "border border-slate-300 text-slate-600 hover:bg-white")">
            @i
          </a>
        }
        
        @if (currentPage < totalPages) {
          <a href="?page=@(currentPage+1)&search=@ViewBag.Search&categoryId=@catId&isApproved=@approved&sortBy=@sort&district=@dist&maxPrice=@maxPrc"
             class="px-3 py-2 border border-slate-300 rounded-lg hover:bg-white transition text-slate-600 hover:text-slate-900">
            <span class="material-symbols-outlined text-lg">chevron_right</span>
          </a>
        }
      </nav>
    </div>
  }
</div>