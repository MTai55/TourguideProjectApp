@using TourismApp.Web.Models
@model List<TourismApp.Web.Models.PlaceViewModel>
@{ ViewData["Title"] = "Bản đồ địa điểm"; }

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0">🗺️ Bản đồ địa điểm</h4>
  <span class="badge bg-primary">@Model.Count địa điểm</span>
</div>

<div class="card shadow-sm">
  <div id="map" style="height:600px;border-radius:12px"></div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const places = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
const isAdmin = @Html.Raw(ViewBag.IsAdmin ? "true" : "false");

const map = L.map('map').setView([10.7769, 106.7009], 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

// Icon theo trạng thái OpenStatus
const icons = {
  'Open':   '🟢',
  'Busy':   '🟡',
  'Closed': '🔴'
};

places.forEach(p => {
  if (!p.latitude || !p.longitude) return;

  const statusIcon = icons[p.openStatus] || '⚫';
  const marker = L.marker([p.latitude, p.longitude]).addTo(map);
  marker.bindPopup(`
    <div style="min-width:220px">
      <strong>${statusIcon} ${p.name}</strong>
      <span class="badge bg-${p.status==='Active'?'success':'warning'}">${p.status}</span><br>
      <small>${p.address}</small><br>
      ⭐ ${p.averageRating?.toFixed(1)} | 📍 ${p.totalVisits} lượt ghé<br>
      ${p.specialty ? '🍽️ ' + p.specialty + '<br>' : ''}
      <div class="mt-2">
        <a href="/Places/Edit/${p.placeId}" class="btn btn-sm btn-primary">✏️ Sửa</a>
        <a href="/Reviews/ByPlace/${p.placeId}" class="btn btn-sm btn-outline-secondary ms-1">⭐</a>
      </div>
    </div>
  `);
});

if (places.length > 0) {
  const bounds = places.filter(p => p.latitude && p.longitude).map(p => [p.latitude, p.longitude]);
  if (bounds.length) map.fitBounds(bounds, { padding: [50, 50] });
}
</script>
}