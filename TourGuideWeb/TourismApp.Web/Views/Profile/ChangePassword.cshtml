@model TourismApp.Web.Models.ChangePasswordViewModel
@{ ViewData["Title"] = "Đổi mật khẩu"; }

<div class="flex items-center gap-3 mb-6 pt-2">
  <a asp-action="Index"
     class="flex items-center gap-1 text-on-surface-variant hover:text-primary transition-colors text-sm font-semibold">
    <span class="material-symbols-outlined text-lg">arrow_back</span> Quay lại
  </a>
  <span class="text-slate-300">/</span>
  <h2 class="text-2xl font-bold tracking-tight">Đổi mật khẩu</h2>
</div>

<div class="max-w-xl">
  <div class="bg-surface-container-lowest rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-surface-container flex items-center gap-2">
      <span class="material-symbols-outlined text-amber-600">lock</span>
      <h3 class="font-bold text-base">Thay đổi mật khẩu</h3>
    </div>
    <form asp-action="ChangePassword" method="post" class="p-6 space-y-5">
      @Html.AntiForgeryToken()

      <!-- Tips -->
      <div class="p-4 bg-blue-50 border border-blue-100 rounded-xl text-xs text-blue-700 space-y-1">
        <p class="font-bold flex items-center gap-1.5">
          <span class="material-symbols-outlined text-sm">info</span> Lưu ý bảo mật
        </p>
        <ul class="ml-5 list-disc space-y-0.5">
          <li>Mật khẩu tối thiểu 6 ký tự</li>
          <li>Nên dùng kết hợp chữ hoa, chữ thường, số</li>
          <li>Không dùng mật khẩu trùng với email hoặc tên</li>
        </ul>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1.5">
          Mật khẩu hiện tại <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <input asp-for="CurrentPassword" id="cur-pwd" type="password"
                 class="w-full px-4 py-3 pr-12 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="••••••••" />
          <button type="button" onclick="togglePwd('cur-pwd','eye1')"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors">
            <span id="eye1" class="material-symbols-outlined text-lg">visibility_off</span>
          </button>
        </div>
        <span asp-validation-for="CurrentPassword" class="text-red-500 text-xs mt-1 block"></span>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1.5">
          Mật khẩu mới <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <input asp-for="NewPassword" id="new-pwd" type="password"
                 class="w-full px-4 py-3 pr-12 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="••••••••" oninput="checkStrength(this.value)" />
          <button type="button" onclick="togglePwd('new-pwd','eye2')"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors">
            <span id="eye2" class="material-symbols-outlined text-lg">visibility_off</span>
          </button>
        </div>
        <!-- Strength bar -->
        <div class="mt-2 h-1.5 bg-surface-container rounded-full overflow-hidden">
          <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
        <p id="strength-label" class="text-xs mt-1 text-on-surface-variant"></p>
        <span asp-validation-for="NewPassword" class="text-red-500 text-xs mt-1 block"></span>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1.5">
          Xác nhận mật khẩu mới <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <input asp-for="ConfirmPassword" id="cfm-pwd" type="password"
                 class="w-full px-4 py-3 pr-12 bg-surface-container-low border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20"
                 placeholder="••••••••" />
          <button type="button" onclick="togglePwd('cfm-pwd','eye3')"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors">
            <span id="eye3" class="material-symbols-outlined text-lg">visibility_off</span>
          </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit"
                class="flex items-center gap-2 px-8 py-3.5 text-white font-bold rounded-xl text-sm hover:scale-[1.02] transition-all"
                style="background:linear-gradient(135deg,#d97706,#f59e0b)">
          <span class="material-symbols-outlined text-sm">lock_reset</span> Đổi mật khẩu
        </button>
        <a asp-action="Index"
           class="px-6 py-3.5 bg-surface-container-low text-on-surface font-bold rounded-xl text-sm hover:bg-surface-container-high transition-colors">
          Hủy
        </a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
  function togglePwd(inputId, iconId) {
    const inp  = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (inp.type === 'password') { inp.type = 'text';     icon.textContent = 'visibility'; }
    else                         { inp.type = 'password'; icon.textContent = 'visibility_off'; }
  }

  function checkStrength(pwd) {
    const bar   = document.getElementById('strength-bar');
    const label = document.getElementById('strength-label');
    let score = 0;
    if (pwd.length >= 6)                    score++;
    if (pwd.length >= 10)                   score++;
    if (/[A-Z]/.test(pwd))                  score++;
    if (/[0-9]/.test(pwd))                  score++;
    if (/[^A-Za-z0-9]/.test(pwd))           score++;

    const cfg = [
      { w:'0%',   color:'',              text:'' },
      { w:'25%',  color:'bg-red-500',    text:'Yếu' },
      { w:'50%',  color:'bg-amber-500',  text:'Trung bình' },
      { w:'75%',  color:'bg-blue-500',   text:'Khá mạnh' },
      { w:'100%', color:'bg-emerald-500',text:'Mạnh' },
    ][Math.min(score, 4)];

    bar.style.width = cfg.w;
    bar.className   = `h-full rounded-full transition-all duration-300 ${cfg.color}`;
    label.textContent = cfg.text;
    label.className   = `text-xs mt-1 ${cfg.color.replace('bg-','text-')}`;
  }
</script>
}
