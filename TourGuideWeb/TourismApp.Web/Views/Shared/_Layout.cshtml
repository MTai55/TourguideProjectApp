<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>@ViewData["Title"] — Phố Ẩm Thực HCM</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --sidebar-bg: #1e293b;
      --sidebar-width: 250px;
      --topbar-h: 60px;
    }
    body { background:#f1f5f9; font-size:14px; }
    .sidebar {
      width: var(--sidebar-width); height:100vh;
      background: var(--sidebar-bg); position:fixed; top:0; left:0;
      display:flex; flex-direction:column; z-index:100;
      box-shadow: 2px 0 8px rgba(0,0,0,.2);
    }
    .sidebar-brand {
      padding:20px 16px; color:#38bdf8; font-weight:800;
      font-size:18px; border-bottom:1px solid #334155;
      display:flex; align-items:center; gap:10px;
    }
    .sidebar-brand small { font-size:11px; color:#64748b; font-weight:400; display:block; }
    .nav-section {
      font-size:10px; font-weight:700; color:#475569;
      text-transform:uppercase; letter-spacing:1px; padding:16px 16px 4px;
    }
    .sidebar .nav-link {
      color:#94a3b8; padding:10px 16px; border-radius:0;
      border-left:3px solid transparent; transition:.15s;
      display:flex; align-items:center; gap:10px;
    }
    .sidebar .nav-link:hover, .sidebar .nav-link.active {
      color:#38bdf8; background:#0f172a; border-left-color:#38bdf8;
    }
    .sidebar-user {
      padding:12px 16px; border-top:1px solid #334155; margin-top:auto;
    }
    .sidebar-user .name { color:#e2e8f0; font-size:13px; font-weight:600; }
    .sidebar-user .role { color:#64748b; font-size:11px; }
    .topbar {
      position:fixed; top:0; left:var(--sidebar-width);
      right:0; height:var(--topbar-h); background:white;
      border-bottom:1px solid #e2e8f0; display:flex;
      align-items:center; justify-content:space-between;
      padding:0 24px; z-index:99; box-shadow:0 1px 4px rgba(0,0,0,.06);
    }
    .topbar-title { font-weight:700; color:#1e293b; font-size:16px; }
    .main-content {
      margin-left:var(--sidebar-width);
      margin-top:var(--topbar-h);
      padding:24px; min-height:calc(100vh - var(--topbar-h));
    }
    .stat-card { border:none; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,.06); }
    .stat-card .icon {
      width:48px; height:48px; border-radius:12px;
      display:flex; align-items:center; justify-content:center; font-size:22px;
    }
    #toast-container { position:fixed; bottom:20px; right:20px; z-index:9999; }
    .toast-item {
      background:white; border-radius:10px; padding:12px 16px; margin-top:8px;
      box-shadow:0 4px 16px rgba(0,0,0,.15); display:flex; align-items:center;
      gap:12px; min-width:280px; animation:slideIn .3s ease;
    }
    @@keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }
  </style>
</head>
<body>
@{
    var token    = Context.Session.GetString("JwtToken");
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
    var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString();
    var action   = ViewContext.RouteData.Values["action"]?.ToString();
}

@if (token != null)
{
    <div class="sidebar">
        <div class="sidebar-brand">
            <span style="font-size:28px">🍜</span>
            <div>
                <div>Phố Ẩm Thực</div>
                <small>TP. Hồ Chí Minh</small>
            </div>
        </div>

        <nav>
            @if (userRole == "Admin") {
                <a asp-controller="AdminDashboard" asp-action="Index" class="nav-link">Dashboard</a>
                <a asp-controller="AdminUsers" asp-action="Index" class="nav-link">Tài khoản</a>
                <a asp-controller="AdminPlaces" asp-action="Index" class="nav-link">Duyệt quán</a>
                <a asp-controller="AdminReviews" asp-action="Index" class="nav-link">Kiểm duyệt</a>
                <a asp-controller="AdminComplaints" asp-action="Index" class="nav-link">Khiếu nại</a>
            } else {
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link">Dashboard</a>
                <a asp-controller="Places" asp-action="Index" class="nav-link">Quán của tôi</a>
                <a asp-controller="Reviews" asp-action="Index" class="nav-link">Đánh giá</a>
                <a asp-controller="Promotions" asp-action="Index" class="nav-link">Khuyến mãi</a>
                <a asp-controller="Places" asp-action="Map" class="nav-link">Bản đồ</a>
            }
        </nav>

        <div class="sidebar-user">
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                     style="width:32px;height:32px;font-size:13px">
                    @userName?[0]
                </div>
                <div>
                    <div class="name">@userName</div>
                    <div class="role">@userRole</div>
                </div>
            </div>
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-sm btn-outline-danger w-100">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="topbar">
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="d-flex align-items-center gap-3">
            @if (userRole == "Admin")
            {
                <a asp-controller="AdminPlaces" asp-action="Index"
                   asp-route-pendingOnly="true" class="btn btn-warning btn-sm">
                    ⏳ Chờ duyệt
                </a>
            }
            else
            {
                <a asp-controller="Places" asp-action="Create" class="btn btn-primary btn-sm">
                    + Thêm quán ăn
                </a>
            }
        </div>
    </div>

    <div class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <div id="toast-container"></div>
}
else
{
    <div>@RenderBody()</div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function showToast(msg, type = 'success') {
    const colors = { success: '#22c55e', error: '#ef4444', info: '#3b82f6' };
    const icons  = { success: '✅', error: '❌', info: 'ℹ️' };
    const el = document.createElement('div');
    el.className = 'toast-item';
    el.innerHTML = `<span>${icons[type]}</span><span>${msg}</span>`;
    el.style.borderLeft = `4px solid ${colors[type]}`;
    document.getElementById('toast-container').appendChild(el);
    setTimeout(() => el.remove(), 4000);
}
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
const userId = '@Context.Session.GetInt32("UserId")';
if (userId) {
    const conn = new signalR.HubConnectionBuilder()
        .withUrl("http://localhost:5010/hubs/notifications")
        .withAutomaticReconnect()
        .build();

    conn.on("NewCheckIn", data => showToast(`📍 ${data.message}`, 'info'));
    conn.on("NewReview",  data => showToast(`⭐ ${data.message}`, 'success'));

    conn.start()
        .then(() => {
            document.getElementById('signalr-status').textContent = '● Online';
            document.getElementById('signalr-status').className = 'badge bg-success';
            conn.invoke("JoinOwnerGroup", userId);
        })
        .catch(() => {
            document.getElementById('signalr-status').textContent = '● Offline';
        });
}
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
