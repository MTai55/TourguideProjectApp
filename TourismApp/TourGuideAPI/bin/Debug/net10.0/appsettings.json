{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TourismAppDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "YourSuperSecretKey_MinimumLength32Chars!",
    "Issuer": "TourGuideAPI",
    "Audience": "TourismApp.Clients",
    "ExpiryMinutes": 1440
  },
  "GeoSettings": {
    "DefaultRadiusKm": 5.0,
    "MaxRadiusKm": 50.0,
    "CheckInRadiusMeters": 100
  },
  "Tracking": {
    "IntervalSeconds": 30,
    "RetentionDays": 90
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://yourdomain.com"
    ]
  }
}