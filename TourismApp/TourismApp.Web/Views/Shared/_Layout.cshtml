<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@ViewData["Title"] — TourGuide Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background: #f8f9fa; }
    .sidebar { width: 240px; min-height: 100vh; background: #1e293b; position: fixed; top: 0; left: 0; }
    .sidebar-brand { padding: 20px 16px; color: #38bdf8; font-weight: 700; font-size: 18px; border-bottom: 1px solid #334155; }
    .sidebar-brand small { display: block; font-size: 11px; color: #64748b; font-weight: 400; margin-top: 2px; }
    .sidebar .nav-link { color: #94a3b8; padding: 10px 16px; border-radius: 0; transition: .15s; }
    .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #38bdf8; background: #0f172a; border-left: 3px solid #38bdf8; }
    .sidebar .nav-link i { width: 20px; margin-right: 8px; }
    .sidebar .nav-section { font-size: 10px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 1px; padding: 12px 16px 4px; }
    .main-content { margin-left: 240px; padding: 24px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; margin: -24px -24px 24px; display: flex; justify-content: space-between; align-items: center; }
    .stat-card { border-radius: 12px; border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
  </style>
</head>
<body>

@{
  var token = Context.Session.GetString("JwtToken");
  var userName = Context.Session.GetString("UserName");
}

@if (token != null) {
  <div class="sidebar d-flex flex-column">
    <div class="sidebar-brand">
      🗺️ TourGuide
      <small>Portal Quản Lý</small>
    </div>
    <nav class="flex-grow-1 mt-2">
      <div class="nav-section">Tổng quan</div>
      <a href="/Dashboard" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
        <i class="bi bi-speedometer2"></i> Dashboard
      </a>
      <div class="nav-section">Quản lý</div>
      <a href="/Places" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Places" ? "active" : "")">
        <i class="bi bi-geo-alt"></i> Địa điểm
      </a>
      <a href="/Reviews" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reviews" ? "active" : "")">
        <i class="bi bi-star"></i> Đánh giá
      </a>
    </nav>
    <div class="p-3 border-top border-secondary">
      <div class="text-white small mb-1">👤 @userName</div>
      <a href="/Auth/Logout" class="btn btn-sm btn-outline-danger w-100">Đăng xuất</a>
    </div>
  </div>
  <div class="main-content">
    @if (TempData["Success"] != null) {
      <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }
    @RenderBody()
  </div>
} else {
  <div class="container">@RenderBody()</div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body></html>